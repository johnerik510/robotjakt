---
interface Props {
  author?: string;
  authorTitle?: string;
  authorImage?: string;
  authorBio?: string;
  datePublished?: string;
  dateModified?: string;
}

const {
  author = 'John Erik Johansson',
  authorTitle = 'Grundare & robotexpert',
  authorImage = '/images/john-erik-johansson.webp',
  authorBio = 'Teknikentusiast och robotexpert. Testat 50+ robotdammsugare, robotgräsklippare och poolrobotar i hemmet med fokus på prestanda, smart hem-integration och långsiktig hållbarhet.',
  datePublished,
  dateModified,
} = Astro.props;

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('sv-SE', { day: 'numeric', month: 'long', year: 'numeric' });
};

const showPublished = !!datePublished;
const showUpdated = !!dateModified && dateModified !== datePublished;
---

<div class="flex items-start gap-4 py-4 mb-6 border-y border-gray-200">
  <a href="/om-redaktionen/" aria-label={`Om ${author}`} class="shrink-0">
    <img src={authorImage} alt={author} class="w-14 h-14 rounded-full object-cover ring-2 ring-gray-100" width="56" height="56" loading="lazy" />
  </a>
  <div class="flex-1 min-w-0">
    <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
      <a href="/om-redaktionen/" class="font-semibold text-gray-900 hover:text-accent transition-colors">{author}</a>
      <span class="text-sm text-gray-500">{authorTitle}</span>
    </div>
    {authorBio && (
      <p class="text-xs text-gray-500 mt-1 leading-snug">{authorBio}</p>
    )}
    {(showPublished || showUpdated) && (
      <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 text-xs text-gray-500 mt-1.5">
        {showPublished && (
          <span>Publicerad: <time datetime={datePublished}>{formatDate(datePublished!)}</time></span>
        )}
        {showUpdated && (
          <span>Uppdaterad: <time datetime={dateModified}>{formatDate(dateModified!)}</time></span>
        )}
      </div>
    )}
  </div>
</div>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: author,
  url: 'https://robotjakt.se/om-redaktionen/',
  image: `https://robotjakt.se${authorImage}`,
  jobTitle: authorTitle,
  description: authorBio,
  knowsAbout: ['robotdammsugare', 'robotgräsklippare', 'poolrobotar', 'smart hem', 'Dreame', 'Roborock', 'Husqvarna'],
  worksFor: {
    '@type': 'Organization',
    name: 'Robotjakt',
    url: 'https://robotjakt.se'
  }
})} />
