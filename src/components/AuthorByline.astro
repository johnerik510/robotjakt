---
/**
 * Redaktionell byline.
 * Visar redaktionsnamn (länkad), kort metodbeskrivning, publicerings- + uppdateringsdatum.
 * Schema.org Organization JSON-LD inkluderad för structured data.
 */
interface Props {
  author?: string;
  authorTitle?: string;
  authorBio?: string;
  datePublished?: string;
  dateModified?: string;
}

const {
  author = 'Robotjakts redaktion',
  authorTitle = 'Oberoende jämförelse av konsumentrobotar',
  authorBio = 'Vi jämför robotdammsugare, robotgräsklippare och poolrobotar utifrån verifierbar data: tekniska specifikationer, kapacitet, navigeringsteknik, oberoende tester och recensioner samt aktuella priser hos svenska butiker, oberoende av provision.',
  datePublished,
  dateModified,
} = Astro.props;

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('sv-SE', { day: 'numeric', month: 'long', year: 'numeric' });
};

const showPublished = !!datePublished;
const showUpdated = !!dateModified && dateModified !== datePublished;
---

<div class="flex items-start gap-4 py-4 mb-6 border-y border-gray-200">
  <a href="/om-redaktionen/" aria-label={`Om ${author}`} class="shrink-0">
    <span class="flex items-center justify-center w-14 h-14 rounded-full bg-gray-100 text-accent ring-2 ring-gray-100" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 9.75h6M9 12h6m-6 2.25h3"/></svg>
    </span>
  </a>
  <div class="flex-1 min-w-0">
    <div class="leading-snug">
      <a href="/om-redaktionen/" class="font-semibold text-gray-900 hover:text-accent transition-colors">{author}</a>
      <span class="text-sm text-gray-500 block">{authorTitle}</span>
    </div>
    {(showPublished || showUpdated) && (
      <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 text-xs text-gray-500 mt-1.5">
        {showPublished && (
          <span>Publicerad: <time datetime={datePublished}>{formatDate(datePublished!)}</time></span>
        )}
        {showUpdated && (
          <span>Uppdaterad: <time datetime={dateModified}>{formatDate(dateModified!)}</time></span>
        )}
      </div>
    )}
  </div>
</div>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: author,
  url: 'https://robotjakt.se/om-redaktionen/',
  description: authorBio,
  knowsAbout: ['robotdammsugare', 'robotgräsklippare', 'poolrobotar', 'fönsterputsrobotar', 'smarta hem', 'Dreame', 'Roborock', 'Husqvarna', 'Ecovacs']
})} />
