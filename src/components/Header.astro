---
const dronareItems = [
  { label: 'Topplista', href: '/dronare/' },
  { label: 'För nybörjare', href: '/dronare-for-nyborjare/' },
  { label: 'Med kamera', href: '/dronare-med-kamera/' },
  { label: 'DJI Mini 5 Pro', href: '/dji-mini-5-pro/' },
  { label: 'DJI Air 3S', href: '/dji-air-3s/' },
];

const dammsugareItems = [
  { label: 'Topplista', href: '/' },
  { label: 'Köpguide', href: '/kopguide-robotdammsugare/' },
  { label: 'Med mopp', href: '/robotdammsugare-med-mopp/' },
  { label: 'Husdjur', href: '/robotdammsugare-husdjur/' },
  { label: 'Budget', href: '/billigaste-robotdammsugare/' },
];

const grasklippareItems = [
  { label: 'Topplista', href: '/robotgrasklippare/' },
  { label: 'Köpguide', href: '/kopguide-robotgrasklippare/' },
  { label: 'Utan slinga', href: '/robotgrasklippare-utan-slinga/' },
  { label: 'Budget', href: '/billigaste-robotgrasklippare/' },
];

const reservdelarItems = [
  { label: 'Alla reservdelar', href: '/reservdelar/' },
  { label: 'Dammsugare reservdelar', href: '/reservdelar/robotdammsugare/' },
  { label: 'Filter', href: '/reservdelar/filter/' },
  { label: 'Borstar', href: '/reservdelar/borstar/' },
  { label: 'Roborock', href: '/reservdelar/roborock/' },
  { label: 'Dreame', href: '/reservdelar/dreame/' },
  { label: 'Ecovacs', href: '/reservdelar/ecovacs/' },
  { label: 'Gräsklippare reservdelar', href: '/reservdelar/robotgrasklippare/' },
  { label: 'Knivar', href: '/reservdelar/knivar/' },
  { label: 'Husqvarna Automower', href: '/reservdelar/husqvarna/' },
];
---

<header class="sticky top-0 z-50 shadow-lg relative">
  <!-- USP-bar -->
  <div class="bg-accent text-white text-xs font-semibold py-2 px-4">
    <div class="max-w-7xl mx-auto flex items-center justify-center gap-4 sm:gap-8 flex-wrap">
      <span class="flex items-center gap-1.5">
        <svg class="w-3 h-3 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        20+ robotar testade
      </span>
      <span class="hidden sm:flex items-center gap-1.5">
        <svg class="w-3 h-3 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        Oberoende &amp; ärliga tester
      </span>
      <span class="hidden md:flex items-center gap-1.5">
        <svg class="w-3 h-3 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        Uppdaterat 2026
      </span>
      <span class="hidden md:flex items-center gap-1.5">
        <svg class="w-3 h-3 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        Alltid gratis guide
      </span>
    </div>
  </div>
  <!-- Mörk navbar -->
  <div class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center group hover:opacity-90 transition-opacity">
        <img src="/images/logo.svg" alt="Robotjakt" class="h-10 w-auto flex-shrink-0 group-hover:scale-105 transition-transform" width="197" height="40" />
      </a>
      <nav class="hidden md:flex items-center space-x-2" aria-label="Huvudnavigering">
        <!-- Drönare dropdown -->
        <div class="relative group">
          <a href="/dronare/" class="flex items-center gap-1 text-sm font-medium text-gray-200 hover:text-white transition-colors px-3 py-2 rounded-md hover:bg-primary-light">
            Drönare
            <svg class="w-4 h-4 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
          <div class="absolute left-0 top-full pt-1 hidden group-hover:block z-50 min-w-[180px]">
            <div class="bg-white rounded-lg shadow-lg border border-gray-100 py-1">
              {dronareItems.map((item) => (
                <a href={item.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-accent transition-colors">
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        </div>
        <!-- Robotdammsugare dropdown -->
        <div class="relative group">
          <a href="/" class="flex items-center gap-1 text-sm font-medium text-gray-200 hover:text-white transition-colors px-3 py-2 rounded-md hover:bg-primary-light">
            Robotdammsugare
            <svg class="w-4 h-4 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
          <div class="absolute left-0 top-full pt-1 hidden group-hover:block z-50 min-w-[180px]">
            <div class="bg-white rounded-lg shadow-lg border border-gray-100 py-1">
              {dammsugareItems.map((item) => (
                <a href={item.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-accent transition-colors">
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        </div>
        <!-- Robotgräsklippare dropdown -->
        <div class="relative group">
          <a href="/robotgrasklippare/" class="flex items-center gap-1 text-sm font-medium text-gray-200 hover:text-white transition-colors px-3 py-2 rounded-md hover:bg-primary-light">
            Robotgräsklippare
            <svg class="w-4 h-4 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
          <div class="absolute left-0 top-full pt-1 hidden group-hover:block z-50 min-w-[180px]">
            <div class="bg-white rounded-lg shadow-lg border border-gray-100 py-1">
              {grasklippareItems.map((item) => (
                <a href={item.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-accent transition-colors">
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        </div>
        <!-- Reservdelar dropdown -->
        <div class="relative group">
          <a href="/reservdelar/" class="flex items-center gap-1 text-sm font-medium text-gray-200 hover:text-white transition-colors px-3 py-2 rounded-md hover:bg-primary-light">
            Reservdelar
            <svg class="w-4 h-4 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
          <div class="absolute left-0 top-full pt-1 hidden group-hover:block z-50 min-w-[220px]">
            <div class="bg-white rounded-lg shadow-lg border border-gray-100 py-1">
              {reservdelarItems.map((item) => (
                <a href={item.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-accent transition-colors">
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        </div>
        <!-- Poolrobot -->
        <a href="/poolrobot/" class="text-sm font-medium text-gray-200 hover:text-white transition-colors px-3 py-2 rounded-md hover:bg-primary-light">
          Poolrobot
        </a>
        <!-- Fönsterputsrobot -->
        <a href="/fonsterputsrobot/" class="text-sm font-medium text-gray-200 hover:text-white transition-colors px-3 py-2 rounded-md hover:bg-primary-light">
          Fönsterputsrobot
        </a>
      </nav>
      <button id="mobile-menu-btn" class="md:hidden p-2.5 rounded-md hover:bg-primary-light transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center" aria-label="Öppna meny" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  </div>
  <nav id="mobile-menu" class="hidden md:hidden fixed left-0 right-0 bottom-0 z-40 bg-primary-dark border-t border-primary-light overflow-y-auto" style="top: var(--header-height, 0px);" aria-label="Mobilnavigering">
    <div class="px-4 py-2 divide-y divide-primary-light/30">

      <!-- Drönare accordion -->
      <div>
        <button class="mobile-accordion-btn w-full flex items-center justify-between px-2 py-4 text-sm font-semibold text-gray-100 hover:text-white" aria-expanded="false">
          Drönare
          <svg class="accordion-icon w-4 h-4 opacity-60 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-content hidden pb-1 space-y-0.5">
          {dronareItems.map((item) => (
            <a href={item.href} class="block px-4 py-3 text-sm text-gray-300 hover:text-white hover:bg-primary-light rounded-md transition-colors">
              {item.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Robotdammsugare accordion -->
      <div>
        <button class="mobile-accordion-btn w-full flex items-center justify-between px-2 py-4 text-sm font-semibold text-gray-100 hover:text-white" aria-expanded="false">
          Robotdammsugare
          <svg class="accordion-icon w-4 h-4 opacity-60 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-content hidden pb-1 space-y-0.5">
          {dammsugareItems.map((item) => (
            <a href={item.href} class="block px-4 py-3 text-sm text-gray-300 hover:text-white hover:bg-primary-light rounded-md transition-colors">
              {item.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Robotgräsklippare accordion -->
      <div>
        <button class="mobile-accordion-btn w-full flex items-center justify-between px-2 py-4 text-sm font-semibold text-gray-100 hover:text-white" aria-expanded="false">
          Robotgräsklippare
          <svg class="accordion-icon w-4 h-4 opacity-60 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-content hidden pb-1 space-y-0.5">
          {grasklippareItems.map((item) => (
            <a href={item.href} class="block px-4 py-3 text-sm text-gray-300 hover:text-white hover:bg-primary-light rounded-md transition-colors">
              {item.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Reservdelar accordion -->
      <div>
        <button class="mobile-accordion-btn w-full flex items-center justify-between px-2 py-4 text-sm font-semibold text-gray-100 hover:text-white" aria-expanded="false">
          Reservdelar
          <svg class="accordion-icon w-4 h-4 opacity-60 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-content hidden pb-1 space-y-0.5">
          {reservdelarItems.map((item) => (
            <a href={item.href} class="block px-4 py-3 text-sm text-gray-300 hover:text-white hover:bg-primary-light rounded-md transition-colors">
              {item.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Övriga kategorier -->
      <div>
        <a href="/poolrobot/" class="block px-2 py-4 text-sm font-semibold text-gray-100 hover:text-white hover:bg-primary-light rounded-md transition-colors">Poolrobot</a>
        <a href="/fonsterputsrobot/" class="block px-2 py-4 text-sm font-semibold text-gray-100 hover:text-white hover:bg-primary-light rounded-md transition-colors">Fönsterputsrobot</a>
      </div>

      <!-- Om Robotjakt -->
      <div>
        <a href="/om-redaktionen/" class="block px-2 py-4 text-sm font-semibold text-gray-400 hover:text-white hover:bg-primary-light rounded-md transition-colors">Om redaktionen</a>
        <a href="/sa-testar-vi/" class="block px-2 py-4 text-sm font-semibold text-gray-400 hover:text-white hover:bg-primary-light rounded-md transition-colors">Så testar vi</a>
      </div>
    </div>
  </nav>
  <!-- Backdrop: stänger menyn vid klick utanför -->
  <div id="mobile-backdrop" class="hidden fixed inset-0 z-30" aria-hidden="true"></div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-backdrop');

  function openMenu() {
    const headerEl = document.querySelector('header');
    const h = headerEl ? headerEl.getBoundingClientRect().bottom : 0;
    (menu as HTMLElement).style.top = h + 'px';
    menu?.classList.remove('hidden');
    backdrop?.classList.remove('hidden');
    btn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    menu?.classList.add('hidden');
    backdrop?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    // stäng alla accordions
    document.querySelectorAll('.mobile-accordion-content').forEach((c) => c.classList.add('hidden'));
    document.querySelectorAll('.accordion-icon').forEach((i) => (i as HTMLElement).style.transform = '');
    document.querySelectorAll('.mobile-accordion-btn').forEach((b) => b.setAttribute('aria-expanded', 'false'));
  }

  btn?.addEventListener('click', () => {
    menu?.classList.contains('hidden') ? openMenu() : closeMenu();
  });

  backdrop?.addEventListener('click', closeMenu);

  // Accordion
  document.querySelectorAll('.mobile-accordion-btn').forEach((b) => {
    b.addEventListener('click', () => {
      const content = b.nextElementSibling as HTMLElement;
      const icon = b.querySelector('.accordion-icon') as HTMLElement;
      const isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      b.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
