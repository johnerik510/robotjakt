---
interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumbs" class="w-full">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
  <ol class="flex flex-wrap items-center gap-1.5 text-xs text-text-lighter" itemscope itemtype="https://schema.org/BreadcrumbList">
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="/" itemprop="item" class="hover:text-accent transition-colors">
        <span itemprop="name">Hem</span>
      </a>
      <meta itemprop="position" content="1" />
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <span aria-hidden="true" class="text-text-lighter/50">/</span>
        {item.href ? (
          <a href={item.href} itemprop="item" class="hover:text-accent transition-colors">
            <span itemprop="name">{item.label}</span>
          </a>
        ) : (
          <span itemprop="name" class="text-text-light font-medium">{item.label}</span>
        )}
        <meta itemprop="position" content={String(i + 2)} />
      </li>
    ))}
  </ol>
  </div>
</nav>
