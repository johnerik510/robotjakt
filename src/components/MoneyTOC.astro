---
/**
 * Auto-TOC för money pages. Renderar "Detaljerad genomgång" + en numrerad
 * lista som byggs client-side från alla <h2> i artikeln som INTE har
 * data-toc-skip (eller ligger inuti ett element med data-toc-skip). H2:er utan
 * id får ett slug-id automatiskt. En kolumn, max 2 rader per post.
 */
interface Props {
  title?: string;
  scope?: string;
}
const { title = 'Detaljerad genomgång', scope = '[data-toc-scope]' } = Astro.props;
---

<nav class="not-prose my-6" aria-label={title} data-toc data-toc-scope-sel={scope}>
  <p class="font-heading text-sm font-semibold text-primary uppercase tracking-wide mb-2">{title}</p>
  <ol class="toc-list"></ol>
</nav>

<style is:global>
  nav[data-toc] .toc-list {
    list-style: decimal;
    margin: 0;
    padding-left: 1.4rem;
  }
  nav[data-toc] .toc-list li {
    line-height: 1.3;
    margin: 0;
    padding: 0.15rem 0;
  }
  nav[data-toc] .toc-list li::marker {
    color: var(--color-text-light);
    font-size: 0.8rem;
  }
  nav[data-toc] .toc-list a {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.9rem;
    color: var(--color-accent);
    text-decoration: none;
  }
  nav[data-toc] .toc-list a:hover { text-decoration: underline; }
  nav[data-toc] .toc-list .toc-prop { color: var(--color-text-light); font-weight: 400; }
  nav[data-toc] .toc-list .toc-name { font-weight: 600; }
</style>

<script>
  function slugify(s: string): string {
    return s.toLowerCase().trim()
      .replace(/\([^)]*\)/g, '')
      .replace(/[åä]/g, 'a').replace(/ö/g, 'o')
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-|-$/g, '');
  }

  document.querySelectorAll('nav[data-toc]').forEach((nav) => {
    const sel = nav.getAttribute('data-toc-scope-sel') || '[data-toc-scope]';
    const scope = document.querySelector(sel) || document.querySelector('main') || document.body;
    const list = nav.querySelector('.toc-list');
    if (!list) return;
    const used = new Set<string>();
    const h2s = Array.from(scope.querySelectorAll('h2')).filter(
      (h) => !h.hasAttribute('data-toc-skip')
        && !h.closest('[data-toc-skip]')
        && (h.textContent || '').trim().length > 0,
    );
    if (h2s.length < 3) { (nav as HTMLElement).style.display = 'none'; return; }

    h2s.forEach((h) => {
      let id = h.id;
      if (!id) {
        id = slugify(h.textContent || '');
        let unique = id, n = 2;
        while (used.has(unique) || document.getElementById(unique)) { unique = `${id}-${n++}`; }
        id = unique;
        h.id = id;
      }
      used.add(id);

      // Etikett: ta bara H2:ans egna textnod (exkludera badge-spans),
      // strippa ledande "N." / "#N." och avslutande "(Butik)".
      let raw = '';
      h.childNodes.forEach((n) => { if (n.nodeType === Node.TEXT_NODE) raw += n.textContent; });
      raw = (raw || h.textContent || '').trim()
        .replace(/^\s*#?\s*\d+[.)]\s*/, '')
        .replace(/\s*\([^)]*\)\s*$/, '')
        .replace(/\s{2,}/g, ' ')
        .trim();

      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${id}`;
      const comma = raw.indexOf(',');
      if (comma > 0) {
        const nameEl = document.createElement('span');
        nameEl.className = 'toc-name';
        nameEl.textContent = raw.slice(0, comma);
        const propEl = document.createElement('span');
        propEl.className = 'toc-prop';
        propEl.textContent = raw.slice(comma);
        a.appendChild(nameEl);
        a.appendChild(propEl);
      } else {
        a.textContent = raw;
      }
      li.appendChild(a);
      list.appendChild(li);
    });
  });
</script>
