---
/**
 * Slim answer-box (AEO) för money pages. Renderas högt på sidan, ovanför
 * featured-CTA. Får aldrig trycka ner CTA:n: håll svaret 30-50 ord.
 * Alltid bg-blue (aldrig grön/gul). Se feedback_answer_first_box_pattern.
 */
interface Props {
  question: string;
  answer: string;
}
const { question, answer } = Astro.props;
---

<div class="not-prose bg-blue-50 border border-blue-200 rounded-lg px-4 py-2.5 mb-4" data-toc-skip>
  <h2 class="text-sm font-bold text-blue-900 mb-0.5" data-toc-skip>{question}</h2>
  <p class="text-blue-800 text-[13px] leading-snug">{answer}</p>
</div>
