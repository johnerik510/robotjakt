---
interface Props {
  rank?: number;
  name: string;
  image?: string;
  price: string;
  rating: number;
  badge?: string;
  pros: string[];
  cons: string[];
  ctaText: string;
  ctaUrl: string;
  dataProduct?: string;
  reviewUrl?: string;
  amazonUrl?: string;
  proshopUrl?: string;
  kjellUrl?: string;
  dustinUrl?: string;
  teknikproffsetUrl?: string;
  robotdammsugarenUrl?: string;
  elonUrl?: string;
  komplettUrl?: string;
  neatsvorUrl?: string;
}

const { rank, name, image, price, rating, badge, pros, cons, ctaText, ctaUrl, dataProduct, reviewUrl, amazonUrl, proshopUrl, kjellUrl, dustinUrl, teknikproffsetUrl, robotdammsugarenUrl, elonUrl, komplettUrl, neatsvorUrl } = Astro.props;
const stars = Math.round(rating * 2) / 2;
---

<article class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow p-5" data-product={dataProduct || name}>
  <div class="flex flex-col sm:flex-row gap-5">
    <div class="flex-shrink-0 flex flex-col items-center gap-2">
      {rank && (
        <span class={`text-xs font-bold uppercase px-3 py-1 rounded-full ${rank === 1 ? 'bg-winner/10 text-winner' : 'bg-bg-alt text-text-light'}`}>
          {rank === 1 ? 'Bäst i test' : `#${rank}`}
        </span>
      )}
      {image ? (
        <div class="w-48 h-48 sm:w-56 sm:h-56 bg-gray-50 rounded-xl p-3 flex items-center justify-center">
          <img src={image} alt={name} class="w-full h-full object-contain" loading="lazy" width="200" height="200" />
        </div>
      ) : (
        <div class="w-48 h-48 sm:w-56 sm:h-56 bg-bg-alt rounded-xl flex items-center justify-center text-text-lighter">
          <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        </div>
      )}
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
        <h3 class="font-heading text-lg font-bold text-text">{name}</h3>
        <span class="text-lg font-bold text-text whitespace-nowrap">{price}</span>
      </div>
      {badge && <span class="inline-block text-xs font-semibold bg-accent/10 text-accent px-2 py-0.5 rounded-full mb-2">{badge}</span>}
      <div class="flex items-center gap-1 mb-3" aria-label={`Betyg: ${rating} av 5`}>
        {Array.from({ length: 5 }).map((_, i) => (
          <svg class={`w-4 h-4 ${i < Math.floor(stars) ? 'text-star' : i < stars ? 'text-star' : 'text-border'}`} fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
        <span class="text-sm font-medium text-text-light ml-1">{rating}/5</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4 text-sm">
        <div>
          <p class="font-semibold text-winner mb-1">Fördelar</p>
          <ul class="space-y-0.5">
            {pros.map(p => <li class="flex items-start gap-1.5"><span class="text-winner mt-0.5">+</span> {p}</li>)}
          </ul>
        </div>
        <div>
          <p class="font-semibold text-cta mb-1">Nackdelar</p>

          <ul class="space-y-0.5">
            {cons.map(c => <li class="flex items-start gap-1.5"><span class="text-cta mt-0.5">-</span> {c}</li>)}
          </ul>
        </div>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <a href={ctaUrl} rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center justify-center px-6 py-3 bg-cta text-white font-semibold rounded-lg hover:bg-cta-dark transition-colors min-h-[44px] text-sm">
          {ctaText}
          <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        </a>
        {amazonUrl && (
          <a href={amazonUrl} rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center justify-center px-5 py-3 border-2 border-cta text-cta font-semibold rounded-lg hover:bg-cta hover:text-white transition-colors min-h-[44px] text-sm">
            Amazon
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        )}
        {proshopUrl && (
          <a href={proshopUrl} rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center justify-center px-5 py-3 border-2 border-border text-text-light font-semibold rounded-lg hover:border-cta hover:text-cta transition-colors min-h-[44px] text-sm">
            Proshop
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        )}
        {kjellUrl && (
          <a href={kjellUrl} rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center justify-center px-5 py-3 border-2 border-border text-text-light font-semibold rounded-lg hover:border-cta hover:text-cta transition-colors min-h-[44px] text-sm">
            Kjell
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        )}
        {dustinUrl && (
          <a href={dustinUrl} rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center justify-center px-5 py-3 border-2 border-border text-text-light font-semibold rounded-lg hover:border-cta hover:text-cta transition-colors min-h-[44px] text-sm">
            Dustin
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        )}
        {teknikproffsetUrl && (
          <a href={teknikproffsetUrl} rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center justify-center px-5 py-3 border-2 border-border text-text-light font-semibold rounded-lg hover:border-cta hover:text-cta transition-colors min-h-[44px] text-sm">
            Teknikproffset
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        )}
        {robotdammsugarenUrl && (
          <a href={robotdammsugarenUrl} rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center justify-center px-5 py-3 border-2 border-border text-text-light font-semibold rounded-lg hover:border-cta hover:text-cta transition-colors min-h-[44px] text-sm">
            Robot-dammsugaren
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        )}
        {elonUrl && (
          <a href={elonUrl} rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center justify-center px-5 py-3 border-2 border-border text-text-light font-semibold rounded-lg hover:border-cta hover:text-cta transition-colors min-h-[44px] text-sm">
            Elon
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        )}
        {komplettUrl && (
          <a href={komplettUrl} rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center justify-center px-5 py-3 border-2 border-border text-text-light font-semibold rounded-lg hover:border-cta hover:text-cta transition-colors min-h-[44px] text-sm">
            Komplett
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        )}
        {neatsvorUrl && (
          <a href={neatsvorUrl} rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center justify-center px-5 py-3 border-2 border-border text-text-light font-semibold rounded-lg hover:border-cta hover:text-cta transition-colors min-h-[44px] text-sm">
            Neatsvor
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        )}
        {reviewUrl && (
          <a href={reviewUrl} class="inline-flex items-center text-accent hover:underline font-medium text-sm min-h-[44px]">
            Läs recension
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        )}
      </div>
    </div>
  </div>
</article>
