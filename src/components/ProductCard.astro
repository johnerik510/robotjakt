---
import { resolveMultiCTA, storeFromUrl } from '../lib/multi-cta';

interface Props {
  rank?: number;
  name: string;
  image?: string;
  price?: string;
  rating: number;
  badge?: string;
  pros: string[];
  cons: string[];
  ctaText?: string;
  ctaUrl?: string;
  brand?: string;       // Valfritt märke, auto-detekteras från name om ej angivet
  dataProduct?: string;
  reviewUrl?: string;
}

const { rank, name, image, price, rating, badge, pros, cons, ctaUrl, brand, dataProduct, reviewUrl } = Astro.props;

// Slå upp alla butiker som säljer produkten, sorterade efter provision
const fallbackStore = ctaUrl ? storeFromUrl(ctaUrl) : '';
const fallback = ctaUrl ? { store: fallbackStore, url: ctaUrl } : undefined;
const multi = resolveMultiCTA(name, brand, fallback);
const primaryUrl = multi?.primary.url ?? ctaUrl;
const primaryStore = (multi?.primary.store ?? fallbackStore) || 'Butik';
const otherCTAs = multi?.others ?? [];

// Märke: explicit prop annars första ordet i namnet (märkesförst i denna nisch)
const detectedBrand = (brand || name.split(' ')[0] || '').trim();
const initial = (detectedBrand.charAt(0) || name.charAt(0)).toUpperCase();
// Avdublettat namn: strippa märket om namnet börjar med det
const displayName = detectedBrand && name.startsWith(detectedBrand + ' ')
  ? (name.slice(detectedBrand.length).replace(/^[\s,-]+/, '') || name)
  : name;

const fullStars = Math.floor(rating);
const halfStar = rating % 1 >= 0.5;
const emptyStars = 5 - fullStars - (halfStar ? 1 : 0);
const gradientId = `half-${(detectedBrand + name).replace(/[^a-z0-9]/gi, '')}`;

// Gradient-badge-rad: vinnaren (rank 1) får grön-blå, övriga blå
const barGradient = rank === 1 ? 'from-winner to-accent' : 'from-accent to-primary';

const isExternal = primaryUrl?.startsWith('http') ?? false;
const rel = isExternal ? 'sponsored nofollow noopener noreferrer' : undefined;
const target = isExternal ? '_blank' : undefined;
const STAR = 'M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z';
---

<div class="not-prose bg-white rounded-2xl shadow-md hover:shadow-xl transition-shadow duration-300 overflow-hidden border border-border" data-product={dataProduct || name}>
  {badge && (
    <div class={`px-4 py-2 text-white text-sm font-bold text-center bg-gradient-to-r ${barGradient}`}>
      {badge}
    </div>
  )}
  <div class="p-3.5 sm:p-6">
    <div class="flex flex-col sm:flex-row gap-3 sm:gap-6">
      <!-- Produktbild -->
      <div class="flex-shrink-0 mx-auto sm:mx-0 relative">
        {image ? (
          <div class="w-32 h-32 sm:w-40 sm:h-44 rounded-xl overflow-hidden bg-gray-50 border border-border flex items-center justify-center relative">
            {rank && (
              <div class={`absolute top-2 left-2 z-10 w-7 h-7 sm:w-8 sm:h-8 rounded-full flex items-center justify-center shadow-md bg-gradient-to-br ${barGradient}`}>
                <span class="text-white text-xs sm:text-sm font-bold">#{rank}</span>
              </div>
            )}
            {primaryUrl ? (
              <a href={primaryUrl} rel={rel} target={target} aria-label={`Bra pris hos ${primaryStore}`} class="block w-full h-full">
                <img src={image} alt={name} class="w-full h-full object-contain p-2" loading="lazy" width="160" height="176" />
              </a>
            ) : (
              <img src={image} alt={name} class="w-full h-full object-contain p-2" loading="lazy" width="160" height="176" />
            )}
          </div>
        ) : (
          <div class={`w-32 h-32 sm:w-40 sm:h-44 rounded-xl flex flex-col items-center justify-center relative overflow-hidden border border-border bg-gradient-to-br ${barGradient}`}>
            {rank && (
              <div class="absolute top-2 left-2 w-7 h-7 sm:w-8 sm:h-8 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center">
                <span class="text-white text-xs sm:text-sm font-bold">#{rank}</span>
              </div>
            )}
            <span class="text-white text-4xl sm:text-5xl font-heading font-bold opacity-90 mb-1" style="text-shadow: 0 2px 8px rgba(0,0,0,0.2)">{initial}</span>
            <span class="text-white/90 text-[10px] sm:text-xs font-semibold tracking-wider uppercase px-3 text-center leading-tight">{detectedBrand}</span>
          </div>
        )}
      </div>

      <!-- Produktinfo -->
      <div class="flex-1 min-w-0">
        <div class="mb-2.5">
          {detectedBrand && <p class="text-text-light text-sm font-medium">{detectedBrand}</p>}
          <h3 class="text-lg sm:text-xl font-heading font-bold text-text leading-tight">
            {primaryUrl ? (
              <a href={primaryUrl} rel={rel} target={target} class="!text-text hover:!text-accent transition-colors no-underline">{displayName}</a>
            ) : (
              displayName
            )}
          </h3>
          <div class="flex items-center gap-0.5 mt-1.5" role="img" aria-label={`${rating} av 5 stjärnor`}>
            <span class="text-sm font-bold text-text mr-1.5">{rating}/5</span>
            {Array.from({ length: fullStars }).map(() => (
              <svg class="w-[18px] h-[18px] text-star" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d={STAR} /></svg>
            ))}
            {halfStar && (
              <svg class="w-[18px] h-[18px]" viewBox="0 0 20 20" aria-hidden="true">
                <defs><linearGradient id={gradientId}><stop offset="50%" stop-color="#f59e0b" /><stop offset="50%" stop-color="#e2e8f0" /></linearGradient></defs>
                <path fill={`url(#${gradientId})`} d={STAR} />
              </svg>
            )}
            {Array.from({ length: emptyStars }).map(() => (
              <svg class="w-[18px] h-[18px] text-gray-200" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d={STAR} /></svg>
            ))}
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-3">
          <div>
            <p class="text-xs font-semibold text-winner uppercase tracking-wider mb-1.5">Fördelar</p>
            <ul class="space-y-1">
              {pros.map((pro) => (
                <li class="text-sm text-text flex items-start gap-1.5">
                  <svg class="w-4 h-4 text-winner flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  {pro}
                </li>
              ))}
            </ul>
          </div>
          <div>
            <p class="text-xs font-semibold text-cta uppercase tracking-wider mb-1.5">Nackdelar</p>
            <ul class="space-y-1">
              {cons.map((con) => (
                <li class="text-sm text-text flex items-start gap-1.5">
                  <svg class="w-4 h-4 text-cta-light flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                  {con}
                </li>
              ))}
            </ul>
          </div>
        </div>

        {primaryUrl && (
          <div class="pt-3.5 mt-1 border-t border-border">
            <div class="flex items-center justify-between gap-3 mb-1.5">
              <span class="text-xs font-semibold text-text-light">Bra pris hos:</span>
              {price && <span class="text-xl font-heading font-bold text-text">{price}</span>}
            </div>
            <a
              href={primaryUrl}
              rel={rel}
              target={target}
              data-product={dataProduct || name}
              class="flex items-center justify-center gap-2 w-full px-6 py-4 rounded-xl bg-cta hover:bg-cta-dark text-white font-bold text-base sm:text-lg transition-colors duration-200 shadow-lg no-underline"
            >
              Bra pris hos {primaryStore}
              <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            </a>
            {otherCTAs.length > 0 && (
              <div class="flex flex-wrap items-center gap-2 mt-2.5">
                <span class="text-xs font-semibold text-text-light uppercase tracking-wide">Även hos:</span>
                {otherCTAs.map((o) => (
                  <a href={o.url} rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center px-3 py-1.5 rounded-lg border border-border text-xs font-semibold text-text-light hover:border-cta hover:text-cta transition-colors no-underline">
                    {o.store}
                  </a>
                ))}
              </div>
            )}
            {reviewUrl && (
              <a href={reviewUrl} class="inline-flex items-center text-text-light hover:text-accent font-medium text-sm mt-2.5 transition-colors">
                Läs vår fullständiga recension
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>
            )}
          </div>
        )}

        {!primaryUrl && reviewUrl && (
          <div class="pt-3.5 mt-1 border-t border-border">
            <a href={reviewUrl} class="inline-flex items-center text-text-light hover:text-accent font-medium text-sm transition-colors">
              Läs vår fullständiga recension
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</div>
