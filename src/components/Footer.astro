---
const robotdammsugare = [
  { label: 'Bästa robotdammsugare', href: '/' },
  { label: 'Med moppfunktion', href: '/robotdammsugare-med-mopp/' },
  { label: 'For husdjur', href: '/robotdammsugare-husdjur/' },
  { label: 'Budget under 4 000 kr', href: '/billigaste-robotdammsugare/' },
  { label: 'Köpguide', href: '/kopguide-robotdammsugare/' },
];

const robotgrasklippare = [
  { label: 'Bästa robotgräsklippare 2026', href: '/robotgrasklippare/' },
  { label: 'Köpguide', href: '/kopguide-robotgrasklippare/' },
  { label: 'Utan slinga', href: '/robotgrasklippare-utan-slinga/' },
  { label: 'Budgetmodeller', href: '/billigaste-robotgrasklippare/' },
];

const recensioner = [
  { label: 'Dreame X40 Ultra recension', href: '/dreame-x40-ultra/' },
  { label: 'Roborock S8 MaxV Ultra recension', href: '/roborock-s8-maxv-ultra/' },
  { label: 'Roborock Qrevo Master recension', href: '/roborock-qrevo-master/' },
];

const legal = [
  { label: 'Om oss', href: '/om-oss/' },
  { label: 'Kontakt', href: '/kontakt/' },
  { label: 'Integritetspolicy', href: '/integritetspolicy/' },
  { label: 'Affiliate-disclaimer', href: '/affiliate-disclaimer/' },
];
---

<footer class="bg-primary text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8">
      <div class="lg:col-span-1">
        <h3 class="font-heading text-white text-lg font-bold mb-4">Robotjakt</h3>
        <p class="text-sm leading-relaxed">
          Vi testar och jämför konsumentrobotar for den svenska marknaden. Oberoende recensioner av robotdammsugare, robotgräsklippare och poolrobotar.
        </p>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Robotdammsugare</h4>
        <ul class="space-y-2">
          {robotdammsugare.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Robotgrasklippare</h4>
        <ul class="space-y-2">
          {robotgrasklippare.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Recensioner</h4>
        <ul class="space-y-2">
          {recensioner.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Information</h4>
        <ul class="space-y-2">
          {legal.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-primary-light">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <p class="text-sm">
          &copy; 2026 Robotjakt.se. Alla rättigheter förbehållna.
        </p>
        <p class="text-xs text-text-lighter">
          Robotjakt.se innehåller affiliatelänkar. Vi kan få provision när du handlar via våra länkar, utan extra kostnad for dig.
        </p>
      </div>
    </div>
  </div>
</footer>
