---

<footer class="bg-primary text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-8 gap-8">
      <div class="col-span-2 md:col-span-3 lg:col-span-1">
        <h3 class="font-heading text-white text-lg font-bold mb-4">Robotjakt</h3>
        <p class="text-sm leading-relaxed">
          Vi testar och jämför konsumentrobotar för den svenska marknaden. Oberoende recensioner av robotdammsugare, robotgräsklippare, drönare och poolrobotar.
        </p>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Drönare</h4>
        <ul class="space-y-2">
          {dronare.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Robotdammsugare</h4>
        <ul class="space-y-2">
          {robotdammsugare.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Recensioner</h4>
        <ul class="space-y-2">
          {dammsugareRecensioner.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Robotgräsklippare</h4>
        <ul class="space-y-2">
          {robotgrasklippare.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Reservdelar</h4>
        <ul class="space-y-2">
          {reservdelar.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Pool & Fönster</h4>
        <ul class="space-y-2">
          {ovriga.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-white text-sm font-bold uppercase tracking-wider mb-4">Information</h4>
        <ul class="space-y-2">
          {legal.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-primary-light">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <p class="text-sm">
          &copy; 2026 Robotjakt.se. Alla rättigheter förbehållna.
        </p>
        <p class="text-xs text-gray-400">
          Robotjakt.se innehåller affiliatelänkar. Vi kan få provision när du handlar via våra länkar, utan extra kostnad för dig.
        </p>
      </div>
    </div>
