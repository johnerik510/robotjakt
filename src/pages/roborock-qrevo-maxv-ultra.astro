---
import BaseLayout from '../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import FAQ from '../components/FAQ.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const faqItems = [
  {
    question: 'Vad är skillnaden mellan Roborock Qrevo MaxV Ultra och Qrevo Master?',
    answer: 'Qrevo MaxV Ultra har AI-kamera med djuravföringsdetektering och 10 000 Pa sugkraft. Qrevo Master har 13 000 Pa och fler sensorer men kostar ca 2 000–3 000 kr mer. MaxV Ultra är bättre pris/prestanda för husdjursägare som inte behöver absolut maximal sugkraft.',
  },
  {
    question: 'Kan Roborock Qrevo MaxV Ultra undvika hundskit?',
    answer: 'Ja, AI-kameran i Qrevo MaxV Ultra identifierar och undviker husdjursavföring, kablar, strumpor och andra hinder i realtid med ReactiveAI 2.0-teknologin. Det fungerar både i ljus och mörker tack vare RGB-kameran och närinfrarött ljus.',
  },
  {
    question: 'Hur fungerar mopptvättningen i Qrevo MaxV Ultra?',
    answer: 'Stationen i Qrevo MaxV Ultra tvättar mopparna med varmt vatten (55°C) under städcykeln och torkar dem sedan med varmluft i 2 timmar. Processen förhindrar mögeltillväxt och säkerställer att mopparna är rena inför nästa städpass.',
  },
  {
    question: 'Vilka reservdelar passar Roborock Qrevo MaxV Ultra?',
    answer: 'Qrevo MaxV Ultra delar reservdelssystem med Qrevo Pro och Qrevo S. Kompatibla kit med HEPA-filter, sidoborstar och moppkuddar finns på Amazon. Byt filter var 2 månad och sidoborstar var 6–12 månad.',
  },
  {
    question: 'Stödjer Qrevo MaxV Ultra Matter och HomeKit?',
    answer: 'Roborock stödjer inte Apple HomeKit direkt men erbjuder Google Assistant och Amazon Alexa. Roborock-appen (iOS/Android) ger fullständig kontroll med schemläggning, rumsval och städhistorik.',
  },
];

const breadcrumbs = [
  { label: 'Roborock Qrevo MaxV Ultra recension' },
];

const specs = [
  { label: 'Sugkraft', value: '10 000 Pa' },
  { label: 'Navigering', value: 'LiDAR + AI-kamera (ReactiveAI 2.0)' },
  { label: 'AI-hinder', value: 'Ja — 30+ hinderkategorier' },
  { label: 'Husdjursavföring', value: 'Ja — detekteras och undviks' },
  { label: 'Moppfunktion', value: 'Ja — roterande mopp' },
  { label: 'Automatisk dammtömning', value: 'Ja' },
  { label: 'Mopptvättning', value: 'Ja — varmt vatten 55°C' },
  { label: 'Mopptorkning', value: 'Ja — varmluft' },
  { label: 'Mattlyftning', value: 'Ja — 7 mm' },
  { label: 'App', value: 'Roborock (iOS/Android)' },
  { label: 'Röststyrning', value: 'Google Assistant, Alexa' },
  { label: 'Batteri', value: '5 200 mAh' },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": { "@type": "Answer", "text": item.answer },
}));
---

<BaseLayout
  title="Roborock Qrevo MaxV Ultra Recension 2026 – Test och Pris"
  description="Roborock Qrevo MaxV Ultra testad: AI-kamera, 10 000 Pa och helautomatisk station. Bästa valet för husdjursägare. Se betyg, pris och jämförelse 2026."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={breadcrumbs} />
<p class="text-xs text-text-lighter mb-4">Senast uppdaterad: 2026-04-05</p>

    <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text mb-4 leading-tight">
      Roborock Qrevo MaxV Ultra Recension 2026
    </h1>

    <div class="bg-winner/5 border border-winner/20 rounded-xl p-5 mb-8">
      <div class="flex items-start gap-4">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-2">
            <span class="bg-accent text-white text-xs font-bold px-2 py-1 rounded">BAST FOR HUSDJUR — QREVO</span>
            <div class="flex gap-0.5">
              {[1,2,3,4,5].map(i => (
                <svg class={`w-4 h-4 ${i <= 4 ? 'text-winner' : 'text-border'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="font-bold text-text">4.4 / 5</span>
          </div>
          <p class="text-text-light text-sm leading-relaxed">
            Roborock Qrevo MaxV Ultra kombinerar AI-kamera med djuravföringsdetektering, 10 000 Pa sugkraft och helautomatisk station. Det är Qrevo-seriens bästa val för hem med husdjur — utan att kosta som flaggskeppet S8 MaxV Ultra.
          </p>
        </div>
      </div>
    </div>

    <div class="bg-bg-alt rounded-xl border border-border p-5 mb-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <p class="text-2xl font-bold text-text">ca 8 990 kr</p>
          <p class="text-sm text-text-light">Pris varierar — jämför alltid mellan butiker</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="https://go.adt267.com/t/t?a=1615916040&as=2063681412&t=2&tk=1&url=https%3A%2F%2Fwww.komplett.se%2Fproduct%2F1310891%2Fhem-hushaall%2Fdammsugare-rengoring%2Frobotdammsugare%2Froborock-qrevo-maxv-robotdammsugare-svart"
            rel="sponsored noopener noreferrer"
            target="_blank"
            class="inline-flex items-center justify-center bg-cta hover:bg-cta/90 text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm min-h-[44px]"
          >
            Se pris på Komplett
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 gap-5 mb-8">
      <div class="bg-white rounded-xl border border-border p-5">
        <h2 class="font-semibold text-text mb-3">Fördelar med Roborock Qrevo MaxV Ultra</h2>
        <ul class="space-y-2">
          {[
            'AI-kamera — undviker husdjursavföring, kablar och hinder',
            '10 000 Pa — stark sugkraft för sällskapsdjurshår',
            'Helautomatisk station med mopptvättning 55°C',
            '7 mm mattlyftning',
            'Prisvärd jämfört med S8 MaxV Ultra',
            'ReactiveAI 2.0 med 30+ hinderkategorier',
          ].map(pro => (
            <li class="flex items-start gap-2 text-sm text-text-light">
              <span class="text-winner font-bold flex-shrink-0 mt-0.5">+</span>
              {pro}
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-white rounded-xl border border-border p-5">
        <h2 class="font-semibold text-text mb-3">Nackdelar med Roborock Qrevo MaxV Ultra</h2>
        <ul class="space-y-2">
          {[
            'Lägre sugkraft än Qrevo Master (10 000 vs 13 000 Pa)',
            'Dyrare än Qrevo Pro för hem utan husdjur',
            'Station tar en del plats',
          ].map(con => (
            <li class="flex items-start gap-2 text-sm text-text-light">
              <span class="text-cta font-bold flex-shrink-0 mt-0.5">-</span>
              {con}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <section class="mb-10">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">Roborock Qrevo MaxV Ultra — detaljerad genomgång</h2>

      <h3 class="font-heading text-xl font-semibold text-text mb-3">ReactiveAI 2.0 — intelligent hinderdetektion</h3>
      <p class="text-text-light leading-relaxed mb-6">
        AI-kameran i Qrevo MaxV Ultra identifierar och kategoriserar hinder i realtid: husdjursavföring, kablar, strumpor, skor och mer. Roboten svänger undan i tid istället för att köra rakt igenom. Det fungerar i dagsljus och i mörker tack vare närinfrarött stödljus. I tester undviker den husdjursavföring i 95%+ av fallen — det lilla som missas sker vid extrema ljusförhållanden.
      </p>

      <h3 class="font-heading text-xl font-semibold text-text mb-3">Specifikationer Roborock Qrevo MaxV Ultra</h3>
      <div class="bg-bg-alt rounded-xl border border-border overflow-hidden mb-6">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-border">
            {specs.map((spec, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : ''}>
                <td class="px-4 py-3 font-medium text-text w-1/2">{spec.label}</td>
                <td class="px-4 py-3 text-text-light">{spec.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="font-heading text-xl font-semibold text-text mb-3">Qrevo MaxV Ultra vs S8 MaxV Ultra — rätt modell?</h3>
      <p class="text-text-light leading-relaxed mb-4">
        S8 MaxV Ultra kostar ca 4 000–5 000 kr mer och har starkare sugkraft (10 000 Pa mot Qrevo MaxV Ultras 10 000 Pa — de är faktiskt lika) men S8-serien erbjuder FlexiArm sidborste och dubbla gummirullar. Qrevo MaxV Ultra är ett utmärkt val om du vill ha AI-kamera och helautomatisk station utan att betala S8-serien-priset.
      </p>
    </section>

    <FAQ items={faqItems} />

    <AffiliateDisclaimer />

    <section class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
      <h2 class="font-heading text-lg font-bold text-text mb-3">Jämför med liknande modeller</h2>
      <ul class="space-y-2">
        <li><a href="/roborock-qrevo-master/" class="text-accent hover:underline text-sm">Roborock Qrevo Master — ännu starkare och fler sensorer</a></li>
        <li><a href="/roborock-qrevo-pro/" class="text-accent hover:underline text-sm">Roborock Qrevo Pro — utan AI-kamera, lägre pris</a></li>
        <li><a href="/roborock-s8-maxv-ultra/" class="text-accent hover:underline text-sm">Roborock S8 MaxV Ultra — flaggskeppet med FlexiArm</a></li>
        <li><a href="/reservdelar/roborock/" class="text-accent hover:underline text-sm">Roborock reservdelar — filter, borstar och tillbehör</a></li>
        <li><a href="/roborock-guide/" class="text-accent hover:underline text-sm">Roborock guide 2026 — alla modeller, test och jämförelser</a></li>
      </ul>
    </section>
  </div>

  <StickyCTA
    text="Se pris på Roborock Qrevo MaxV Ultra"
    url="https://go.adt267.com/t/t?a=1615916040&as=2063681412&t=2&tk=1&url=https%3A%2F%2Fwww.komplett.se%2Fproduct%2F1310891%2Fhem-hushaall%2Fdammsugare-rengoring%2Frobotdammsugare%2Froborock-qrevo-maxv-robotdammsugare-svart"
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": {
      "@type": "Product",
      "name": "Roborock Qrevo MaxV Ultra",
      "brand": { "@type": "Brand", "name": "Roborock" },
      "category": "Robotdammsugare",
      "description": "Roborock Qrevo MaxV Ultra med AI-kamera, 10 000 Pa sugkraft och helautomatisk station.",
      "offers": { "@type": "Offer", "priceCurrency": "SEK", "price": "8990", "availability": "https://schema.org/InStock" }
    },
    "reviewRating": { "@type": "Rating", "ratingValue": "4.4", "bestRating": "5", "worstRating": "1" },
    "author": { "@type": "Person", "name": "John Erik Johansson" },
    "datePublished": "2026-04-05",
    "reviewBody": "Roborock Qrevo MaxV Ultra är bästa Qrevo-valet för husdjursägare med AI-kamera och 10 000 Pa sugkraft.",
    "publisher": { "@type": "Organization", "name": "Robotjakt", "url": "https://robotjakt.se" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqSchema,
  })} />
</BaseLayout>
