  article={{ datePublished: "2026-05-16", dateModified: "2026-06-22", image: "/images/roborock-qrevo-master.webp" }}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6" data-toc-scope>
