const faqItems = [
  {
    question: 'Vilken robotdammsugare är bäst för husdjur 2026?',
    answer: 'Roborock S8 MaxV Ultra är vår toppranking för husdjursägare tack vare sina dubbla gummirullar som inte trasslas av djurhår, 10 000 Pa sugkraft som hanterar pälsklumpar, och AI-kamera som undviker djuravföring. Dreame X40 Ultra är ett utmärkt alternativ med ännu starkare sugkraft.',
  },
  {
    question: 'Trasslas borstrullen av katthår och hundhår?',
    answer: 'Modeller med gummirullar i stället för borstar (som Roborock S8 MaxV Ultra och Dreame X40 Ultra) trasslas nästan aldrig. Traditionella borsthuvuden kan trasslas av långa hår, speciellt från långhåriga katter och hundar. Välj alltid en modell med gummirullar om du har husdjur.',
