const faqItems = [
  {
    question: 'Vilken robotdammsugare är bäst i test 2026?',
    answer: 'Dreame X50 Ultra är vår testvinnare april 2026. Med 20 000 Pa sugkraft, VersaLift-navigering som når under låga möbler och en självrenande PowerDock är den bäst i klassen. Dreame X40 Ultra är ett starkt alternativ med sin unika utfällbara mopparm. Roborock S8 MaxV Ultra är bäst för husdjurshem tack vare AI-kameran som undviker djuravföring.',
  },
  {
    question: 'Är det värt att köpa en robotdammsugare med moppfunktion?',
    answer: 'Ja, för hem med hård- och halvhårdgolv. Dreame X40 Ultra har en utfällbar mopparm som når hörnen och torkar med 4 Newton tryckkraft, tillräckligt för intorkade fläckar. Roborock S8 MaxV Ultra kombinerar vibrerande mopphuvud (3 000 vibrationer/min) med automatisk mopplyftning när den kör över mattor. Modeller utan mopplyftning ska du undvika om du har heltäckningsmattor, de blöter ner dem. Se vår guide om robotdammsugare med mopp för fler alternativ.',
  },
  {
    question: 'Vilken robotdammsugare är bäst för husdjur?',
    answer: 'För djurägare rekommenderar vi modeller med stark sugkraft (minst 8 000 Pa) och gummirullar som inte trasslas av päls. Roborock S8 MaxV Ultra har en AI-kamera som identifierar och undviker djuravföring. Dreame X40 Ultra och Roborock Qrevo Master klarar djurhår utmärkt. Se vår guide: Robotdammsugare för husdjur.',
  },
  {
    question: 'Hur ofta behöver man tömma en robotdammsugare?',
    answer: 'Dreame X50 Ultra och X40 Ultra har stationer med dammpose på 2,5 liter som räcker 45 till 75 dagar i ett normalt hushåll. Roborock S8 MaxV Ultra och Qrevo Master har stationer med påsar på 2,5 liter, ungefär samma frekvens. Modeller utan självtömmande station, som Neatsvor X650 Pro, kräver att du tömmer behållaren efter varje cykel (ca 250 ml). Nästan alla premiummodeller från 2025 och framåt inkluderar självtömmande station som standard.',
  },
  {
    question: 'Kan en robotdammsugare ersätta en vanlig dammsugare?',
    answer: 'För daglig underhållsstädning ja. En robotdammsugare håller golven rena mellan mer grundliga städningar. För djuprengöring av soffor, trappor och svåråtkomliga ställen behöver du fortfarande en vanlig eller sladdlös dammsugare.',
  },
  {
    question: 'Vad är LiDAR-navigering och varför är det viktigt?',
    answer: 'LiDAR är en lasersensor som skapar en exakt karta av hemmet i realtid. Det ger effektivare städrutter, bättre hinderundvikning och möjlighet att sätta no-go-zoner i appen. Budget-modeller utan LiDAR navigerar slumpmässigt och missar ytor. Nästan alla mellanklassrobotar och uppåt har LiDAR 2026.',
  },
  {
    question: 'Säljer Husqvarna robotdammsugare?',
    answer: 'Nej, Husqvarna tillverkar robotgräsklippare (Automower-serien) och inte robotdammsugare. Letar du efter Husqvarna är det utomhusrobotar du hittar. Vill du ha en robotdammsugare med samma fokus på kvalitet och support, titta på Dreame, Roborock eller iRobot, som alla har auktoriserade svenska återförsäljare.',
  },
  {
    question: 'Vilken robotdammsugare passar bäst i lägenhet?',
    answer: 'Roborock Q Revo och Dreame L20 Ultra är våra starkaste rekommendationer för lägenheter. Båda är 9,5 cm höga, klarar 1 till 2 cm trösklar och navigerar effektivt i korridortunga planlösningar med LiDAR. Roborock Q Revo har dubbla roterande moppar och en station som tvättar mopparna automatiskt, vilket är praktiskt i en lägenhet där du inte har utrymme för ett separat mopphinksystem. Se vår fullständiga guide om robotdammsugare för lägenhet för fler alternativ.',
  },
];

const breadcrumbs = [
  { label: 'Robotdammsugare' },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": item.answer,
  },
}));
