export const articleMeta = {
  title: "Bästa budget-robotdammsugare 2026: jämförda prisval",
  description: "Bästa budget-robotdammsugarna 2026 jämförda. LiDAR och app-styrning till lågt pris. Se topplista med specifikationer, betyg och bästa köp under 3 000 kr.",
