import StickyCTA from '../../components/StickyCTA.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const breadcrumbs = [
  { label: 'Robotdammsugare', href: '/robotdammsugare/' },
  { label: 'Med LiDAR' },
];

