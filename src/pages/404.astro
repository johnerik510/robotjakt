---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sidan hittades inte | Robotjakt" description="Sidan du letar efter finns inte.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <h1 class="font-heading text-6xl font-bold text-text mb-4">404</h1>
    <p class="text-text-light mb-8">Sidan du letar efter finns inte eller har flyttats.</p>
    <a href="/" class="inline-flex items-center px-6 py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent-dark transition-colors min-h-[44px]">
      Till startsidan
    </a>
  </div>
</BaseLayout>
