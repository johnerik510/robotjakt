      <div class="overflow-x-auto rounded-xl border border-border">
        <table class="w-full text-sm bg-white">
          <thead>
            <tr class="border-b border-border bg-bg-alt">
              <th class="text-left px-4 py-3 font-semibold text-text">Egenskap</th>
              <th class="text-left px-4 py-3 font-semibold text-text">Husqvarna Automower 430V NERA</th>
              <th class="text-left px-4 py-3 font-semibold text-text">Mammotion LUBA 3 AWD 3000X</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr class="bg-bg-alt/30">
              <td class="px-4 py-3 font-medium text-text">Max yta</td>
              <td class="px-4 py-3 text-winner font-semibold">4 800 m²</td>
              <td class="px-4 py-3 text-text-light">3 000 m²</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-text">Gränskabel krävs</td>
              <td class="px-4 py-3 text-winner font-semibold">Nej, slinglös</td>
              <td class="px-4 py-3 text-winner font-semibold">Nej, slinglös</td>
            </tr>
            <tr class="bg-bg-alt/30">
              <td class="px-4 py-3 font-medium text-text">Navigeringsteknik</td>
              <td class="px-4 py-3 text-text-light">Satellit + AI-vision</td>
              <td class="px-4 py-3 text-text-light">LiDAR + RTK + AI-kameror</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-text">Drivning</td>
              <td class="px-4 py-3 text-text-light">Tvåhjulsdrift</td>
              <td class="px-4 py-3 text-winner font-semibold">Fyrhjulsdrift (AWD)</td>
            </tr>
            <tr class="bg-bg-alt/30">
              <td class="px-4 py-3 font-medium text-text">Max lutning</td>
              <td class="px-4 py-3 text-text-light">50 %</td>
              <td class="px-4 py-3 text-winner font-semibold">Upp till 80 % (AWD)</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-text">Klippbredd</td>
              <td class="px-4 py-3 text-text-light">24 cm</td>
              <td class="px-4 py-3 text-winner font-semibold">40 cm</td>
            </tr>
            <tr class="bg-bg-alt/30">
