              <td class="px-4 py-3 text-text-light">20-60 mm</td>
              <td class="px-4 py-3 text-text-light">25-70 mm</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-text">Bullernivå</td>
              <td class="px-4 py-3 text-winner font-semibold">56 dB(A)</td>
              <td class="px-4 py-3 text-text-light">70 dB(A)</td>
