---
import BaseLayout from '../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import FAQ from '../components/FAQ.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbs = [
  { label: 'Fönsterputsrobot' },
];

const faqItems = [
  {
    question: 'Klarar en fönsterputsrobot fönster utan ram?',
    answer: 'Det beror på modellen. Ecovacs Winbot W2 Omni är speciellt konstruerad för ramfria fönster och använder AI-säkerhetsdetektering för att känna igen glaskanten utan fysisk ram. Enklare modeller som W1 Pro och Liectroux WS-1080 kräver en ram att stanna mot — de kan inte användas utan ram eftersom de inte kan identifiera glasets kant.',
  },
  {
    question: 'Kan fönsterputsrobotar användas utomhus?',
    answer: 'Ja, men det beror på smutsnivån och väderförhållandena. Ecovacs Winbot W2 Omni och W1 Pro fungerar bra utomhus på normalt smutsiga fönster. Vid kraftigt ingroat smuts, kalkfläckar eller fågelspillning kan roboten behöva köra flera cykler eller smutsen förbehandlas med lämpligt fönsterputsmedel. Kör aldrig roboten i regn eller blåsigt väder.',
  },
  {
    question: 'Hur länge tar det för en robot att putsa ett fönster?',
    answer: 'Ett standardfönster på ca 80 x 120 cm tar ungefär 5–10 minuter för en fönsterputsrobot. Större fönster, balkongräcken av glas eller panoramafönster tar proportionellt längre tid. Winbot W2 Omni är snabbast i vart test och klarar ett standardfönster på ca 5 minuter.',
  },
  {
    question: 'Är fönsterputsrobotar säkra — kan de ramla ner?',
    answer: 'Alla seriösa fönsterputsrobotar har inbyggda säkerhetssystem. Winbot W2 Omni har AI-detektering av glasets kant. W1 Pro och Liectroux WS-1080 har en säkerhetsline som ingår i förpackningen — du fäster linan i roboten och i ett ankare på väggen som backup. Säkerhetslinan aktiveras bara om vakuumsugningen skulle svikta. Alltid med säkerhetsline vid tvätteriet på höga höjder.',
  },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": item.answer,
  },
}));
---

<BaseLayout
  title="Fönsterputsrobot April 2026 — Bästa modellerna testad"
  description="Vi jämför de bästa fönsterputsrobotarna 2026. Hitta rätt modell för dina fönster — inomhus, utomhus och takfönster. Priser och recensioner."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
