---
import BaseLayout from '../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import FAQ from '../components/FAQ.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbs = [
  { label: 'Robotgräsklippare', href: '/robotgrasklippare/' },
  { label: 'Mammotion LUBA AWO 3000 vs Segway Navimow H800E' },
];

const faqItems = [
  {
    question: 'Mammotion LUBA AWO 3000 eller Segway Navimow H800E — vilket ska jag välja?',
    answer: 'LUBA AWO 3000 passar dig med kuperad terräng — 75% lutningstolerans mot H800E:s 45% är en avgörande skillnad. H800E är enklare att installera och kräver ingen RTK-antenn, vilket gör den mer lämpad för öppna, plana tomter med god GPS-mottagning. Välj LUBA för brant mark och komplexa hinder, välj H800E för enkla öppna tomter.',
  },
  {
    question: 'Behöver båda modellerna perimeterkabel?',
    answer: 'Nej — varken LUBA AWO 3000 eller Segway Navimow H800E kräver perimeterkabel. LUBA AWO 3000 använder RTK GPS (centimeterprecision) + referensantenn. H800E använder Exact!Fusion med GPS, IMU och visuell detektion. Båda är slingfria och gränser ritas i respektive app.',
  },
  {
    question: 'Klarar LUBA AWO 3000 brantare backar än Segway H800E?',
    answer: 'Ja, klart. LUBA AWO 3000 klarar 75% lutning mot H800E:s 45%. Om din trädgård har backar brantare än 45% är LUBA det enda alternativet av dessa två. Lutning är den starkaste anledningen att välja LUBA framför H800E.',
  },
  {
    question: 'Vad kostar respektive modell?',
    answer: 'Mammotion LUBA AWO 3000 kostar ca 24 990 kr. Segway Navimow H800E kostar ca 17 990 kr. LUBA är ca 7 000 kr dyrare men motiverar det med 75% lutning mot H800E:s 45% och 4G-uppkoppling mot H800E:s WiFi. Prioriterar du priset är H800E det bättre valet för plan terräng.',
  },
  {
    question: 'Vilken har enklast installation?',
    answer: 'Segway Navimow H800E är något enklare att installera. Du placerar stationen och ritar gränserna i appen — ingen RTK-antenn behöver monteras. LUBA AWO 3000 kräver att du monterar en RTK-referensantenn med fri himmelssikt, vilket tar extra tid men ger mer precis navigering. Båda är avsevärt enklare än att gräva ner perimeterkabel.',
  },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": item.answer,
  },
}));
---

<BaseLayout
  title="Mammotion LUBA AWO 3000 vs Segway Navimow H800E 2026 — Jämförelse"
  description="Vi jämför Mammotion LUBA AWO 3000 och Segway Navimow H800E. Båda är slingfria — men LUBA klarar 75% lutning mot H800E:s 45%. Vilket passar din trädgård?"
>
  <section class="bg-gradient-to-br from-primary to-primary-dark text-white py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} light={true} />
      <h1 class="font-heading text-2xl sm:text-3xl font-bold mb-2">Mammotion LUBA AWO 3000 vs Segway Navimow H800E 2026</h1>
      <p class="text-gray-300 text-sm max-w-2xl">Båda är slingfria GPS-robotar för ca 3 000 m² — men de skiljer sig kraftigt i lutningstolerans, navigeringsteknik och pris.</p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <p class="text-text-light mb-4 text-base">
      Mammotion LUBA AWO 3000 och Segway Navimow H800E är de två starkaste slingfria alternativen för medelstora trädgårdar 2026. Ingen av dem kräver perimeterkabel — men de fungerar fundamentalt olika och passar olika tomter.
    </p>
    <p class="text-text-light mb-6 text-base">
      Kortfattat: LUBA AWO 3000 vinner på kuperad terräng, H800E på enkel installation och pris.
    </p>

    <h2 class="font-heading text-xl font-bold mt-6 mb-4">Snabbjämförelse</h2>
    <div class="mb-8">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-primary text-white">
            <th class="p-3 text-left font-semibold">Egenskap</th>
            <th class="p-3 text-left font-semibold">LUBA AWO 3000</th>
            <th class="p-3 text-left font-semibold">Navimow H800E</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-border bg-white">
            <td class="p-3 font-medium text-text">Max yta</td>
            <td class="p-3 text-text-light">3 000 m²</td>
            <td class="p-3 text-text-light">3 000 m²</td>
          </tr>
          <tr class="border-b border-border">
            <td class="p-3 font-medium text-text">Lutning</td>
            <td class="p-3 text-text-light font-semibold text-winner">75%</td>
            <td class="p-3 text-text-light">45%</td>
          </tr>
          <tr class="border-b border-border bg-white">
            <td class="p-3 font-medium text-text">Klippbredd</td>
            <td class="p-3 text-text-light font-semibold text-winner">26 cm</td>
            <td class="p-3 text-text-light">22 cm</td>
          </tr>
          <tr class="border-b border-border">
            <td class="p-3 font-medium text-text">Navigering</td>
            <td class="p-3 text-text-light">RTK GPS + antenn</td>
            <td class="p-3 text-text-light">Exact!Fusion GPS</td>
          </tr>
          <tr class="border-b border-border bg-white">
            <td class="p-3 font-medium text-text">Slingkabel</td>
            <td class="p-3 text-text-light">Nej</td>
            <td class="p-3 text-text-light">Nej</td>
          </tr>
          <tr class="border-b border-border">
            <td class="p-3 font-medium text-text">Uppkoppling</td>
            <td class="p-3 text-text-light font-semibold text-winner">4G</td>
            <td class="p-3 text-text-light">WiFi</td>
          </tr>
          <tr class="border-b border-border bg-white">
            <td class="p-3 font-medium text-text">Drifttid</td>
            <td class="p-3 text-text-light">120 min</td>
            <td class="p-3 text-text-light">120 min</td>
          </tr>
          <tr class="border-b border-border">
            <td class="p-3 font-medium text-text">Laddtid</td>
            <td class="p-3 text-text-light">90 min</td>
            <td class="p-3 text-text-light font-semibold text-winner">90 min</td>
          </tr>
          <tr class="bg-white">
            <td class="p-3 font-medium text-text">Pris</td>
            <td class="p-3 text-text-light">ca 24 990 kr</td>
            <td class="p-3 font-bold text-winner">ca 17 990 kr</td>
          </tr>
        </tbody>
      </table>
    </div>

    <h2 class="font-heading text-xl font-bold mt-8 mb-4">Lutningstolerans — den avgörande skillnaden</h2>
    <p class="text-text-light mb-4 text-base">
      LUBA AWO 3000 klarar 75% lutning. Segway Navimow H800E klarar 45%. Det är ingen liten skillnad — det är skillnaden mellan en robot som tar sig upp för en brant sluttning och en som stoppar halvvägs.
    </p>
    <p class="text-text-light mb-6 text-base">
      Har du en trädgård med backar brantare än 45% är valet enkelt: LUBA AWO 3000. H800E är däremot fullt kapabel för en plan eller måttligt kuperad tomt — men det är den enda modellen av dessa två som kan prestera optimalt på brant mark.
    </p>

    <h2 class="font-heading text-xl font-bold mt-8 mb-4">Navigeringsteknik — RTK vs Exact!Fusion</h2>
    <p class="text-text-light mb-4 text-base">
      LUBA AWO 3000 använder RTK GPS med en fast referensantenn för centimeterprecision. Systemet är stabilt och pålitligt men kräver att referensantennen monteras med fri himmelssikt.
    </p>
    <p class="text-text-light mb-6 text-base">
      Segway Navimow H800E använder Exact!Fusion — en kombination av GPS, IMU och visuell detektion. Det kräver ingen separat antenn men är mer beroende av god GPS-mottagning på tomten. Under tät trädkrona kan prestandan variera mer än med LUBA:s RTK-system.
    </p>

    <h2 class="font-heading text-xl font-bold mt-8 mb-4">Uppkoppling — 4G vs WiFi</h2>
    <p class="text-text-light mb-4 text-base">
      LUBA AWO 3000 har inbyggd 4G vilket innebär att du kan styra roboten var du än befinner dig utan att vara hemma i WiFi-nätets räckvidd. H800E är WiFi-baserad — du behöver antingen vara hemma i nätverket eller ha en annan lösning för fjärrstyrning.
    </p>
    <p class="text-text-light mb-6 text-base">
      4G är en klar fördel för dig som vill ha full kontroll på distans. WiFi räcker för de flesta hemma-scenarion men är en begränsning när du är på semester.
    </p>

    <div class="grid sm:grid-cols-2 gap-5 mb-8">
      <div class="bg-winner/5 border border-winner/20 rounded-xl p-5">
        <h3 class="font-semibold text-text mb-3">Välj LUBA AWO 3000 om du...</h3>
        <ul class="space-y-2">
          {[
            'Har backar brantare än 45%',
            'Vill ha 4G-fjärrstyrning',
            'Har en komplex trädgård med hinder',
            'Prioriterar navigeringsprecision',
          ].map(item => (
            <li class="flex items-start gap-2 text-sm text-text-light">
              <span class="text-winner font-bold flex-shrink-0 mt-0.5">+</span>
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-4">
          <a href="https://www.maskinklippet.se/tradgard/robotgrasklippare-och-tillbehor/robotgrasklippare/mammotion-luba-2-awd-3000x-robotgrasklippare" rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center justify-center bg-cta hover:bg-cta-dark text-white font-semibold px-4 py-2 rounded-lg text-sm w-full min-h-[44px]">
            Se pris på LUBA AWO 3000
          </a>
        </div>
      </div>
      <div class="bg-accent/5 border border-accent/20 rounded-xl p-5">
        <h3 class="font-semibold text-text mb-3">Välj Segway Navimow H800E om du...</h3>
        <ul class="space-y-2">
          {[
            'Har plan eller måttligt kuperad tomt',
            'Vill ha enklast möjliga installation',
            'Prioriterar lägre pris',
            'Har god GPS-mottagning på tomten',
          ].map(item => (
            <li class="flex items-start gap-2 text-sm text-text-light">
              <span class="text-accent font-bold flex-shrink-0 mt-0.5">+</span>
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-4">
          <a href="https://www.pricerunner.se/search?q=segway+navimow+h800e" rel="sponsored noopener noreferrer" target="_blank" class="inline-flex items-center justify-center bg-accent hover:bg-accent/90 text-white font-semibold px-4 py-2 rounded-lg text-sm w-full min-h-[44px]">
            Jämför pris på H800E
          </a>
        </div>
      </div>
    </div>

    <FAQ items={faqItems} />

    <AffiliateDisclaimer />

    <section class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
      <h2 class="font-heading text-lg font-bold text-text mb-3">Relaterade recensioner</h2>
      <ul class="space-y-2">
        <li><a href="/mammotion-luba-awo-3000/" class="text-accent hover:underline text-sm">Mammotion LUBA AWO 3000 — fullständig recension</a></li>
        <li><a href="/segway-navimow-h800e/" class="text-accent hover:underline text-sm">Segway Navimow H800E — fullständig recension</a></li>
        <li><a href="/mammotion-luba-2-awd-5000x/" class="text-accent hover:underline text-sm">Mammotion LUBA 2 AWD 5000X — flaggskeppsmodellen</a></li>
        <li><a href="/robotgrasklippare-utan-slinga/" class="text-accent hover:underline text-sm">Bästa robotgräsklippare utan slinga 2026</a></li>
        <li><a href="/robotgrasklippare/" class="text-accent hover:underline text-sm">Bästa robotgräsklippare 2026 — alla modeller</a></li>
      </ul>
    </section>
  </div>

  <StickyCTA
    text="Se pris på LUBA AWO 3000"
    url="https://www.maskinklippet.se/tradgard/robotgrasklippare-och-tillbehor/robotgrasklippare/mammotion-luba-2-awd-3000x-robotgrasklippare"
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqSchema,
  })} />
</BaseLayout>
