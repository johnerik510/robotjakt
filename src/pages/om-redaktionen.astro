---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

// Person-noden själv definieras en gång globalt i BaseLayout (@id https://robotjakt.se/#axel)
// och emitteras på varje sida. Den här sidan lägger bara till en ProfilePage-nod vars
// mainEntity pekar tillbaka på samma @id, precis som schema.org rekommenderar för en om-mig-sida.
const profilePageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': 'https://robotjakt.se/om-redaktionen/#profilepage',
  url: 'https://robotjakt.se/om-redaktionen/',
  name: 'Axel Jönemyr, redaktören bakom Robotjakt.se',
  mainEntity: { '@id': 'https://robotjakt.se/#axel' },
};
---

<BaseLayout
  title="Axel Jönemyr, redaktören bakom Robotjakt.se"
  description="Axel Jönemyr är redaktör för Robotjakt. Läs om hur han jämför robotdammsugare och robotgräsklippare utifrån navigering, sugkraft, räckvidd, tester och priser."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={[{ label: 'Om redaktionen' }]} />

    <header class="mb-8 flex flex-col sm:flex-row items-start gap-6">
      <img
        src="/images/axel-jonemyr.webp"
        alt="Axel Jönemyr, redaktör för Robotjakt"
        width="112"
        height="112"
        class="w-28 h-28 rounded-full object-cover ring-2 ring-gray-100 shrink-0"
        loading="eager"
      />
      <div>
        <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text mb-2">Axel Jönemyr</h1>
        <p class="text-accent font-semibold mb-3">Grundare och redaktör, Robotjakt</p>
        <p class="text-text-light text-lg leading-relaxed max-w-2xl">
          Jag driver Robotjakt för att du ska kunna jämföra robotdammsugare och robotgräsklippare på riktiga grunder, navigering, sugkraft, räckvidd och pris, utan att läsa dig igenom tillverkarnas marknadsföring.
        </p>
        <nav class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-4 text-sm" aria-label="Axels profiler">
          <a href="https://www.linkedin.com/in/axel-j%C3%B6nemyr-ba1443170/" rel="me noopener" target="_blank" class="text-accent underline hover:opacity-80">LinkedIn</a>
          <a href="https://www.instagram.com/axlpxl/" rel="me noopener" target="_blank" class="text-accent underline hover:opacity-80">Instagram</a>
          <a href="https://www.strava.com/athletes/2699302" rel="me noopener" target="_blank" class="text-accent underline hover:opacity-80">Strava</a>
          <a href="https://www.facebook.com/axel.jonemyr/" rel="me noopener" target="_blank" class="text-accent underline hover:opacity-80">Facebook</a>
        </nav>
      </div>
    </header>

    <div class="bg-white rounded-2xl border border-border p-6 sm:p-8 mb-8">
      <p class="text-sm text-accent font-semibold mb-3">Oberoende jämförelse av konsumentrobotar</p>
      <p class="text-text-light text-sm leading-relaxed mb-3">
        Robotjakt är en oberoende svensk guide för robotdammsugare, robotgräsklippare och poolrobotar. Jag köper inte in och labbtestar inte robotarna själv. I stället jämför jag modellerna utifrån verifierbar data så att du kan fatta ett välgrundat köpbeslut.
      </p>
      <p class="text-text-light text-sm leading-relaxed mb-3">
        Underlaget är tekniska specifikationer från tillverkarna, klippyta och kapacitet, navigeringsteknik, oberoende tester och recensioner samt aktuella priser hos svenska butiker. Jag väger samman dessa källor och redovisar både styrkor och svagheter för varje produkt. Rangordningen styrs av produktens egenskaper och pris, aldrig av vilken provision en länk ger.
      </p>
      <p class="text-text-light text-sm leading-relaxed">
        Kontakt: <!--email_off--><a href="mailto:info@robotjakt.se" class="text-accent underline">info@robotjakt.se</a><!--/email_off-->
      </p>
    </div>

    <div class="space-y-6">
      <div class="bg-white rounded-2xl border border-border p-6 sm:p-8">
        <h2 class="font-heading text-xl font-bold text-text mb-3">Expertområden</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm text-text-light">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Robotdammsugare & robotmoppar
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Robotgräsklippare
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Poolrobotar
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Fönsterputsrobotar
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Smart hem-integration
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Reservdelar & underhåll
          </li>
        </ul>
      </div>

      <div class="bg-white rounded-2xl border border-border p-6 sm:p-8">
        <h2 class="font-heading text-xl font-bold text-text mb-3">Så jämför jag</h2>
        <p class="text-sm text-text-light leading-relaxed mb-3">
          Jag väger samman tekniska specifikationer, kapacitet och navigeringsteknik med oberoende tester, recensioner och aktuella priser hos svenska butiker. Bedömningen tar hänsyn till svenska förhållanden, trädgårdar med nordiskt klimat, hem med trösklar och blandade golvytor.
        </p>
        <a href="/sa-testar-vi/" class="text-accent font-semibold text-sm underline">Så jämför vi</a>
      </div>

      <div class="bg-white rounded-2xl border border-border p-6 sm:p-8">
        <h2 class="font-heading text-xl font-bold text-text mb-3">Redaktionell policy</h2>
        <p class="text-sm text-text-light leading-relaxed mb-3">
          Jag tar aldrig betalt för positiva omdömen. Alla rekommendationer baseras på verifierbar data och en samlad bedömning av oberoende källor. Affiliatelänkar påverkar aldrig vilka produkter jag rekommenderar eller vilken ranking de får.
        </p>
        <a href="/redaktionell-policy/" class="text-accent font-semibold text-sm underline">Läs den redaktionella policyn &rarr;</a>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(profilePageSchema)} />
</BaseLayout>
