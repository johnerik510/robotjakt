---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const editorialSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Robotjakts redaktion',
  url: 'https://robotjakt.se/om-redaktionen/',
  description: 'Robotjakts redaktion jämför konsumentrobotar utifrån verifierbar data: tekniska specifikationer, kapacitet, navigeringsteknik, oberoende tester och recensioner samt aktuella priser hos svenska butiker.',
  knowsAbout: ['robotdammsugare', 'robotgräsklippare', 'poolrobotar', 'smart hem', 'Dreame', 'Roborock', 'Husqvarna', 'Ecovacs'],
  parentOrganization: {
    '@type': 'Organization',
    name: 'Robotjakt.se',
    url: 'https://robotjakt.se',
  },
};
---

<BaseLayout
  title="Redaktionen bakom Robotjakt.se: experter på robotar"
  description="Möt redaktionen bakom Robotjakt.se. Vi granskar robotar oberoende och objektivt. Läs om vår bakgrund och hur vi granskar produkterna."
  article={true}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={[{ label: 'Om redaktionen' }]} />

    <h1 class="font-heading text-3xl font-bold text-text mb-6">Om redaktionen</h1>

    <div class="bg-white rounded-2xl border border-border p-6 sm:p-8 mb-8">
      <p class="text-sm text-accent font-semibold mb-3">Oberoende jämförelse av konsumentrobotar</p>
      <p class="text-text-light text-sm leading-relaxed mb-3">
        Robotjakt är en oberoende svensk guide för robotdammsugare, robotgräsklippare och poolrobotar. Vi köper inte in och labbtestar inte robotarna själva. I stället jämför vi modellerna utifrån verifierbar data så att du kan fatta ett välgrundat köpbeslut.
      </p>
      <p class="text-text-light text-sm leading-relaxed mb-3">
        Vårt underlag är tekniska specifikationer från tillverkarna, klippyta och kapacitet, navigeringsteknik, oberoende tester och recensioner samt aktuella priser hos svenska butiker. Vi väger samman dessa källor och redovisar både styrkor och svagheter för varje produkt. Rangordningen styrs av produktens egenskaper och pris, aldrig av vilken provision en länk ger.
      </p>
      <p class="text-text-light text-sm leading-relaxed">
        Kontakt: <!--email_off--><a href="mailto:info@robotjakt.se" class="text-accent underline">info@robotjakt.se</a><!--/email_off-->
      </p>
    </div>

    <div class="space-y-6">
      <div class="bg-white rounded-2xl border border-border p-6 sm:p-8">
        <h2 class="font-heading text-xl font-bold text-text mb-3">Expertområden</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm text-text-light">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Robotdammsugare & robotmoppar
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Robotgräsklippare
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Poolrobotar
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Fönsterputsrobotar
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Smart hem-integration
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Reservdelar & underhåll
          </li>
        </ul>
      </div>

      <div class="bg-white rounded-2xl border border-border p-6 sm:p-8">
        <h2 class="font-heading text-xl font-bold text-text mb-3">Så jämför vi</h2>
        <p class="text-sm text-text-light leading-relaxed mb-3">
          Vi väger samman tekniska specifikationer, kapacitet och navigeringsteknik med oberoende tester, recensioner och aktuella priser hos svenska butiker. Bedömningen tar hänsyn till svenska förhållanden, trädgårdar med nordiskt klimat, hem med trösklar och blandade golvytor.
        </p>
        <a href="/sa-testar-vi/" class="text-accent font-semibold text-sm underline">Så jämför vi</a>
      </div>

      <div class="bg-white rounded-2xl border border-border p-6 sm:p-8">
        <h2 class="font-heading text-xl font-bold text-text mb-3">Redaktionell policy</h2>
        <p class="text-sm text-text-light leading-relaxed mb-3">
          Vi tar aldrig betalt för positiva omdömen. Alla rekommendationer baseras på verifierbar data och en samlad bedömning av oberoende källor. Affiliatelänkar påverkar aldrig vilka produkter vi rekommenderar eller vilken ranking de får.
        </p>
        <a href="/redaktionell-policy/" class="text-accent font-semibold text-sm underline">Läs vår redaktionella policy &rarr;</a>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(editorialSchema)} />
</BaseLayout>
