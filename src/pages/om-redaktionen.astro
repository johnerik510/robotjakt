---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'John Erik Johansson',
  url: 'https://robotjakt.se/om-redaktionen/',
  image: 'https://robotjakt.se/images/john-erik-johansson.webp',
  jobTitle: 'Grundare & robotexpert',
  description: 'Teknikentusiast och robotexpert. Testat 50+ robotdammsugare, robotgräsklippare och poolrobotar i hemmet.',
  knowsAbout: ['robotdammsugare', 'robotgräsklippare', 'poolrobotar', 'smart hem', 'Dreame', 'Roborock', 'Husqvarna', 'Ecovacs'],
  worksFor: {
    '@type': 'Organization',
    name: 'Robotjakt.se',
    url: 'https://robotjakt.se',
  },
};
---

<BaseLayout
  title="Om redaktionen | Robotjakt"
  description="Möt teamet bakom Robotjakt.se. John Erik Johansson testar robotdammsugare, robotgräsklippare och poolrobotar i verklig hemmiljö."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={[{ label: 'Om redaktionen' }]} />

    <h1 class="font-heading text-3xl font-bold text-text mb-6">Om redaktionen</h1>

    <div class="bg-white rounded-2xl border border-border p-6 sm:p-8 mb-8">
      <div class="flex flex-col sm:flex-row items-start gap-6">
        <img
          src="/images/john-erik-johansson.webp"
          alt="John Erik Johansson"
          class="w-24 h-24 rounded-full object-cover flex-shrink-0"
          width="96"
          height="96"
          loading="eager"
        />
        <div>
          <h2 class="font-heading text-xl font-bold text-text mb-1">John Erik Johansson</h2>
          <p class="text-sm text-accent font-semibold mb-3">Grundare & robotexpert</p>
          <p class="text-text-light text-sm leading-relaxed mb-3">
            Teknikentusiast med ett genuint intresse för smart hem-teknik och konsumentrobotar. Har testat över 50 robotdammsugare, robotgräsklippare och poolrobotar i verklig hemmiljö — från budgetmodeller till toppmodeller från Dreame, Roborock, Ecovacs, Husqvarna och fler.
          </p>
          <p class="text-text-light text-sm leading-relaxed mb-3">
            Robotjakt grundades med ett enda mål: att ge svenska konsumenter ärliga, oberoende och databaserade rekommendationer. Alla tester genomförs i verklig miljö — inte i ett labb. Det innebär att resultaten speglar hur robotarna faktiskt presterar i svenska hem och trädgårdar.
          </p>
          <p class="text-text-light text-sm leading-relaxed">
            Kontakt: <a href="mailto:vpniskguiden@proton.me" class="text-accent hover:underline">vpniskguiden@proton.me</a>
          </p>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="bg-white rounded-2xl border border-border p-6 sm:p-8">
        <h2 class="font-heading text-xl font-bold text-text mb-3">Expertområden</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm text-text-light">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Robotdammsugare & robotmoppar
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Robotgräsklippare
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Poolrobotar
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Fönsterputsrobotar
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Smart hem-integration
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Reservdelar & underhåll
          </li>
        </ul>
      </div>

      <div class="bg-white rounded-2xl border border-border p-6 sm:p-8">
        <h2 class="font-heading text-xl font-bold text-text mb-3">Så testar vi</h2>
        <p class="text-sm text-text-light leading-relaxed mb-3">
          Varje robot testas i minst 4 veckor i verklig hemmiljö. Vi utvärderar navigering, rengöringsresultat, batteritid, ljudnivå, appfunktionalitet och prisvärdhet. Testkriterierna är anpassade för svenska förhållanden — trädgårdar med nordiskt klimat, hem med tröskelramar och blandade golvytor.
        </p>
        <a href="/sa-testar-vi/" class="text-accent font-semibold text-sm hover:underline">Läs mer om vår testmetod &rarr;</a>
      </div>

      <div class="bg-white rounded-2xl border border-border p-6 sm:p-8">
        <h2 class="font-heading text-xl font-bold text-text mb-3">Redaktionell policy</h2>
        <p class="text-sm text-text-light leading-relaxed mb-3">
          Vi tar aldrig betalt för positiva recensioner. Alla rekommendationer baseras på våra egna tester och erfarenheter. Affiliatelänkar påverkar aldrig vilka produkter vi rekommenderar eller vilken ranking de får.
        </p>
        <a href="/redaktionell-policy/" class="text-accent font-semibold text-sm hover:underline">Läs vår redaktionella policy &rarr;</a>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
</BaseLayout>
