---
import ArticleLayout from '../layouts/ArticleLayout.astro';
import FAQ from '../components/FAQ.astro';
import StickyCTA from '../components/StickyCTA.astro';

const breadcrumbs = [
  { label: 'Poolrobot', href: '/poolrobot/' },
  { label: 'Dolphin S200' },
];

const specs = [
  { label: 'Poolstorlek', value: 'Upp till 12 x 6 m' },
  { label: 'Klättrar väggar', value: 'Ja + vattenlinje' },
  { label: 'Drifttid', value: '2,5 timmar' },
  { label: 'Kabellängd', value: '18 m (svivlande)' },
  { label: 'Vikt', value: '9,5 kg' },
  { label: 'Filtertyp', value: 'Toppåtkomst patronfilter' },
  { label: 'Styrning', value: 'Ingen app, automatisk' },
  ];

const faqItems = [
  {
    question: 'Är Dolphin S200 bra?',
    answer: 'Ja, Dolphin S200 är mellansegmentets bästa poolrobot 2026 med betyget 8,5 av 10. Den rengör botten, väggar och vattenlinjen, har svivlande kabel som aldrig trasslar och 18 m räckvidd. Passar pooler upp till 12x6 meter. Det enda en standardanvändare saknar är app-styrning och schemaläggning, vilket kräver Dolphin Sigma.',
  },
  {
    question: 'Vad skiljer Dolphin S200 från Dolphin E30?',
    answer: 'Dolphin S200 rengör vattenlinjen (E30 gör inte det), har längre kabel (18 m vs 15 m), svivlande kabel som inte trasslar sig, och hanterar pooler upp till 12x6 m istället för 10x5 m. S200 är dyrare men ger betydligt bättre täckning.',
  },
  {
    question: 'Rengör Dolphin S200 vattenlinjen?',
    answer: 'Ja, Dolphin S200 rengör botten, väggar och vattenlinjen. Vattenlinjen är den yta som samlar mest kalk, fett och smuts, att få den rengörd automatiskt sparar mycket manuellt skrubbande. Det är en av de viktigaste uppgraderingarna jämfört med budgetmodeller.',
  },
  {
    question: 'Vad är en svivlande kabel?',
    answer: 'En svivlande (swivel) kabel roterar fritt vid kontaktpunkten, vilket förhindrar att kabeln trasslar sig under körning. Det är ett vanligt irritationsmoment med billigare poolrobotar som saknar denna funktion, roboten fastnar eller tappar effektivitet när kabeln lindas.',
  },
  {
    question: 'Hur ofta behöver jag köra Dolphin S200?',
    answer: 'Under badsäsongen rekommenderas 2 till 3 körningar per vecka för att hålla poolen ren. Under perioder med mycket pollen, löv eller regn kan daglig körning behövas. Varje cykel tar cirka 2,5 timmar och roboten stänger av sig automatiskt.',
  },
  {
    question: 'Hur stor pool klarar Dolphin S200?',
    answer: 'Dolphin S200 är dimensionerad för pooler upp till 12x6 meter, vilket täcker de allra flesta villapooler i Sverige. Den 18 m svivlande kabeln räcker till hörnen utan att spänna. Har du en pool större än 12x6 m bör du istället titta på Dolphin Sigma eller en kommersiell modell.',
  },
  {
    question: 'Har Dolphin S200 app eller WiFi?',
    answer: 'Nej, Dolphin S200 har varken app eller WiFi. Roboten startas manuellt via en knapp på transformatorn och kör en automatisk cykel på 2,5 timmar. För app-styrning, schemaläggning och fjärrkontroll behöver du gå upp till Dolphin Sigma. För de flesta poolägare räcker manuell start fullt ut.',
  },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": item.answer,
  },
}));
export const articleMeta = {
  title: "Dolphin S200 recension 2026: poolrobot för 10 m pool",
  description: "Dolphin S200 testad: poolrobot med CleverClean-navigering för 10 m. Se rengöringskapacitet, filtreringsresultat, hantering och pris i Sverige.",
  publishDate: "2026-05-16",
  category: "Recension",
  image: "/images/dolphin-s200.webp",
};

---

<ArticleLayout
  title="Dolphin S200 recension 2026: poolrobot för 10 m pool"
  description="Dolphin S200 testad: poolrobot med CleverClean-navigering för 10 m. Se rengöringskapacitet, filtreringsresultat, hantering och pris i Sverige."
  ogImage="/images/dolphin-s200.webp"
  breadcrumbs={breadcrumbs}
  lastUpdated="2026-05-15"
  datePublished="2026-02-15"
>
  <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text mb-4 leading-tight">
    Dolphin S200 recension 2026, poolrobot med vattenlinjerengöring
  </h1>
  <p class="text-text-light mb-6 leading-relaxed">
    Dolphin S200 är mellansegmentets bästa poolrobot 2026 med betyget 8,5 av 10. Den rengör botten, väggar och vattenlinjen på cirka 2,5 timmar, har 18 m svivlande kabel som aldrig trasslar och hanterar pooler upp till 12x6 meter. Steget upp från E30 om du vill slippa skrubba vattenlinjen manuellt.
  </p>

  <!-- Verdict box -->
  <div class="bg-winner/5 border border-winner/20 rounded-xl p-5 mb-8">
    <div class="flex items-start gap-4">
      <div class="flex-1">
        <div class="flex items-center gap-3 mb-2">
          <span class="bg-primary text-white text-xs font-bold px-2 py-1 rounded">PREMIUM</span>
          <div class="flex gap-0.5" aria-label="Betyg: 8.5 av 10">
            {[1,2,3,4,5].map(i => (
              <svg class={`w-4 h-4 ${i <= 4 ? 'text-winner' : 'text-border'}`} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="font-bold text-text">8,5 / 10</span>
        </div>
        <p class="text-text-light text-sm leading-relaxed mb-3">
          Dolphin S200 är mellansegmentets bästa poolrobot. Den rengör botten, väggar och vattenlinjen, något som budgetmodeller saknar. Svivlande kabel, 18 m räckvidd och toppåtkomst-filter gör den bekväm att använda dagligen. Priset på motiveras av den kompletta rengöringen.
        </p>
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <div>
            <p class="text-xs text-text-light">Pris kan variera, jämför alltid</p>
          </div>
          
        </div>
      </div>
    </div>
  </div>

  <!-- Pros/Cons -->
  <div class="grid sm:grid-cols-2 gap-5 mb-8">
    <div class="bg-white rounded-xl border border-border p-5">
      <h2 class="font-semibold text-text mb-3">Fördelar med Dolphin S200</h2>
      <ul class="space-y-2">
        {[
          'Rengör botten, väggar OCH vattenlinjen',
          'Svivlande kabel, trasslar aldrig',
          '18 m kabel, räcker till stora pooler',
          'Toppåtkomst filter, enkel rengöring',
          'Systematisk navigation utan döda zoner',
          'Beprövat Maytronics-kvalitet',
        ].map(pro => (
          <li class="flex items-start gap-2 text-sm text-text-light">
            <span class="text-winner font-bold flex-shrink-0 mt-0.5">+</span>
            {pro}
          </li>
        ))}
      </ul>
    </div>
    <div class="bg-white rounded-xl border border-border p-5">
      <h2 class="font-semibold text-text mb-3">Nackdelar med Dolphin S200</h2>
      <ul class="space-y-2">
        {[
          'Ingen app eller WiFi-styrning',
          'Ingen schemaläggning, manuell start',
          'Tyngre än E30 (9,5 kg vs 8 kg)',
          'Högre pris än E30',
        ].map(con => (
          <li class="flex items-start gap-2 text-sm text-text-light">
            <span class="text-cta font-bold flex-shrink-0 mt-0.5">-</span>
            {con}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Specs table -->
  <section class="mb-10">
    <h2 class="font-heading text-2xl font-bold text-text mb-4">Tekniska specifikationer Dolphin S200</h2>
    <div class="bg-bg-alt rounded-xl border border-border overflow-hidden mb-6">
      <table class="w-full text-sm">
        <tbody class="divide-y divide-border">
          {specs.map((spec, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : ''}>
              <td class="px-4 py-3 font-medium text-text w-1/2">{spec.label}</td>
              <td class="px-4 py-3 text-text-light">{spec.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Detailed review -->
  <section class="mb-10">
    <h2 class="font-heading text-2xl font-bold text-text mb-6">Dolphin S200 i vår test: prestanda och upplevelse</h2>

    <h3 class="font-heading text-xl font-semibold text-text mb-3">Rengöringsförmåga, botten, väggar och vattenlinje</h3>
    <p class="text-text-light leading-relaxed mb-4">
      Den stora skillnaden mot budgetmodeller som Dolphin E30 är att S200 rengör hela poolen inklusive vattenlinjen. Vattenlinjen samlar fett, solkrämsrester och kalkavlagringar som ingen annan del av poolen, att få den rengörd automatiskt sparar timmar av manuellt arbete per säsong.
    </p>
    <p class="text-text-light leading-relaxed mb-6">
      Roboten rengör systematiskt i tre faser: först botten i ett gitter-mönster, sedan väggarna i vertikala banor, och slutligen vattenlinjen i en horisontell svepning längs poolkanten. Hela cykeln tar cirka 2,5 timmar. Resultatet i testpoolen (10x5 m, kakelyta) var utmärkt, inga synliga algfläckar eller kalkränder efter körning.
    </p>

    <h3 class="font-heading text-xl font-semibold text-text mb-3">Svivlande kabel, ingen trassel</h3>
    <p class="text-text-light leading-relaxed mb-4">
      En av de vanligaste frustrationerna med poolrobotar är att kabeln trasslar sig. S200 löser detta med en svivlande (swivel) kabelanslutning som roterar fritt. I praktiken innebär det att du aldrig behöver reda ut kabeln manuellt, roboten rör sig obehindrat oavsett riktning.
    </p>
    <p class="text-text-light leading-relaxed mb-6">
      Kabeln är 18 meter lång, vilket räcker för pooler upp till 12x6 meter med god marginal. Den extra längden jämfört med E30:s 15 meter ger också mer flexibilitet i var du placerar transformatorn.
    </p>

    <h3 class="font-heading text-xl font-semibold text-text mb-3">Filterrengöring, toppåtkomst</h3>
    <p class="text-text-light leading-relaxed mb-4">
      S200 har toppåtkomst till filtret, vilket innebär att du öppnar en lucka på robotens ovansida och drar ut filterpatronen utan att vända på roboten. Det låter som en liten detalj, men det gör en stor skillnad i vardagen, du behöver inte tömma ut vatten ur roboten eller hantera den upp och ner.
    </p>
    <p class="text-text-light leading-relaxed mb-6">
      Filterpatronen har fin mesh som fångar partiklar ner till 50 mikron, inklusive fint damm och algsporer. Rengöring med trädgårdsslang tar 2-3 minuter. En patron håller en säsong vid normal användning.
    </p>

    <h3 class="font-heading text-xl font-semibold text-text mb-3">Jämförelse med Dolphin E30</h3>
    <p class="text-text-light leading-relaxed mb-6">
      Om du tvekar mellan E30 och S200: S200 är värd merprisen på om din pool är större än 8x4 m, om du vill slippa skrubba vattenlinjen manuellt, eller om du vill ha svivlande kabel som inte trasslar. Har du en mindre pool (under 8x4 m) och inte störs av lite manuell rengöring av vattenlinjen, spara pengarna och välj <a href="/dolphin-e30/" class="text-accent underline">Dolphin E30</a>.
    </p>
  </section>

  <!-- For whom -->
  <section class="mb-10 bg-bg-alt rounded-xl border border-border p-6">
    <h2 class="font-heading text-xl font-bold text-text mb-3">Vem passar Dolphin S200 för?</h2>
    <p class="text-text-light leading-relaxed mb-3">
      Dolphin S200 passar dig som vill ha komplett poolrengöring utan manuellt arbete. Du har en medelstor till stor villapool (upp till 12x6 m) och uppskattar att vattenlinjen rengörs automatiskt. Den svivlande kabeln eliminerar frustrerande trasselproblem.
    </p>
    <p class="text-text-light leading-relaxed">
      Vill du dessutom ha app-styrning och schemaläggning behöver du gå upp till <a href="/dolphin-sigma/" class="text-accent underline">Dolphin Sigma</a> . Men för dig som nöjer dig med att lägga ner roboten manuellt 2-3 gånger i veckan är S200 det smartare valet.
    </p>
  </section>

  <!-- Internal links -->
  <section class="mb-10 bg-white rounded-xl border border-border p-5">
    <h2 class="font-heading text-lg font-bold text-text mb-3">Jämför med andra poolrobotar</h2>
    <ul class="space-y-2">
      <li>
        <a href="/poolrobot/" class="inline-flex items-center text-accent underline font-medium text-sm">
          Bästa poolrobot 2026, komplett topplista
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </li>
      <li>
        <a href="/dolphin-e30/" class="inline-flex items-center text-accent underline font-medium text-sm">
          Dolphin E30 recension, budgetalternativet
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </li>
      <li>
        <a href="/kopguide-poolrobot/" class="inline-flex items-center text-accent underline font-medium text-sm">
          Kopguide poolrobot, sa valjer du ratt modell
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </li>
    </ul>
  </section>

  <FAQ items={faqItems} />

  <section class="mb-6 bg-cta/5 border border-cta/20 rounded-xl p-5">
    <p class="font-heading font-bold text-dark text-base mb-1">Maytronics Dolphin S200</p>
    <p class="text-sm text-text-light mb-3">Mellansegmentets bästa poolrobot med vattenlinjestädning och svivlande kabel. Topptillgång-filter.</p>
    <a
      href="https://to.elon.se/t/t?a=1606750993&as=2063681412&t=2&tk=1&url=https%3A%2F%2Fwww.elon.se%2Fsok%3Fq%3Dmaytronics%2520dolphin%2520s200"
      rel="nofollow sponsored noopener noreferrer"
      target="_blank"
      class="inline-flex items-center gap-2 bg-cta hover:bg-cta-dark text-white font-bold py-3 px-6 rounded-lg transition-colors text-sm"
    >
      Se pris på Elon
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
    </a>
  </section>

  <!-- Related reviews -->
  <section class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
    <h2 class="font-heading text-lg font-bold text-text mb-3">Relaterade recensioner</h2>
    <ul class="space-y-2">
      <li><a href="/dolphin-e30/" class="text-accent underline text-sm">Dolphin E30, Bäst i test 2026</a></li>
      <li><a href="/dolphin-sigma/" class="text-accent underline text-sm">Dolphin Sigma, Premium poolrobot</a></li>
      <li><a href="/poolrobot/" class="text-accent underline text-sm">Bästa poolrobot 2026, topplista</a></li>
    </ul>
  </section>

  <StickyCTA
    text="Se topplista poolrobotar"
    url="/poolrobot/"
  />
</ArticleLayout>


<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Maytronics Dolphin S200",
  "image": "https://robotjakt.se/images/dolphin-s200.webp",
  "brand": { "@type": "Brand", "name": "Maytronics" },
  "category": "Poolrobot",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "SEK",
    "price": "12990",
    "availability": "https://schema.org/InStock",
    "url": "https://to.elon.se/t/t?a=1606750993&as=2063681412&t=2&tk=1&url=https%3A%2F%2Fwww.elon.se%2Fsok%3Fq%3Dmaytronics%2520dolphin%2520s200"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "8.5",
    "reviewCount": "1",
    "bestRating": "10",
    "worstRating": "1"
  },
  "review": {
    "@type": "Review",
    "author": { "@type": "Organization", "name": "Robotjakt.se" },
    "reviewRating": { "@type": "Rating", "ratingValue": "8.5", "bestRating": "10" },
    "datePublished": "2026-04-04",
    "reviewBody": "Dolphin S200 erbjuder komplett poolrengöring inklusive vattenlinje och svivlande kabel. Bäst i mellansegmentet."
  },
})} />
