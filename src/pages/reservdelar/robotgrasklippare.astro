---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';
import FAQ from '../../components/FAQ.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const TAG = 'johnerik510-20';

const products = [
  {
    asin: 'B0C9C5VNM1',
    img: '/images/parts-robot-kit-3.webp',
    name: '45-pack universalblad, Husqvarna, Gardena, Yardforce',
    compat: 'Passar: Husqvarna Automower 105, 115H, 310, 315, 315X, 430X, 450X, Gardena Sileno, Yardforce',
    includes: '45 ersättningsblad + skruvar',
    badge: 'Bäst i test',
    type: 'Knivar',
  },
  {
    asin: 'B07WMTTSS4',
    img: '/images/parts-robot-filter-4.webp',
    name: 'Domar 30-pack förstärkta robotgräsklipparblad',
    compat: 'Passar: Husqvarna Automower, Gardena Sileno, Yard Force',
    includes: '30 förstärkta blad + skruvar',
    badge: null,
    type: 'Knivar',
  },
  {
    asin: 'B083SKXKR7',
    img: '/images/parts-lawn-blade.webp',
    name: 'Willingood 30-pack titanblad, universalpassning',
    compat: 'Passar: Husqvarna Automower, Gardena, McCulloch, Segway Navimow',
    includes: '30 titanblad + 30 skruvar',
    badge: 'Titanstål',
    type: 'Knivar',
  },
  {
    asin: 'B0DRHWXPHC',
    img: '/images/parts-robot-filter-2.webp',
    name: 'Forever Speed, begränsningskabel 100 m (2,7 mm)',
    compat: 'Passar: Husqvarna Automower, Gardena Sileno, Worx Landroid, McCulloch',
    includes: '100 m kabel, diameter 2,7 mm',
    badge: null,
    type: 'Kabel',
  },
  {
    asin: 'B0DRHXG9WX',
    img: '/images/parts-husqvarna-blade.webp',
    name: 'Forever Speed, begränsningskabel 150 m (2,7 mm)',
    compat: 'Passar: Husqvarna Automower, Gardena Sileno, Worx Landroid, McCulloch',
    includes: '150 m kabel, diameter 2,7 mm',
    badge: 'Stor tomt',
    type: 'Kabel',
  },
  {
    asin: 'B0D9QB7H3S',
    img: '/images/parts-robot-filter-5.webp',
    name: '20-pack kabelklämmor, reparerar begränsningskabel',
    compat: 'Passar: Gardena, Husqvarna och alla kabeldrivna robotgräsklippare',
    includes: '20 anslutningsklämmor, passar kabel 2,7 till 3,4 mm',
    badge: null,
    type: 'Kabel',
  },
];

const faqItems = [
  {
    question: 'Hur ofta ska jag byta knivar på robotgräsklipparen?',
    answer: 'Byt knivar varje säsong, helst på våren innan du startar klippningen. Med stenig eller hård mark slits knivarna fortare och kan behöva bytas mitt i säsongen.',
  },
  {
    question: 'Fungerar universalblad i alla robotgräsklippare?',
    answer: 'Universalblad fungerar i de flesta modeller från Husqvarna, Gardena, Worx och McCulloch som använder ett standardhållarsystem. Kontrollera alltid kompatibilitetslistan i produktbeskrivningen.',
  },
  {
    question: 'Min begränsningskabel är trasig, behöver jag byta hela kabeln?',
    answer: 'Nej. Använd kabelklämmor för att skärva ihop kabeln vid brottstället. Det tar 5 minuter och kostar till lägre pris per skärv.',
  },
];

const breadcrumbs = [
  { label: 'Reservdelar', href: '/reservdelar/' },
  { label: 'Robotgräsklippare' },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": item.answer,
  },
}));
export const articleMeta = {
  title: "Reservdelar robotgräsklippare 2026: knivar och mer",
  description: "Komplett guide till reservdelar för robotgräsklippare 2026. Knivar, skruvar, laddningsplattor och slingtillbehör. Se kompatibilitet och pris Sverige.",
  publishDate: "2026-03-29",
  category: "Reservdelar",
  image: "/images/parts-husqvarna-blade.webp",
};

---

<BaseLayout
  title="Reservdelar robotgräsklippare 2026: knivar och mer"
  description="Komplett guide till reservdelar för robotgräsklippare 2026. Knivar, skruvar, laddningsplattor och slingtillbehör. Se kompatibilitet och pris Sverige."
  article={{ datePublished: "2026-03-29", dateModified: "2026-05-27", image: "/images/parts-husqvarna-blade.webp" }}
>
  <section class="bg-primary text-white py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} light={true} />
  <div class="max-w-4xl mx-auto px-4 py-2 flex flex-wrap items-center gap-2 text-xs text-slate-500">
    <a href="/om-redaktionen/" class="flex items-center gap-1.5 hover:text-blue-600 transition-colors">
      <img src="/images/team-anna.webp" alt="Anna Svensson" class="w-5 h-5 rounded-full object-cover" width="20" height="20" loading="lazy" />
      <span class="font-medium text-slate-700">Anna Svensson</span>
    </a>
    <span>·</span>
    <span>Uppdaterad 27 maj 2026</span>
  </div>
      <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-3">Robotgräsklippare reservdelar</h1>
      <p class="text-gray-200 max-w-2xl">Ersättningsknivar, begränsningskabel och kabelklämmor till Husqvarna Automower, Gardena Sileno, Worx Landroid och Segway Navimow.</p>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
<p class="text-sm text-text-light mb-2">Senast uppdaterad: april 2026, {products.length} produkter</p>

    <div class="bg-accent/5 border border-accent/20 rounded-xl px-5 py-4 mb-8 text-sm text-text">
      <strong>Säsongsstart-tips:</strong> Byt knivar och kontrollera begränsningskabeln varje vår innan du startar robotgräsklipparen. Det tar 15 minuter och förebygger driftstopp under säsongen.
    </div>

    <h2 class="font-heading text-xl font-bold text-text mb-4">Knivar och blad</h2>
    <div class="space-y-4 mb-10">
      {products.filter(p => p.type === 'Knivar').map((p, i) => (
        <article class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow p-5">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-shrink-0 flex flex-col items-center gap-2">
              {i === 0 && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-winner/10 text-winner">{p.badge}</span>}
              {i > 0 && p.badge && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-bg-alt text-text-light">{p.badge}</span>}
              <div class="w-32 h-32 bg-gray-50 rounded-xl p-2 flex items-center justify-center border border-border">
                <img src={p.img} alt={p.name} class="w-full h-full object-contain" loading="lazy" width="200" height="200" />
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-heading font-bold text-text text-base mb-1">{p.name}</h3>
              <p class="text-xs text-accent font-medium mb-2">{p.compat}</p>
              <p class="text-xs text-text-light mb-4"><strong class="text-text">Innehåller:</strong> {p.includes}</p>
              <div class="flex flex-wrap items-center gap-3">
                
                
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <h2 class="font-heading text-xl font-bold text-text mb-4">Begränsningskabel och klämmor</h2>
    <div class="space-y-4 mb-10">
      {products.filter(p => p.type === 'Kabel').map((p) => (
        <article class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow p-5">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-shrink-0 flex flex-col items-center gap-2">
              {p.badge && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-bg-alt text-text-light">{p.badge}</span>}
              <div class="w-32 h-32 bg-gray-50 rounded-xl p-2 flex items-center justify-center border border-border">
                <img src={p.img} alt={p.name} class="w-full h-full object-contain" loading="lazy" width="200" height="200" />
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-heading font-bold text-text text-base mb-1">{p.name}</h3>
              <p class="text-xs text-accent font-medium mb-2">{p.compat}</p>
              <p class="text-xs text-text-light mb-4"><strong class="text-text">Innehåller:</strong> {p.includes}</p>
              <div class="flex flex-wrap items-center gap-3">
                
                
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <section class="mb-8">
      <h2 class="font-heading text-xl font-bold text-text mb-4">Fler reservdelar</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href="/reservdelar/husqvarna/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Husqvarna Automower reservdelar</a>
        <a href="/reservdelar/knivar/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Alla knivar och kabel</a>
        <a href="/reservdelar/robotdammsugare/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Robotdammsugare reservdelar</a>
        <a href="/reservdelar/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Alla reservdelar</a>
      </div>
    </section>

    <FAQ items={faqItems} />

    <AffiliateDisclaimer />
  </main>
</BaseLayout>
