---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';
import FAQ from '../../components/FAQ.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const AMZN_TAG = 'johnerik510-20';

const parts = [
  {
    category: 'Knivar',
    desc: 'Byt knivar varje säsong eller vid synlig slitage — trubbiga knivar drar och sliter på gräset.',
    products: [
      {
        name: 'Husqvarna Automower knivar — 9-pack (standard)',
        compat: 'Passar: Husqvarna Automower 105, 115H, 310, 315, 315X, 320, 330X, 430X',
        price: 'ca 89–129 kr',
        badge: 'Populärast',
        ctaUrl: `https://www.amazon.se/s?k=husqvarna+automower+knivar+9+pack&tag=${AMZN_TAG}`,
      },
      {
        name: 'Gardena Sileno knivar — 9-pack',
        compat: 'Passar: Gardena Sileno City 250, 500, 750, Life 750, Minimo',
        price: 'ca 89–129 kr',
        badge: null,
        ctaUrl: `https://www.amazon.se/s?k=gardena+sileno+knivar+reservdelar&tag=${AMZN_TAG}`,
      },
      {
        name: 'Worx Landroid knivar — 9-pack',
        compat: 'Passar: Worx Landroid M500, L1500, S300',
        price: 'ca 79–119 kr',
        badge: null,
        ctaUrl: `https://www.amazon.se/s?k=worx+landroid+knivar+reservdelar&tag=${AMZN_TAG}`,
      },
      {
        name: 'Mammotion LUBA knivar',
        compat: 'Passar: Mammotion LUBA 2 AWO 1000H, LUBA AWO 3000',
        price: 'ca 149–199 kr',
        badge: null,
        ctaUrl: `https://www.amazon.se/s?k=mammotion+luba+knivar+blades&tag=${AMZN_TAG}`,
      },
    ],
  },
  {
    category: 'Begränsningskabel & spiraler',
    desc: 'Kabel och spiraler för perimeter-baserade robotgräsklippare.',
    products: [
      {
        name: 'Husqvarna Automower begränsningskabel — 150 m',
        compat: 'Passar: Alla Husqvarna Automower med trådsystem',
        price: 'ca 199–279 kr',
        badge: null,
        ctaUrl: `https://www.amazon.se/s?k=husqvarna+automower+begransningskabel+150m&tag=${AMZN_TAG}`,
      },
      {
        name: 'Husqvarna Automower spiraler — 200-pack',
        compat: 'Passar: Alla Husqvarna Automower med trådsystem',
        price: 'ca 99–149 kr',
        badge: null,
        ctaUrl: `https://www.amazon.se/s?k=husqvarna+automower+spiraler+spikar&tag=${AMZN_TAG}`,
      },
      {
        name: 'Gardena begränsningskabel & spiraler-kit',
        compat: 'Passar: Gardena Sileno-serien',
        price: 'ca 179–249 kr',
        badge: null,
        ctaUrl: `https://www.amazon.se/s?k=gardena+sileno+begransningskabel+spiraler&tag=${AMZN_TAG}`,
      },
    ],
  },
  {
    category: 'Rengöring & skötsel',
    desc: 'Håll sensorer och chassi i trim för bästa navigering och livslängd.',
    products: [
      {
        name: 'Rengöringsborste för sensorer & hjul',
        compat: 'Universell — passar alla robotgräsklippare',
        price: 'ca 49–89 kr',
        badge: null,
        ctaUrl: `https://www.amazon.se/s?k=robotgrasklippare+rengoring+borste&tag=${AMZN_TAG}`,
      },
      {
        name: 'Knivbytesverktyg (säkert byte utan verktyg)',
        compat: 'Universell',
        price: 'ca 39–69 kr',
        badge: null,
        ctaUrl: `https://www.amazon.se/s?k=robotgrasklippare+knivbyte+verktyg&tag=${AMZN_TAG}`,
      },
    ],
  },
];

const faqItems = [
  {
    question: 'Hur ofta bör man byta knivar på robotgräsklipparen?',
    answer: 'Byt knivar minst en gång per säsong — helst vid säsongsstart. Med mycket grus eller sten i gräset kan knivarna slöas snabbare och behöva bytas mitt i säsongen. Ett tecken på slitna knivar är ojämnt klippt gräs med fransiga strån.',
  },
  {
    question: 'Kan man slipa knivarna istället för att byta dem?',
    answer: 'Robotgräsklipparens knivar är designade för att bytas ut, inte slipas. De kostar runt 10–15 kr styck i ett 9-pack — det är billigare och säkrare att köpa nya. Försök aldrig att slipa knivar utan att ta bort dem från maskinen.',
  },
  {
    question: 'Vad händer om man kör med trasig begränsningskabel?',
    answer: 'En trasig begränsningskabel kan göra att robotgräsklipparen inte startar alls, kör fel, eller stängs av mitt i klippningen med ett felmeddelande. Du kan hitta kabelbrottet med en kabelsökare eller systematiskt kontrollera längs hela perimetern.',
  },
  {
    question: 'Vilka knivar passar Husqvarna Automower 430X Nera?',
    answer: 'Husqvarna Automower 430X Nera använder standard Husqvarna Automower-knivar (artikelnummer 591 34 04-01) i ett 9-pack. Dessa passar de flesta Automower-modeller. Kontrollera att paketet anger 430X-kompatibilitet vid köp.',
  },
];

const breadcrumbs = [
  { label: 'Reservdelar', href: '/reservdelar/' },
  { label: 'Robotgräsklippare reservdelar' },
];
---

<BaseLayout
  title="Reservdelar till robotgräsklippare — Knivar, kabel & spiraler | Robotjakt"
  description="Reservdelar till robotgräsklippare. Knivar till Husqvarna Automower, Gardena Sileno och Worx Landroid. Begränsningskabel, spiraler och mer via Amazon."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="bg-primary text-white py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-3">Reservdelar till robotgräsklippare</h1>
      <p class="text-gray-200 max-w-2xl">Knivar, begränsningskabel, spiraler och skötselkit till Husqvarna Automower, Gardena Sileno, Worx Landroid och Mammotion LUBA.</p>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <AffiliateDisclaimer />
    <p class="text-sm text-text-light mb-6">Senast uppdaterad: mars 2026</p>

    <div class="bg-accent/5 border border-accent/20 rounded-xl px-5 py-4 mb-8 text-sm text-text">
      <strong>Säsongsstart-tips:</strong> Byt knivar, kontrollera kabel och spiraler, rengör sensorer och laddningsplatta — gör robotgräsklipparen redo inför säsongen.
    </div>

    {parts.map(section => (
      <section class="mb-10">
        <h2 class="font-heading text-2xl font-bold text-text mb-1">{section.category}</h2>
        <p class="text-sm text-text-light mb-5">{section.desc}</p>
        <div class="space-y-4">
          {section.products.map(p => (
            <article class="bg-white rounded-xl border border-border shadow-sm p-5">
              <div class="flex flex-col sm:flex-row sm:items-start gap-4">
                <div class="flex-1">
                  <div class="flex flex-wrap items-start gap-2 mb-1">
                    <h3 class="font-heading font-bold text-text text-base">{p.name}</h3>
                    {p.badge && <span class="text-xs font-semibold bg-winner/10 text-winner px-2 py-0.5 rounded-full">{p.badge}</span>}
                  </div>
                  <p class="text-xs text-accent font-medium mb-3">{p.compat}</p>
                  <div class="flex flex-wrap items-center gap-3">
                    <span class="text-lg font-bold text-text">{p.price}</span>
                    <a
                      href={p.ctaUrl}
                      rel="sponsored nofollow noopener"
                      target="_blank"
                      class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-cta text-white font-semibold rounded-lg hover:bg-cta-dark transition-colors text-sm min-h-[44px]"
                    >
                      Köp på Amazon
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                    </a>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="mb-8">
      <h2 class="font-heading text-xl font-bold text-text mb-4">Se fler reservdelar</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href="/reservdelar/husqvarna/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Husqvarna Automower reservdelar</a>
        <a href="/reservdelar/knivar/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Knivar — alla märken</a>
        <a href="/robotgrasklippare/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Bästa robotgräsklippare 2026</a>
        <a href="/kopguide-robotgrasklippare/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Köpguide robotgräsklippare</a>
      </div>
    </section>

    <FAQ items={faqItems} />
  </main>
</BaseLayout>
