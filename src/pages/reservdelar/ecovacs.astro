---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';
import FAQ from '../../components/FAQ.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const TAG = 'johnerik510-20';

const products = [
  {
    asin: 'B0DQ84RLZ7',
    img: '/images/parts-ecovacs-x5-kit.jpg',
    name: 'Ecovacs Deebot X5 Omni / X5 Pro — 20-delars komplett kit',
    compat: 'Passar: Deebot X5 Omni, X5 Pro',
    includes: '1 rullborste, 4 sidoborstar, 4 HEPA-filter, 6 dammpåsar, 4 mopptorkdukar, rengöringsborste',
    price: '226 kr',
    badge: 'Bästsäljare',
  },
  {
    asin: 'B0D7D1V4BP',
    img: '/images/parts-robot-kit-5.jpg',
    name: 'Ecovacs Deebot X5 Omni / X5 Pro — komplett tillbehörskit',
    compat: 'Passar: Deebot X5 Omni, X5 Pro',
    includes: '1 rullborste, 4 sidoborstar, 3 HEPA-filter, 3 dammpåsar, 4 mopptorkdukar',
    price: '373 kr',
    badge: 'Premium',
  },
  {
    asin: 'B0DF8695XP',
    img: '/images/parts-ecovacs-x5-brush-kit.jpg',
    name: 'Ecovacs Deebot X5 Omni / X5 Pro — borstar + filter + mopp',
    compat: 'Passar: Deebot X5 Omni, X5 Pro',
    includes: '1 huvudborste, 4 sidoborstar, 3 HEPA-filter, 3 dammpåsar, 4 mopptorkdukar',
    price: '231 kr',
    badge: null,
  },
  {
    asin: 'B0DY1DF8HQ',
    img: '/images/parts-ecovacs-kit-2.jpg',
    name: 'HIYOUNG — Ecovacs Deebot X5 / X5 Pro Omni — 20-delars kit',
    compat: 'Passar: Deebot X5 Omni, X5 Pro',
    includes: '2 huvudborstar, 4 sidoborstar, 4 HEPA-filter, 6 mopptorkdukar, 4 dammpåsar',
    price: '350 kr',
    badge: null,
  },
];

const faqItems = [
  {
    question: 'Passar alla Deebot X5-kit varandra?',
    answer: 'Deebot X5 Omni och X5 Pro delar samma reservdelssystem. Kontrollera att kittet du köper anger X5 Omni eller X5 Pro som kompatibel modell — inte bara "X5".',
  },
  {
    question: 'Hur ofta byter jag dammpåsar i Ecovacs dockningsstation?',
    answer: 'Byt dammpåsar när de är fyllda till 70–80 % eller var 4–6 vecka vid daglig städning. Appen meddelar dig när påsen behöver bytas.',
  },
  {
    question: 'Kan jag tvätta moppkuddarna i maskin?',
    answer: 'Ja, de flesta Ecovacs-moppkuddar är tvättbara i 40 grader. Låt dem lufttorka helt innan du sätter tillbaka dem — fuktig moppkudda kan skapa mögel och dålig lukt.',
  },
];

const breadcrumbs = [
  { label: 'Reservdelar', href: '/reservdelar/' },
  { label: 'Ecovacs' },
];
---

<BaseLayout
  title="Ecovacs Deebot reservdelar 2026 — filter och borstar"
  description="Reservdelar till Ecovacs Deebot X5 Omni och X5 Pro. Kompletta kit med filter, borstar, moppkuddar och dammpåsar — köp direkt på Amazon."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="bg-primary text-white py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-3">Ecovacs Deebot reservdelar</h1>
      <p class="text-gray-200 max-w-2xl">Tillbehörskit, filter, borstar och moppkuddar till Ecovacs Deebot X5 Omni och X5 Pro — håll roboten i toppskick.</p>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <AffiliateDisclaimer />
    <p class="text-sm text-text-light mb-6">Senast uppdaterad: mars 2026 &mdash; {products.length} produkter</p>

    <div class="space-y-4 mb-10">
      {products.map((p, i) => (
        <article class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow p-5">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-shrink-0 flex flex-col items-center gap-2">
              {i === 0 && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-winner/10 text-winner">{p.badge}</span>}
              {i > 0 && p.badge && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-bg-alt text-text-light">{p.badge}</span>}
              <div class="w-32 h-32 bg-gray-50 rounded-xl p-2 flex items-center justify-center border border-border">
                <img src={p.img} alt={p.name} class="w-full h-full object-contain" loading="lazy" />
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-bold text-text text-base mb-1">{p.name}</h2>
              <p class="text-xs text-accent font-medium mb-2">{p.compat}</p>
              <p class="text-xs text-text-light mb-4"><strong class="text-text">Innehåller:</strong> {p.includes}</p>
              <div class="flex flex-wrap items-center gap-3">
                <span class="text-xl font-bold text-text">{p.price}</span>
                <a href={`https://www.amazon.se/dp/${p.asin}?tag=${TAG}`} rel="sponsored nofollow noopener" target="_blank" class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-cta text-white font-semibold rounded-lg hover:bg-cta-dark transition-colors text-sm min-h-[44px]">
                  Köp på Amazon
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </a>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <section class="mb-8">
      <h2 class="font-heading text-xl font-bold text-text mb-4">Fler reservdelar</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href="/reservdelar/roborock/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Roborock reservdelar</a>
        <a href="/reservdelar/dreame/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Dreame reservdelar</a>
        <a href="/reservdelar/filter/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Filter till robotdammsugare</a>
        <a href="/reservdelar/borstar/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Borstar till robotdammsugare</a>
      </div>
    </section>

    <FAQ items={faqItems} />
  </main>
</BaseLayout>
