---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';
import FAQ from '../../components/FAQ.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const TAG = 'johnerik510-20';

const products = [
  {
    asin: 'B0CG4RR3W5',
    img: 'https://m.media-amazon.com/images/I/71iWCGSELCL._AC_UL320_.jpg',
    name: 'Roborock S8 / S8+ / S8 Pro Ultra — komplett borstar + filter kit',
    compat: 'Passar: S8, S8+, S8 Pro Ultra, S8 Max Ultra, S8 MaxV Ultra',
    includes: '2 huvudborstar, 4 sidoborstar, 2 HEPA-filter, 4 moppdukar, skruvmejsel',
    price: '252 kr',
    badge: 'Mest komplett',
    type: 'Komplett kit',
  },
  {
    asin: 'B0D6RFC7Q5',
    img: 'https://m.media-amazon.com/images/I/61yKYuMFi6L._AC_UL320_.jpg',
    name: 'Roborock S8 / S8+ / S8 Pro Ultra — gummiborstar + filter',
    compat: 'Passar: S8, S8+, S8 Pro Ultra',
    includes: '2 gummiborstar (huvudborste), 6 sidoborstar, 4 HEPA-filter',
    price: '195 kr',
    badge: 'Bästa pris',
    type: 'Borstar + filter',
  },
  {
    asin: 'B0CY5CWRXQ',
    img: 'https://m.media-amazon.com/images/I/71gGUWkjcFL._AC_UL320_.jpg',
    name: 'Roborock Qrevo S / Qrevo Pro / Qrevo MaxV — 20-delars kit',
    compat: 'Passar: Qrevo S, Qrevo Pro, Qrevo MaxV, Qrevo Plus',
    includes: '1 huvudborste, 6 sidoborstar, 4 HEPA-filter, 4 moppkuddar, 4 dammpåsar',
    price: '220 kr',
    badge: null,
    type: 'Komplett kit',
  },
  {
    asin: 'B0DRK62DKH',
    img: 'https://m.media-amazon.com/images/I/71hBkMqpgPL._AC_UL320_.jpg',
    name: 'Dreame X40 Ultra / X30 Ultra / L20 Ultra — huvudborstar',
    compat: 'Passar: X40 Ultra, X30 Ultra, L20 Ultra, L10s Ultra Gen2, L10s Pro Gen2',
    includes: '1 par gummiborstar (huvudborste) + skyddslock',
    price: '123 kr',
    badge: 'Bästa pris',
    type: 'Huvudborstar',
  },
  {
    asin: 'B0GQSJCLY4',
    img: 'https://m.media-amazon.com/images/I/71R1DqiXgcL._AC_UL320_.jpg',
    name: 'Dreame X40 Ultra / L40 Ultra / D20 Pro Plus — sidoborstar',
    compat: 'Passar: X40 Ultra, X40 Ultra Complete, L40 Ultra, D20 Pro Plus',
    includes: '6 sidoborstar (3-armade)',
    price: '141 kr',
    badge: null,
    type: 'Sidoborstar',
  },
  {
    asin: 'B0DFBMQ64P',
    img: 'https://m.media-amazon.com/images/I/71pTtn+ZUlL._AC_UL320_.jpg',
    name: 'Dreame X40 Ultra / X30 Ultra / L20 Ultra — 18-delars komplett kit',
    compat: 'Passar: X40 Ultra, X30 Ultra, L20 Ultra',
    includes: '1 huvudborste, 4 sidoborstar, 4 HEPA-filter, 4 moppkuddar, 4 dammpåsar',
    price: '256 kr',
    badge: 'Populärt',
    type: 'Komplett kit',
  },
  {
    asin: 'B0DQ84RLZ7',
    img: 'https://m.media-amazon.com/images/I/81z6rTFxA2L._AC_UL320_.jpg',
    name: 'Ecovacs Deebot X5 Omni / X5 Pro — 20-delars komplett kit',
    compat: 'Passar: Deebot X5 Omni, X5 Pro',
    includes: '1 rullborste, 4 sidoborstar, 4 HEPA-filter, 6 dammpåsar, 4 mopptorkdukar',
    price: '226 kr',
    badge: null,
    type: 'Komplett kit',
  },
  {
    asin: 'B0DF8695XP',
    img: 'https://m.media-amazon.com/images/I/611+p5Cey7L._AC_UL320_.jpg',
    name: 'Ecovacs Deebot X5 Omni / X5 Pro — borstar + filter + mopp',
    compat: 'Passar: Deebot X5 Omni, X5 Pro',
    includes: '1 huvudborste, 4 sidoborstar, 3 HEPA-filter, 3 dammpåsar, 4 mopptorkdukar',
    price: '231 kr',
    badge: null,
    type: 'Komplett kit',
  },
];

const faqItems = [
  {
    question: 'Hur ofta ska jag byta borstar på robotdammsugaren?',
    answer: 'Sidoborstar slits snabbast — byt var 6–12 månad eller när de böjer sig och inte längre är raka. Huvudborsten håller 12–18 månader. Kontrollera regelbundet att inga hår eller trådar fastnat runt axeln.',
  },
  {
    question: 'Vad är skillnaden mellan gummiborste och borstborste?',
    answer: 'Gummiborstar är bättre för hårda golv och lämnar inga borstrester. Traditionella borstborstar är effektivare på mattor. De flesta moderna Roborock- och Dreamemodeller levereras med gummiborstar som standardbyte.',
  },
  {
    question: 'Passar tredjepartsborstar lika bra som original?',
    answer: 'Ja, i de flesta fall. Välj borstar som tydligt anger kompatibla modeller och kontrollera kundrecensioner. Undvik extremt billiga borstar utan modellspecifikation — de kan ha fel dimensioner och sitta löst.',
  },
];

const breadcrumbs = [
  { label: 'Reservdelar', href: '/reservdelar/' },
  { label: 'Borstar' },
];
---

<BaseLayout
  title="Ersättningsborstar till robotdammsugare 2026 — Roborock, Dreame, Ecovacs"
  description="Köp rätt ersättningsborstar till din robotdammsugare. Komplett kit med huvud- och sidoborstar till Roborock S8, Dreame X40, Ecovacs Deebot X5 — direkt på Amazon."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="bg-primary text-white py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-3">Ersättningsborstar till robotdammsugare</h1>
      <p class="text-gray-200 max-w-2xl">Huvud- och sidoborstar till Roborock, Dreame och Ecovacs. Byt slitna borstar för att hålla sugkraft och städkvalitet på topp.</p>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <AffiliateDisclaimer />
    <p class="text-sm text-text-light mb-2">Senast uppdaterad: mars 2026 &mdash; {products.length} borstkits</p>

    <div class="bg-accent/5 border border-accent/20 rounded-xl px-5 py-4 mb-8 text-sm text-text">
      <strong>Tips:</strong> Köp ett komplett kit (borstar + filter + moppkuddar) — du sparar pengar och behöver bara beställa en gång.
    </div>

    <div class="space-y-4 mb-10">
      {products.map((p, i) => (
        <article class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow p-5">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-shrink-0 flex flex-col items-center gap-2">
              {i === 0 && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-winner/10 text-winner">{p.badge}</span>}
              {i > 0 && p.badge && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-bg-alt text-text-light">{p.badge}</span>}
              <div class="w-32 h-32 bg-gray-50 rounded-xl p-2 flex items-center justify-center border border-border">
                <img src={p.img} alt={p.name} class="w-full h-full object-contain" loading="lazy" />
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-start gap-2 mb-1">
                <h2 class="font-heading font-bold text-text text-base">{p.name}</h2>
                <span class="text-xs bg-bg-alt text-text-light px-2 py-0.5 rounded-full">{p.type}</span>
              </div>
              <p class="text-xs text-accent font-medium mb-2">{p.compat}</p>
              <p class="text-xs text-text-light mb-4"><strong class="text-text">Innehåller:</strong> {p.includes}</p>
              <div class="flex flex-wrap items-center gap-3">
                <span class="text-xl font-bold text-text">{p.price}</span>
                <a
                  href={`https://www.amazon.se/dp/${p.asin}?tag=${TAG}`}
                  rel="sponsored nofollow noopener"
                  target="_blank"
                  class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-cta text-white font-semibold rounded-lg hover:bg-cta-dark transition-colors text-sm min-h-[44px]"
                >
                  Köp på Amazon
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </a>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <section class="mb-8">
      <h2 class="font-heading text-xl font-bold text-text mb-4">Fler reservdelar</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href="/reservdelar/filter/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Filter till robotdammsugare</a>
        <a href="/reservdelar/roborock/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Alla Roborock reservdelar</a>
        <a href="/reservdelar/dreame/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Alla Dreame reservdelar</a>
        <a href="/reservdelar/ecovacs/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Alla Ecovacs reservdelar</a>
      </div>
    </section>

    <FAQ items={faqItems} />
  </main>
</BaseLayout>
