---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';
import FAQ from '../../components/FAQ.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const TAG = 'johnerik510-20';

const products = [
  {
    asin: 'B0CG4RR3W5',
    img: '/images/parts-roborock-s8-kit.webp',
    name: 'Roborock S8 / S8+ / S8 Pro Ultra, komplett tillbehörskit',
    compat: 'Passar: S8, S8+, S8 Pro Ultra, S8 Max Ultra, S8 MaxV Ultra',
    includes: '2 HEPA-filter, 2 huvudborstar, 4 sidoborstar, 4 moppdukar, skruvmejsel',
    badge: 'Bästsäljare',
    series: 'S8-serien',
  },
  {
    asin: 'B0CQHPR8TR',
    img: '/images/parts-robot-kit-6.webp',
    name: 'Roborock S8+ / S8 Pro Ultra, komplett kit med dammpåsar',
    compat: 'Passar: S8+, S8 Pro Ultra, S8 Max Ultra',
    includes: '2 HEPA-filter, 2 huvudborstar, 4 sidoborstar, 4 dammpåsar, 4 moppdukar',
    badge: 'Mest komplett',
    series: 'S8-serien',
  },
  {
    asin: 'B0D6RFC7Q5',
    img: '/images/parts-roborock-filter.webp',
    name: 'Roborock S8 / S8+ / S8 Pro Ultra, gummiborstar + filter',
    compat: 'Passar: S8, S8+, S8 Pro Ultra',
    includes: '2 gummiborstar, 6 sidoborstar, 4 HEPA-filter',
    badge: 'Bästa pris',
    series: 'S8-serien',
  },
  {
    asin: 'B0CY5CWRXQ',
    img: '/images/parts-roborock-qrevo-kit.webp',
    name: 'Roborock Qrevo S / Qrevo Pro / Qrevo MaxV, 20-delars kit',
    compat: 'Passar: Qrevo S, Qrevo Pro, Qrevo MaxV, Qrevo Plus',
    includes: '1 huvudborste, 6 sidoborstar, 4 HEPA-filter, 4 moppkuddar, 4 dammpåsar',
    badge: null,
    series: 'Qrevo-serien',
  },
  {
    asin: 'B0DG5J1QK7',
    img: '/images/parts-roborock-qrevo-kit-2.webp',
    name: 'Roborock Qrevo Pro / Qrevo S / Qrevo MaxV, 22-delars kit',
    compat: 'Passar: Qrevo Pro, Qrevo S, Qrevo MaxV',
    includes: '2 huvudborstar, 6 sidoborstar, 4 HEPA-filter, 4 dammpåsar, 4 mopptorkdukar',
    badge: null,
    series: 'Qrevo-serien',
  },
  {
    asin: 'B0DG5H9HLH',
    img: '/images/parts-roborock-qrevo-kit-3.webp',
    name: 'Roborock Qrevo S / Qrevo Pro / Qrevo MaxV, 21-delars kit',
    compat: 'Passar: Qrevo S, Qrevo Pro, Qrevo MaxV',
    includes: '1 huvudborste, 4 sidoborstar, 4 HEPA-filter, 4 mopptorkdukar, 6 dammpåsar',
    badge: 'Bästa pris Qrevo',
    series: 'Qrevo-serien',
  },
];

const faqItems = [
  {
    question: 'Vilket reservdelskit passar min Roborock-modell?',
    answer: 'S8, S8+, S8 Pro Ultra, S8 Max Ultra och S8 MaxV Ultra delar alla samma reservdelssystem. Qrevo-serien (Qrevo S, Qrevo Pro, Qrevo MaxV) har ett eget separat system. Kontrollera alltid att kittet du köper anger din exakta modell.',
  },
  {
    question: 'Hur ofta ska jag byta reservdelar på Roborock S8?',
    answer: 'HEPA-filter: var 2 månad. Sidoborstar: var 6 till 12 månad. Huvudborste (gummiborstar): var 12 till 18 månad. Moppkuddar: tvätta varje vecka, byt när de är slitna. Dammpåsar: när fyllda eller var 4 till 6 vecka.',
  },
  {
    question: 'Fungerar tredjepartskits i Roborock utan att ogiltigförklara garantin?',
    answer: 'I Sverige gäller att använda tredjepartsförbrukningsartiklar (filter, borstar) normalt inte ogiltigförklarar garantin på roboten. Kontakta Roborock kundtjänst om du är osäker.',
  },
];

const breadcrumbs = [
  { label: 'Reservdelar', href: '/reservdelar/' },
  { label: 'Roborock' },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": item.answer,
  },
}));
export const articleMeta = {
  title: "Reservdelar Roborock robotdammsugare 2026: komplett",
  description: "Komplett guide till reservdelar för Roborock 2026. Filter, borstar, moppar och dockningsstationer. Se kompatibilitet, byte-intervall och pris i Sverige.",
  publishDate: "2026-03-29",
  category: "Reservdelar",
  image: "/images/parts-roborock-filter.webp",
};

---

<BaseLayout
  title="Reservdelar Roborock robotdammsugare 2026: komplett"
  description="Komplett guide till reservdelar för Roborock 2026. Filter, borstar, moppar och dockningsstationer. Se kompatibilitet, byte-intervall och pris i Sverige."
  article={{ datePublished: "2026-03-29", dateModified: "2026-05-27", image: "/images/parts-roborock-filter.webp" }}
>
  <section class="bg-primary text-white py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} light={true} />
  <div class="max-w-4xl mx-auto px-4 py-2 flex flex-wrap items-center gap-2 text-xs text-slate-500">
    <a href="/om-redaktionen/" class="flex items-center gap-1.5 hover:text-blue-600 transition-colors">
      <span class="font-medium text-slate-700">Axel Jönemyr</span>
    </a>
    <span class="text-slate-400">·</span>
    <span>Redaktör, Robotjakt</span>
    <span>·</span>
    <span>Uppdaterad 27 maj 2026</span>
  </div>
      <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-3">Roborock reservdelar</h1>
      <p class="text-gray-200 max-w-2xl">Kompletta tillbehörskit till Roborock S8-serien och Qrevo-serien. Filter, borstar, moppkuddar och dammpåsar, allt du behöver för att hålla roboten i toppskick.</p>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
<p class="text-sm text-text-light mb-6">Senast uppdaterad: april 2026, {products.length} tillbehörskit</p>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
      {['S8-serien', 'Qrevo-serien'].map(series => (
        <a href={`#${series.toLowerCase().replace('-', '')}`} class="bg-white border border-border rounded-lg px-4 py-3 text-center hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">{series}</a>
      ))}
      <a href="/reservdelar/filter/" class="bg-white border border-border rounded-lg px-4 py-3 text-center hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Bara filter</a>
      <a href="/reservdelar/borstar/" class="bg-white border border-border rounded-lg px-4 py-3 text-center hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Bara borstar</a>
    </div>

    <h2 id="s8serien" class="font-heading text-xl font-bold text-text mb-4">S8-serien</h2>
    <div class="space-y-4 mb-10">
      {products.filter(p => p.series === 'S8-serien').map((p, i) => (
        <article class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow p-5">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-shrink-0 flex flex-col items-center gap-2">
              {i === 0 && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-winner/10 text-winner">{p.badge}</span>}
              {i > 0 && p.badge && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-bg-alt text-text-light">{p.badge}</span>}
              <div class="w-32 h-32 bg-gray-50 rounded-xl p-2 flex items-center justify-center border border-border">
                <img src={p.img} alt={p.name} class="w-full h-full object-contain" loading="lazy" width="200" height="200" />
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-heading font-bold text-text text-base mb-1">{p.name}</h3>
              <p class="text-xs text-accent font-medium mb-2">{p.compat}</p>
              <p class="text-xs text-text-light mb-4"><strong class="text-text">Innehåller:</strong> {p.includes}</p>
              <div class="flex flex-wrap items-center gap-3">
                
                
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <h2 id="qrevoserien" class="font-heading text-xl font-bold text-text mb-4">Qrevo-serien</h2>
    <div class="space-y-4 mb-10">
      {products.filter(p => p.series === 'Qrevo-serien').map((p, i) => (
        <article class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow p-5">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-shrink-0 flex flex-col items-center gap-2">
              {i === 0 && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-bg-alt text-text-light">{p.badge || 'Populärt'}</span>}
              {i > 0 && p.badge && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-winner/10 text-winner">{p.badge}</span>}
              <div class="w-32 h-32 bg-gray-50 rounded-xl p-2 flex items-center justify-center border border-border">
                <img src={p.img} alt={p.name} class="w-full h-full object-contain" loading="lazy" width="200" height="200" />
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-heading font-bold text-text text-base mb-1">{p.name}</h3>
              <p class="text-xs text-accent font-medium mb-2">{p.compat}</p>
              <p class="text-xs text-text-light mb-4"><strong class="text-text">Innehåller:</strong> {p.includes}</p>
              <div class="flex flex-wrap items-center gap-3">
                
                
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <section class="mb-8">
      <h2 class="font-heading text-xl font-bold text-text mb-4">Fler reservdelar</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href="/reservdelar/dreame/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Dreame reservdelar</a>
        <a href="/reservdelar/ecovacs/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Ecovacs reservdelar</a>
        <a href="/reservdelar/filter/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Filter till robotdammsugare</a>
        <a href="/reservdelar/borstar/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Borstar till robotdammsugare</a>
      </div>
    </section>

    <FAQ items={faqItems} />

    <AffiliateDisclaimer />
  </main>
</BaseLayout>
