---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';
import FAQ from '../../components/FAQ.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const TAG = 'johnerik510-20';

const products = [
  {
    asin: 'B0C9C5VNM1',
    img: '/images/parts-robot-kit-3.webp',
    name: '45-pack universalblad, Husqvarna, Gardena, Yardforce',
    compat: 'Passar: Husqvarna Automower (alla modeller), Gardena Sileno, Yardforce',
    includes: '45 ersättningsblad + skruvar ingår',
    badge: 'Bäst i test',
    detail: 'Standardtjocklek 0,75 mm, passar alla standardhållare',
  },
  {
    asin: 'B07WMTTSS4',
    img: '/images/parts-robot-filter-4.webp',
    name: 'Domar 30-pack förstärkta robotgräsklipparblad',
    compat: 'Passar: Husqvarna Automower, Gardena, Yard Force',
    includes: '30 blad + skruvar',
    badge: null,
    detail: 'Förstärkt stål för längre livslängd, populärt val',
  },
  {
    asin: 'B0D6YWJFJP',
    img: '/images/parts-dreame-brush.webp',
    name: '30-pack premium ersättningsblad, Husqvarna Automower',
    compat: 'Passar: Husqvarna Automower 105, 115H, 315, 315X, 430X, 450X',
    includes: '30 blad + skruvar',
    badge: null,
    detail: 'Väderbeständiga och långlivade blad',
  },
  {
    asin: 'B083SKXKR7',
    img: '/images/parts-lawn-blade.webp',
    name: 'Willingood 30-pack titanblad, universalpassning',
    compat: 'Passar: Husqvarna Automower, Gardena, McCulloch, Segway Navimow',
    includes: '30 titanblad + 30 skruvar',
    badge: 'Titanstål',
    detail: 'Extra hårda titanblad för tuffare gräs och kanter',
  },
  {
    asin: 'B0DRHWXPHC',
    img: '/images/parts-robot-filter-2.webp',
    name: 'Forever Speed, begränsningskabel 100 m (2,7 mm)',
    compat: 'Passar: Husqvarna Automower, Gardena Sileno, Worx Landroid, McCulloch',
    includes: '100 m kabel, diameter 2,7 mm, förtennad koppar',
    badge: null,
    detail: 'Universalkabel, passar alla kabeldrivna robotgräsklippare',
  },
  {
    asin: 'B0DRHXG9WX',
    img: '/images/parts-husqvarna-blade.webp',
    name: 'Forever Speed, begränsningskabel 150 m (2,7 mm)',
    compat: 'Passar: Husqvarna Automower, Gardena Sileno, Worx Landroid, McCulloch',
    includes: '150 m kabel, diameter 2,7 mm, förtennad koppar',
    badge: 'Stor tomt',
    detail: 'Räcker till tomter upp till ca 1 500 kvm',
  },
  {
    asin: 'B0D9QB7H3S',
    img: '/images/parts-robot-filter-5.webp',
    name: '20-pack kabelklämmor, skarvar och reparerar begränsningskabel',
    compat: 'Passar: Gardena, Husqvarna, alla kabeldrivna robotgräsklippare',
    includes: '20 anslutningsklämmor, passar kabel 2,7 till 3,4 mm',
    badge: null,
    detail: 'Nödvändiga för att skärva ihop kabel vid reparation',
  },
];

const faqItems = [
  {
    question: 'Hur ofta ska jag byta knivar på robotgräsklipparen?',
    answer: 'Byt knivar varje säsong (på våren) eller när du märker att gräset ser ojämnt klippt ut. Med hård mark, stenar eller rotfibrer i gräset slits knivarna snabbare, kontrollera var 4 till 6 vecka.',
  },
  {
    question: 'Passar universalblad i min Husqvarna Automower?',
    answer: 'Ja, universalblad passar alla standardmodeller av Husqvarna Automower som använder det vanliga triangulära hållarsystemet. Det gäller modeller 105, 115H, 310, 315, 315X, 430X och 450X. Kontrollera alltid produktbeskrivningen för kompatibilitet.',
  },
  {
    question: 'Behöver jag byta begränsningskabeln?',
    answer: 'Kabeln behöver sällan bytas i sin helhet men kan gå sönder vid grävarbeten, frost eller skadedjur. Använd kabelklämmor för att skärva ihop en bruten kabel, det är enkelt och billigt.',
  },
  {
    question: 'Vad är skillnaden mellan vanliga stålblad och titanblad?',
    answer: 'Titanblad är hårdare och håller skärpan längre, vilket är bra på tuffare mark med stenar eller kvistar. Vanliga stålblad räcker för normalt gräs och är billigare att byta ut. Välj titan om din tomt är krävande.',
  },
];

const breadcrumbs = [
  { label: 'Reservdelar', href: '/reservdelar/' },
  { label: 'Knivar & kabel' },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": item.answer,
  },
}));
export const articleMeta = {
  title: "Reservknivar till robotgräsklippare 2026: guide och köp",
  description: "Köpguide till reservknivar för robotgräsklippare 2026. Original och kompatibla alternativ till Husqvarna, Gardena och fler. Se byte-intervall och pris.",
  publishDate: "2026-03-29",
  category: "Reservdelar",
  image: "/images/parts-lawn-blade.webp",
};

---

<BaseLayout
  title="Reservknivar till robotgräsklippare 2026: guide och köp"
  description="Köpguide till reservknivar för robotgräsklippare 2026. Original och kompatibla alternativ till Husqvarna, Gardena och fler. Se byte-intervall och pris."
>
  <section class="bg-primary text-white py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} light={true} />
      <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-3">Knivar och kabel till robotgräsklippare</h1>
      <p class="text-gray-200 max-w-2xl">Ersättningsknivar, begränsningskabel och kabelklämmor till Husqvarna Automower, Gardena Sileno och Worx Landroid.</p>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
<p class="text-sm text-text-light mb-2">Senast uppdaterad: april 2026, {products.length} produkter</p>

    <div class="bg-accent/5 border border-accent/20 rounded-xl px-5 py-4 mb-8 text-sm text-text">
      <strong>Byt knivar varje säsong:</strong> Slöa knivar river gräset istället för att klippa det, vilket stressar gräsmattan och ökar risken för sjukdomar. Byt på våren innan säsongsstart.
    </div>

    <h2 class="font-heading text-xl font-bold text-text mb-4">Knivar</h2>
    <div class="space-y-4 mb-10">
      {products.filter((_, i) => i < 4).map((p, i) => (
        <article class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow p-5">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-shrink-0 flex flex-col items-center gap-2">
              {i === 0 && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-winner/10 text-winner">{p.badge}</span>}
              {i > 0 && p.badge && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-bg-alt text-text-light">{p.badge}</span>}
              <div class="w-32 h-32 bg-gray-50 rounded-xl p-2 flex items-center justify-center border border-border">
                <img src={p.img} alt={p.name} class="w-full h-full object-contain" loading="lazy" width="200" height="200" />
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-bold text-text text-base mb-1">{p.name}</h2>
              <p class="text-xs text-accent font-medium mb-1">{p.compat}</p>
              <p class="text-xs text-text-light mb-1"><strong class="text-text">Innehåller:</strong> {p.includes}</p>
              <p class="text-xs text-text-light mb-4">{p.detail}</p>
              <div class="flex flex-wrap items-center gap-3">
                
                
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <h2 class="font-heading text-xl font-bold text-text mb-4">Begränsningskabel och klämmor</h2>
    <div class="space-y-4 mb-10">
      {products.filter((_, i) => i >= 4).map((p) => (
        <article class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow p-5">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-shrink-0 flex flex-col items-center gap-2">
              {p.badge && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-bg-alt text-text-light">{p.badge}</span>}
              <div class="w-32 h-32 bg-gray-50 rounded-xl p-2 flex items-center justify-center border border-border">
                <img src={p.img} alt={p.name} class="w-full h-full object-contain" loading="lazy" width="200" height="200" />
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-bold text-text text-base mb-1">{p.name}</h2>
              <p class="text-xs text-accent font-medium mb-1">{p.compat}</p>
              <p class="text-xs text-text-light mb-1"><strong class="text-text">Innehåller:</strong> {p.includes}</p>
              <p class="text-xs text-text-light mb-4">{p.detail}</p>
              <div class="flex flex-wrap items-center gap-3">
                
                
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <section class="mb-8">
      <h2 class="font-heading text-xl font-bold text-text mb-4">Fler reservdelar</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href="/reservdelar/husqvarna/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Alla Husqvarna reservdelar</a>
        <a href="/reservdelar/robotgrasklippare/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Robotgräsklippare reservdelar</a>
        <a href="/reservdelar/filter/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Filter till robotdammsugare</a>
        <a href="/reservdelar/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Alla reservdelar</a>
      </div>
    </section>

    <FAQ items={faqItems} />

    <AffiliateDisclaimer />
  </main>
</BaseLayout>
