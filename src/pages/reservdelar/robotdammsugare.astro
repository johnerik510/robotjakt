---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';
import FAQ from '../../components/FAQ.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const TAG = 'johnerik510-20';

const products = [
  {
    asin: 'B0CG4RR3W5',
    img: '/images/parts-roborock-s8-kit.jpg',
    name: 'Roborock S8 / S8+ / S8 Pro Ultra — komplett tillbehörskit',
    compat: 'Passar: S8, S8+, S8 Pro Ultra, S8 Max Ultra, S8 MaxV Ultra',
    includes: '2 HEPA-filter, 2 huvudborstar, 4 sidoborstar, 4 moppdukar',
    price: '252 kr',
    badge: 'Populärast',
    brand: 'Roborock',
  },
  {
    asin: 'B0CY5CWRXQ',
    img: '/images/parts-roborock-qrevo-kit.jpg',
    name: 'Roborock Qrevo S / Qrevo Pro / Qrevo MaxV — 20-delars kit',
    compat: 'Passar: Qrevo S, Qrevo Pro, Qrevo MaxV, Qrevo Plus',
    includes: '1 huvudborste, 6 sidoborstar, 4 HEPA-filter, 4 moppkuddar, 4 dammpåsar',
    price: '220 kr',
    badge: null,
    brand: 'Roborock',
  },
  {
    asin: 'B0DFBMQ64P',
    img: '/images/parts-dreame-x40-kit.jpg',
    name: 'Dreame X40 Ultra / X30 Ultra / L20 Ultra — 18-delars kit',
    compat: 'Passar: X40 Ultra, X30 Ultra, L20 Ultra',
    includes: '1 huvudborste, 4 sidoborstar, 4 HEPA-filter, 4 moppkuddar, 4 dammpåsar',
    price: '256 kr',
    badge: null,
    brand: 'Dreame',
  },
  {
    asin: 'B0DTTPX9DW',
    img: '/images/parts-dreame-x40-filter.jpg',
    name: 'Dreame X40 Ultra / L10s Pro Ultra Heat — 4-pack filter',
    compat: 'Passar: X40 Ultra Complete, X40 Master, L10s Pro Ultra Heat, X30 Pro Plus',
    includes: '4 HEPA E12-filter',
    price: '125 kr',
    badge: 'Bästa pris',
    brand: 'Dreame',
  },
  {
    asin: 'B0DQ84RLZ7',
    img: '/images/parts-ecovacs-x5-kit.jpg',
    name: 'Ecovacs Deebot X5 Omni / X5 Pro — 20-delars kit',
    compat: 'Passar: Deebot X5 Omni, X5 Pro',
    includes: '1 rullborste, 4 sidoborstar, 4 HEPA-filter, 6 dammpåsar, 4 mopptorkdukar',
    price: '226 kr',
    badge: null,
    brand: 'Ecovacs',
  },
  {
    asin: 'B0DF8695XP',
    img: '/images/parts-ecovacs-x5-brush-kit.jpg',
    name: 'Ecovacs Deebot X5 Omni / X5 Pro — borstar + filter + mopp',
    compat: 'Passar: Deebot X5 Omni, X5 Pro',
    includes: '1 huvudborste, 4 sidoborstar, 3 HEPA-filter, 3 dammpåsar, 4 mopptorkdukar',
    price: '231 kr',
    badge: null,
    brand: 'Ecovacs',
  },
];

const brands = ['Roborock', 'Dreame', 'Ecovacs'];

const faqItems = [
  {
    question: 'Vilka reservdelar behöver man byta regelbundet?',
    answer: 'HEPA-filter (var 2–3 mån), sidoborstar (var 6–12 mån), huvudborste (var 12 mån) och moppkuddar (tvätta veckovis, byt vid slitage). Dammpåsar vid behov.',
  },
  {
    question: 'Kostar det mycket att underhålla en robotdammsugare?',
    answer: 'Nej. Kompletta kit kostar 200–350 kr och räcker 6–12 månader. Det är billigare än service och håller roboten i toppskick hela året.',
  },
  {
    question: 'Kan jag köpa originaldelar eller räcker tredjepartskits?',
    answer: 'Tredjepartskits fungerar utmärkt för förbrukningsartiklar som filter och borstar. Välj kit med tydlig kompatibilitetsinfo och goda recensioner.',
  },
];

const breadcrumbs = [
  { label: 'Reservdelar', href: '/reservdelar/' },
  { label: 'Robotdammsugare' },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": item.answer,
  },
}));
---

<BaseLayout
  title="Robotdammsugare Reservdelar 2026 — Filter & Borstar"
  description="Reservdelar till robotdammsugare — filter, borstar och kompletta kit till Roborock, Dreame och Ecovacs. Köp direkt på Amazon med snabb leverans till Sverige."
>
  <section class="bg-primary text-white py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={breadcrumbs} light={true} />
      <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-3">Robotdammsugare reservdelar</h1>
      <p class="text-gray-200 max-w-2xl">Kompletta tillbehörskit till Roborock, Dreame och Ecovacs. Filter, borstar och moppkuddar — allt på ett ställe.</p>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <AffiliateDisclaimer />
    <p class="text-sm text-text-light mb-6">Senast uppdaterad: april 2026 &mdash; {products.length} produkter</p>

    <div class="flex flex-wrap gap-2 mb-8">
      {brands.map(b => (
        <a href={`/reservdelar/${b.toLowerCase()}/`} class="bg-white border border-border rounded-full px-4 py-2 text-sm font-semibold text-text hover:border-accent hover:text-accent transition-colors">{b}</a>
      ))}
      <a href="/reservdelar/filter/" class="bg-white border border-border rounded-full px-4 py-2 text-sm font-semibold text-text hover:border-accent hover:text-accent transition-colors">Bara filter</a>
      <a href="/reservdelar/borstar/" class="bg-white border border-border rounded-full px-4 py-2 text-sm font-semibold text-text hover:border-accent hover:text-accent transition-colors">Bara borstar</a>
    </div>

    <div class="space-y-4 mb-10">
      {products.map((p, i) => (
        <article class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow p-5">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-shrink-0 flex flex-col items-center gap-2">
              {i === 0 && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-winner/10 text-winner">{p.badge}</span>}
              {i > 0 && p.badge && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-bg-alt text-text-light">{p.badge}</span>}
              <div class="w-32 h-32 bg-gray-50 rounded-xl p-2 flex items-center justify-center border border-border">
                <img src={p.img} alt={p.name} class="w-full h-full object-contain" loading="lazy" />
              </div>
              <span class="text-xs text-text-lighter font-medium">{p.brand}</span>
            </div>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-bold text-text text-base mb-1">{p.name}</h2>
              <p class="text-xs text-accent font-medium mb-2">{p.compat}</p>
              <p class="text-xs text-text-light mb-4"><strong class="text-text">Innehåller:</strong> {p.includes}</p>
              <div class="flex flex-wrap items-center gap-3">
                <span class="text-xl font-bold text-text">{p.price}</span>
                <a href={`https://www.amazon.se/dp/${p.asin}?tag=${TAG}`} rel="sponsored nofollow noopener noreferrer" target="_blank" class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-cta text-white font-semibold rounded-lg hover:bg-cta-dark transition-colors text-sm min-h-[44px]">
                  Köp på Amazon
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </a>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <FAQ items={faqItems} />
  </main>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqSchema,
  })} />
</BaseLayout>
