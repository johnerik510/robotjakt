---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';
import FAQ from '../../components/FAQ.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const TAG = 'johnerik510-20';

const products = [
  {
    asin: 'B0CG4RR3W5',
    img: '/images/parts-roborock-s8-kit.jpg',
    name: 'Roborock S8 / S8+ / S8 Pro Ultra — komplett tillbehörskit',
    compat: 'Passar: S8, S8+, S8 Pro Ultra, S8 Max Ultra, S8 MaxV Ultra',
    includes: '2 HEPA-filter, 2 huvudborstar, 4 sidoborstar, 4 moppdukar',
    price: '252 kr',
    badge: 'Bästsäljare',
    interval: 'Byt filter var 2–3 mån',
  },
  {
    asin: 'B0D6RFC7Q5',
    img: '/images/parts-roborock-filter.jpg',
    name: 'Roborock S8 / S8+ / S8 Pro Ultra — filter + gummiborstar',
    compat: 'Passar: S8, S8+, S8 Pro Ultra',
    includes: '4 HEPA-filter, 2 gummiborstar, 6 sidoborstar',
    price: '195 kr',
    badge: 'Bästa pris',
    interval: 'Byt filter var 2 mån',
  },
  {
    asin: 'B0CY5CWRXQ',
    img: '/images/parts-roborock-qrevo-kit.jpg',
    name: 'Roborock Qrevo S / Qrevo Pro / Qrevo MaxV — 20-delars kit',
    compat: 'Passar: Qrevo S, Qrevo Pro, Qrevo MaxV, Qrevo Plus',
    includes: '4 HEPA-filter, 1 huvudborste, 4 moppkuddar, 6 sidoborstar, 4 dammpåsar',
    price: '220 kr',
    badge: null,
    interval: 'Byt filter var 2–3 mån',
  },
  {
    asin: 'B0DFBMQ64P',
    img: '/images/parts-dreame-x40-kit.jpg',
    name: 'Dreame X40 Ultra / X30 Ultra / L20 Ultra — 18-delars tillbehörskit',
    compat: 'Passar: X40 Ultra, X30 Ultra, L20 Ultra, L10s Ultra Gen2',
    includes: '4 HEPA-filter, 1 huvudborste, 4 moppkuddar, 4 sidoborstar, 4 dammpåsar',
    price: '256 kr',
    badge: 'Populärt val',
    interval: 'Byt filter var 2–3 mån',
  },
  {
    asin: 'B0DTTPX9DW',
    img: '/images/parts-dreame-x40-filter.jpg',
    name: 'Dreame X40 Ultra / L10s Pro Ultra Heat / X30 Pro — 4-pack filter',
    compat: 'Passar: X40 Ultra Complete, X40 Master, L10s Pro Ultra Heat, X30 Pro Plus',
    includes: '4 HEPA E12-filter',
    price: '125 kr',
    badge: 'Bästa pris',
    interval: 'Byt var 2 mån',
  },
  {
    asin: 'B0DQ84RLZ7',
    img: '/images/parts-ecovacs-x5-kit.jpg',
    name: 'Ecovacs Deebot X5 Omni / X5 Pro — 20-delars komplett kit',
    compat: 'Passar: Deebot X5 Omni, X5 Pro',
    includes: '4 HEPA-filter, 1 rullborste, 4 sidoborstar, 6 dammpåsar, 4 mopptorkdukar',
    price: '226 kr',
    badge: null,
    interval: 'Byt filter var 2 mån',
  },
  {
    asin: 'B0DF8695XP',
    img: '/images/parts-ecovacs-x5-brush-kit.jpg',
    name: 'Ecovacs Deebot X5 Omni / X5 Pro — filter + borstar + mopp',
    compat: 'Passar: Deebot X5 Omni, X5 Pro',
    includes: '3 HEPA-filter, 1 huvudborste, 4 sidoborstar, 3 dammpåsar, 4 mopptorkdukar',
    price: '231 kr',
    badge: null,
    interval: 'Byt filter var 2 mån',
  },
];

const faqItems = [
  {
    question: 'Hur ofta ska jag byta filter på min robotdammsugare?',
    answer: 'Byt HEPA-filter var 2–3 månad vid normalt bruk. Har du husdjur eller allergiker hemma bör du byta var 4–6 vecka. Många modellers appar skickar påminnelse när det är dags.',
  },
  {
    question: 'Vad är skillnaden mellan HEPA E11 och E12?',
    answer: 'HEPA E11 filtrerar 95 % av partiklar ner till 0,3 mikron. HEPA E12 filtrerar 99,5 %. För allergiker eller husdjursägare rekommenderas E12. Kontrollera att filtret är äkta HEPA — inte bara "HEPA-liknande".',
  },
  {
    question: 'Fungerar tredjepartsfilter från Amazon lika bra som original?',
    answer: 'Kvaliteten varierar. Välkända märken med tydlig kompatibilitetsinfo håller generellt god kvalitet. Undvik extremt billiga okända filter utan specifikationer — de kan ha sämre filtrationsförmåga.',
  },
  {
    question: 'Kan jag tvätta filtret istället för att byta?',
    answer: 'Vissa filter är tvättbara — skölj med kallt vatten och torka i 24 timmar. HEPA-filter i de flesta modeller är inte tvättbara: vatten förstör filtermaterialet. Kontrollera din modells manual.',
  },
];

const breadcrumbs = [
  { label: 'Reservdelar', href: '/reservdelar/' },
  { label: 'Filter' },
];
---

<BaseLayout
  title="Ersättningsfilter robotdammsugare April 2026 — HEPA och mer"
  description="Köp rätt HEPA-filter till din robotdammsugare. Kompletta kit till Roborock S8, Dreame X40 Ultra, Ecovacs Deebot X5 — direktlänk till Amazon med snabb leverans."
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="bg-primary text-white py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-3">Ersättningsfilter till robotdammsugare</h1>
      <p class="text-gray-200 max-w-2xl">HEPA-filter och tillbehörskit till Roborock, Dreame och Ecovacs — byt filter regelbundet för maximal sugkraft och ren inomhusluft.</p>
    </div>
  </section>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <AffiliateDisclaimer />
    <p class="text-sm text-text-light mb-2">Senast uppdaterad: mars 2026 &mdash; {products.length} filterkit</p>

    <div class="bg-accent/5 border border-accent/20 rounded-xl px-5 py-4 mb-8 text-sm text-text">
      <strong>Tips:</strong> Köp ett komplett kit (filter + borstar) istället för filter separat — du får fler delar till bättre pris och slipper beställa igen när borsten är sliten.
    </div>

    <div class="space-y-4 mb-10">
      {products.map((p, i) => (
        <article class="bg-white rounded-xl border border-border shadow-sm hover:shadow-md transition-shadow p-5">
          <div class="flex flex-col sm:flex-row gap-4">
            <div class="flex-shrink-0 flex flex-col items-center gap-2">
              {i === 0 && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-winner/10 text-winner">Bästsäljare</span>}
              {i > 0 && p.badge && <span class="text-xs font-bold uppercase px-3 py-1 rounded-full bg-bg-alt text-text-light">{p.badge}</span>}
              <div class="w-32 h-32 bg-gray-50 rounded-xl p-2 flex items-center justify-center border border-border">
                <img src={p.img} alt={p.name} class="w-full h-full object-contain" loading="lazy" />
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <h2 class="font-heading font-bold text-text text-base mb-1">{p.name}</h2>
              <p class="text-xs text-accent font-medium mb-2">{p.compat}</p>
              <p class="text-xs text-text-light mb-1"><strong class="text-text">Innehåller:</strong> {p.includes}</p>
              <p class="text-xs text-text-light mb-4"><strong class="text-text">Byta:</strong> {p.interval}</p>
              <div class="flex flex-wrap items-center gap-3">
                <span class="text-xl font-bold text-text">{p.price}</span>
                <a
                  href={`https://www.amazon.se/dp/${p.asin}?tag=${TAG}`}
                  rel="sponsored nofollow noopener noreferrer"
                  target="_blank"
                  class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-cta text-white font-semibold rounded-lg hover:bg-cta-dark transition-colors text-sm min-h-[44px]"
                >
                  Köp på Amazon
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </a>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <section class="mb-10">
      <h2 class="font-heading text-xl font-bold text-text mb-2">Byt-intervall per modell</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-bg-alt">
              <th class="text-left px-4 py-3 font-semibold text-text rounded-tl-lg">Modell</th>
              <th class="text-left px-4 py-3 font-semibold text-text">Filtertyp</th>
              <th class="text-left px-4 py-3 font-semibold text-text rounded-tr-lg">Byt-intervall</th>
            </tr>
          </thead>
          <tbody>
            {[
              { model: 'Roborock S8 / S8+ / S8 Pro Ultra', type: 'HEPA E11', interval: 'Var 2 månad' },
              { model: 'Roborock Qrevo Pro / Qrevo MaxV', type: 'HEPA E11', interval: 'Var 2 månad' },
              { model: 'Dreame X40 Ultra / L20 Ultra', type: 'HEPA E12', interval: 'Var 2–3 månad' },
              { model: 'Ecovacs Deebot X5 Omni / T20 Omni', type: 'HEPA E11', interval: 'Var 2 månad' },
            ].map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-bg-alt/50'}>
                <td class="px-4 py-3 font-medium text-text border-t border-border">{row.model}</td>
                <td class="px-4 py-3 text-text-light border-t border-border">{row.type}</td>
                <td class="px-4 py-3 text-text-light border-t border-border">{row.interval}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="font-heading text-xl font-bold text-text mb-4">Fler reservdelar</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href="/reservdelar/borstar/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Borstar till robotdammsugare</a>
        <a href="/reservdelar/roborock/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Alla Roborock reservdelar</a>
        <a href="/reservdelar/dreame/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Alla Dreame reservdelar</a>
        <a href="/reservdelar/ecovacs/" class="bg-white border border-border rounded-lg px-4 py-3 hover:border-accent hover:shadow-sm transition-all text-sm font-semibold text-text hover:text-accent">Alla Ecovacs reservdelar</a>
      </div>
    </section>

    <FAQ items={faqItems} />
  </main>
</BaseLayout>
