    emptying: 'Manuell',
    mop: 'Nej',
    bestFor: 'Enkel dagsstädning, budget',
  },
];

const faqItems = [
  {
    question: 'Vad är eufy och vem tillverkar dem?',
    answer: 'eufy är ett konsumentelektronikmärke under Anker Innovations, ett kinesiskt teknikföretag grundat 2011, känt globalt för bärbara batterier och Qi-laddare. eufy-linjen lanserades 2016 med fokus på smarthemsprodukter inklusive robotdammsugare, övervakningskameror och dörrklockor. Anker/eufy säljer i Sverige via Amazon, Elgiganten och auktoriserade näthandlare.',
  },
  {
    question: 'Är eufy robotdammsugare bra eller en kompromiss?',
