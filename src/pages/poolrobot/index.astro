---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';
import FAQ from '../../components/FAQ.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AuthorByline from '../../components/AuthorByline.astro';
import AnswerBox from '../../components/AnswerBox.astro';
import MoneyFeatured from '../../components/MoneyFeatured.astro';
import MoneyComparisonTable from '../../components/MoneyComparisonTable.astro';
import MoneyTOC from '../../components/MoneyTOC.astro';
import MethodologyBlock from '../../components/MethodologyBlock.astro';

const products = [
  {
    rank: 1,
    name: 'Zodiac Electric Pool Cleaner GT3220',
    image: 'https://csdam.net/data/jpg/0/dc98b5ed/dc98b5ed-5b66-4dc3-85d2-044eee59877f.jpg',
    rating: 4.5,
    badge: 'Bäst i test',
    pros: ['Rengör botten och väggar', 'Pålitlig motor', 'Enkel filtertömning', 'Zodiac-kvalitet'],
    cons: ['Ingen app/WiFi', 'Kabeldriven'],
    ctaText: 'Bra pris hos CS Megastore',
    ctaUrl: 'https://go.csmegastore.se/t/t?a=1514097163&as=2063681412&t=2&tk=1&cupa_sku=20565812&url=https://www.csmegastore.se/i/20565812/zodiac-electric-pool-cleaner-gt3220',
    dataProduct: 'Zodiac GT3220',
  },
  {
    rank: 2,
    name: 'Planet Pool Orca 50CL',
    image: '/images/orca-50cl.webp',
    rating: 4.3,
    badge: 'Bäst budget',
    pros: ['Batteridrift, ingen kabel', 'Rengör botten och väggar', 'Lättviktig (4,5 kg)', 'Passar pooler upp till 80 m³'],
    cons: ['Ingen app', 'Batteridriven, begränsad drifttid'],
    ctaText: 'Bra pris hos Villanytt',
    ctaUrl: 'https://addrevenue.io/t?c=3467327&a=984922&m=SE&u=https%3A%2F%2Fvillanytt.se%2Fprodukt%2Fpoolrobot-orca-50cl-batteridriven%2F%3Futm_source%3DGoogle%20Shopping%26utm_campaign%3DGoogle%20Shopping%26utm_medium%3Dcpc%26utm_term%3D62432',
    dataProduct: 'Planet Pool Orca 50CL',
  },
  {
    rank: 3,
    name: 'CF 200CL Poolrobot',
    image: '/images/cf-200cl.webp',
    rating: 4.2,
    pros: ['Rengör botten och väggar', 'Kraftfull sugmotor', 'Enkel att hantera', 'Passar de flesta poolformer'],
    cons: ['Ingen app', 'Kabeldriven'],
    ctaText: 'Bra pris hos Villanytt',
    ctaUrl: 'https://addrevenue.io/t?c=3467327&a=984922&m=SE&u=https%3A%2F%2Fvillanytt.se%2Fprodukt%2Fcf-200cl-poolrobot%2F%3Futm_source%3DGoogle%20Shopping%26utm_campaign%3DGoogle%20Shopping%26utm_medium%3Dcpc%26utm_term%3D74422',
    dataProduct: 'CF 200CL Poolrobot',
  },
  {
    rank: 4,
    name: 'Planet Pool Orca 300+',
    image: '/images/orca-300plus.webp',
    rating: 4.4,
    badge: 'Bäst mellanklass',
    pros: ['Rengör botten, väggar och vattenlinje', 'Batteridrift', 'Passar pooler upp till 120 m³', 'Bra filtreringskapacitet'],
    cons: ['Ingen WiFi-app', 'Tyngre modell'],
    ctaText: 'Bra pris hos Villanytt',
    ctaUrl: 'https://addrevenue.io/t?c=3467327&a=984922&m=SE&u=https%3A%2F%2Fvillanytt.se%2Fprodukt%2Fpoolrobot-orca-300cl-batteridriven%2F%3Futm_source%3DGoogle%20Shopping%26utm_campaign%3DGoogle%20Shopping%26utm_medium%3Dcpc%26utm_term%3D60843',
    dataProduct: 'Planet Pool Orca 300+',
  },
  {
    rank: 5,
    name: 'CF 400CL Poolrobot',
    image: '/images/cf-400cl.webp',
    rating: 4.3,
    pros: ['Rengör botten, väggar och vattenlinje', 'Stark sugkraft', 'Passar stora pooler', 'Dubbla filter'],
    cons: ['Ingen app', 'Kabeldriven'],
    ctaText: 'Bra pris hos Villanytt',
    ctaUrl: 'https://addrevenue.io/t?c=3467327&a=984922&m=SE&u=https%3A%2F%2Fvillanytt.se%2Fprodukt%2Fpoolrobot-cf-400cl%2F%3Futm_source%3DGoogle%20Shopping%26utm_campaign%3DGoogle%20Shopping%26utm_medium%3Dcpc%26utm_term%3D74421',
    dataProduct: 'CF 400CL Poolrobot',
  },
  {
    rank: 6,
    name: 'Zodiac Robot CNX-LI 5220 IQ',
    image: 'https://csdam.net/data/jpg/0/52a79c66/52a79c66-3500-43df-8129-62a751dd58e1.jpg',
    rating: 4.4,
    badge: 'Premium',
    pros: ['WiFi-app via MyDolphin', 'Rengör botten, väggar och vattenlinje', 'Intelligent navigering', 'Kraftfullt filter'],
    cons: ['Dyr', 'Kräver Wi-Fi-router nära poolen'],
    ctaText: 'Bra pris hos CS Megastore',
    ctaUrl: 'https://go.csmegastore.se/t/t?a=1514097163&as=2063681412&t=2&tk=1&cupa_sku=20565815&url=https://www.csmegastore.se/i/20565815/zodiac-robot-cnx-li-5220-iq',
    dataProduct: 'Zodiac CNX-LI 5220 IQ',
  },
];

const faqItems = [
  {
    question: 'Hur länge håller en poolrobot?',
    answer: 'En poolrobot håller normalt 5 till 10 år med rätt skötsel. Det viktigaste är att alltid ta upp roboten ur poolen efter varje rengöringscykel, spola av den med rent vatten och förvara den svalt och skyddat från sol och frost. Byt filter och borstar regelbundet enligt tillverkarens anvisningar.',
  },
  {
    question: 'Kan poolroboten vara i vattnet hela tiden?',
    answer: 'Nej, poolroboten ska inte ligga kvar i poolen konstant. Ta alltid upp den ur vattnet när rengöringen är klar. Långvarig vistelse i poolkemikalier sliter på motor, kabel och filter. Roboten bör förvaras ur vattnet och skyddad från solljus när den inte används.',
  },
  {
    question: 'Behöver man fortfarande kemikalier när man har poolrobot?',
    answer: 'Ja, en poolrobot ersätter inte kemikalier. Roboten tar hand om smuts, alger och partiklar på botten och väggarna, men vattnets pH-balans och klorhalt måste fortfarande hållas på rätt nivå med kemikalier. Robot och kemikalier kompletterar varandra för en ren och hygienisk pool.',
  },
  {
    question: 'Vad skiljer en poolrobot från en manuell dammsugare?',
    answer: 'En poolrobot arbetar helt automatiskt utan att du behöver göra något, du lägger ner den i poolen och hämtar den när den är klar. En manuell pooldammsugare kopplas till poolens filterpump och kräver att du manuellt styr munstycket längs botten och väggarna. En robot är betydligt enklare och mer tidseffektiv.',
  },
  {
    question: 'Vilken poolrobot passar en rund pool?',
    answer: 'De flesta poolrobotar passar både rektangulära och runda pooler, robotarna navigerar efter poolens form automatiskt. Det viktigaste är att kontrollera att kabeln är lång nog i förhållande till poolens diameter, och att poolens yta (m²) ryms inom robotens kapacitet. Välj en modell med minst 20 % marginal över din faktiska poolstorlek.',
  },
  {
    question: 'Hur ofta ska man köra en poolrobot?',
    answer: 'Under badsäsongen räcker det oftast att köra poolroboten två till tre gånger i veckan. Används poolen dagligen eller står den under träd som fäller löv och pollen kör du den hellre varje dag. När säsongen är över och poolen står stilla behövs roboten mer sällan, men en körning innan vintertäckning hjälper till att hålla botten ren.',
  },
  {
    question: 'Kan man bada med poolroboten i vattnet?',
    answer: 'Nej, du ska inte bada samtidigt som poolroboten arbetar. Roboten drivs av el och kabeln samt rörliga delar utgör en onödig risk när någon är i vattnet. Kör roboten när poolen är tom, ta upp den när cykeln är klar och bada först därefter. De flesta tillverkare anger detta tydligt i sina säkerhetsanvisningar.',
  },
  {
    question: 'Hur fungerar en poolrobot?',
    answer: 'En poolrobot är en självgående enhet som sjunker till poolbotten och rör sig systematiskt över golv, väggar och ibland vattenlinjen. En inbyggd pump suger in vatten och smuts genom ett filter samtidigt som borstar lossar alger och beläggningar. Smutsen fångas i robotens egen filterkorg, helt skilt från poolens ordinarie filterpump.',
  },
];

const breadcrumbs = [
  { label: 'Poolrobot' },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": item.answer,
  },
}));

export const articleMeta = {
  title: "Bästa poolrobot 2026: bäst i test och jämförelse",
  description: "Bästa poolrobot 2026 rankad efter reningstäckning, filtreringsförmåga och pris. Zodiac GT3220 vinner. 8 modeller jämförda, klara köpråd per poolstorlek.",
  publishDate: "2026-03-29",
  category: "Topplista",
  image: "https://csdam.net/data/jpg/0/dc98b5ed/dc98b5ed-5b66-4dc3-85d2-044eee59877f.jpg",
};
---

<BaseLayout
  title="Bästa poolrobot 2026: bäst i test och jämförelse"
  description="Bästa poolrobot 2026 rankad efter reningstäckning, filtreringsförmåga och pris. Zodiac GT3220 vinner. 8 modeller jämförda, klara köpråd per poolstorlek."
  article={{ datePublished: "2026-03-29", dateModified: "2026-06-22", image: "https://csdam.net/data/jpg/0/dc98b5ed/dc98b5ed-5b66-4dc3-85d2-044eee59877f.jpg" }}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6" data-toc-scope>
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text mb-3 leading-tight">
      Poolrobot bäst i test 2026
    </h1>
    <AuthorByline datePublished="2026-03-29" dateModified="2026-06-22" />

    <AnswerBox
      question="Snabbt svar: Vilken poolrobot är bäst 2026?"
      answer="Zodiac Electric Pool Cleaner GT3220 är bästa poolrobot 2026. Den rengör både botten och väggar med en pålitlig motor och har ett filter som är enkelt att tömma, och Zodiac-kvaliteten gör att den håller länge."
    />

    <MoneyFeatured {...products[0]} />

    <MoneyComparisonTable products={products} title="Jämförelsetabell - bästa poolrobot 2026" />

    <p class="text-text-light mb-4 max-w-2xl">
      Zodiac Electric Pool Cleaner GT3220 är vår bästa poolrobot i test 2026. Den rengör både botten och väggar med en pålitlig motor och har ett enkelt filter att tömma. Zodiac-kvaliteten gör att den håller länge.
    </p>

    <MoneyTOC />
    <p class="text-sm text-text-lighter mb-6 max-w-2xl bg-bg-alt border border-border rounded-lg px-4 py-3">
      <strong class="text-text">Söker du Maytronics Dolphin?</strong> Dolphin E30, S200 och Sigma säljs via svenska poolfackhandlare och finns inte hos våra affiliatepartners. Vi har recenserat dem separat, men kan inte länka direkt till köp. Vill du ha en robot vi kan förmedla pris på: se listan nedan.
    </p>

    <!-- Topplista med produktkort -->
    <div class="space-y-10 mb-12">
      {products.map((p) => (
        <div>
          <h2 class="font-heading text-xl font-bold text-text mb-3">
            #{p.rank}. {p.name}
            {p.badge && <span class="ml-2 text-sm font-semibold text-accent bg-accent/10 px-2 py-0.5 rounded">{p.badge}</span>}
          </h2>
          <ProductCard {...p} />
          {p.reviewUrl && (
            <div class="mt-2 px-1">
              <a href={p.reviewUrl} class="text-accent underline text-sm font-medium">Läs vår fullständiga recension av {p.name}</a>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Batteri vs kabel -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">Batteridriven eller kabeldriven poolrobot?</h2>
      <p class="text-text-light mb-4 leading-relaxed text-sm">
        Valet mellan batteri och kabel handlar om var poolen står och hur stor den är. Batteridrivna modeller som Planet Pool Orca 50CL är sladdlösa och smidiga att lyfta i och ur, men har en begränsad drifttid per laddning. Kabeldrivna robotar som Zodiac GT3220 och CF 200CL kör så länge du vill utan att tappa kraft, vilket passar större pooler, men kabeln måste hanteras så den inte trasslar.
      </p>
      <div class="grid sm:grid-cols-2 gap-5 mb-2">
        <div class="bg-white rounded-xl border border-border p-5">
          <h3 class="font-semibold text-text mb-2">Batteridriven, sladdlös frihet</h3>
          <p class="text-sm text-text-light">Lättast att lyfta i och ur, ingen kabel som trasslar. Passar små och mellanstora pooler. Nackdelen är att städtiden styrs av batteriets kapacitet, så väldigt stora pooler kan kräva en extra laddning.</p>
        </div>
        <div class="bg-white rounded-xl border border-border p-5">
          <h3 class="font-semibold text-text mb-2">Kabeldriven, obegränsad drifttid</h3>
          <p class="text-sm text-text-light">Tappar aldrig kraft mitt i en körning och passar stora villapooler. Kräver att kabeln är lång nog för poolens längd plus marginal, och att du ger akt på trassel kring trappor och stegar.</p>
        </div>
      </div>
    </section>

    <!-- Köpguide-sektion -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">Hur väljer du rätt poolrobot?</h2>
      <div class="space-y-6 text-text-light text-sm leading-relaxed">
        <div>
          <h3 class="font-heading text-lg font-bold text-text mb-2">Poolstorlek och kabellängd</h3>
          <p>Kontrollera alltid att kabeln räcker till poolens längd plus lite extra, roboten ska kunna nå alla hörn utan att kabeln stramar. En 15 m kabel räcker för de flesta villapooler på 8 till 10 m, men har du en längre pool behöver du en modell med 18 m kabel eller mer.</p>
        </div>
        <div>
          <h3 class="font-heading text-lg font-bold text-text mb-2">Botten vs väggar</h3>
          <p>Billigare modeller rengör bara poolbotten. Bättre modeller klättrar väggarna och tar bort alger och smuts längs hela poolsidan. Om du har en pool med vita väggar som lätt synliggör missfärgningar är väggstädning ett viktigt kriterium.</p>
        </div>
        <div>
          <h3 class="font-heading text-lg font-bold text-text mb-2">Filtertyp</h3>
          <p>Patronfilter är enklast att rensa, plocka ut patronen, skölj av och sätt tillbaka. Påsfilter samlar mer smuts och passar pooler med mycket organiskt material (löv, insekter), men är lite mer krångliga att hantera. Välj patronfilter för enklast skötsel.</p>
        </div>
        <div>
          <h3 class="font-heading text-lg font-bold text-text mb-2">Drifttid</h3>
          <p>2 till 3 timmar räcker normalt för en omgång i en villapool. Kör roboten en gång per dag eller varannan dag beroende på hur mycket poolen används. Premium-modeller som Dolphin Sigma kan köras längre tack vare kraftigare motor och batteri.</p>
        </div>
        <div>
          <h3 class="font-heading text-lg font-bold text-text mb-2">App-kontroll</h3>
          <p>WiFi-styrning via app är onödig funktion i budget- och mellanklassmodeller, roboten gör sitt jobb lika bra utan. I premiumsegmentet ger appen möjlighet att schemalägga, se städhistorik och styra roboten manuellt, vilket kan vara praktiskt för större pooler.</p>
        </div>
      </div>
    </section>

    <!-- Interna länkar -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">Fler guider på Robotjakt</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href="/robotgrasklippare/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Bästa robotgräsklippare 2026</h3>
          <p class="text-sm text-text-light">Vi jämför robotgräsklippare, Husqvarna, Gardena, Mammotion och fler.</p>
        </a>
        <a href="/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Alla robottester</h3>
          <p class="text-sm text-text-light">Se alla våra tester och jämförelser, robotar för hem och trädgård.</p>
        </a>
        <a href="/poolrobot-for-nedgraevd-pool/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Poolrobot för nedgrävd pool</h3>
          <p class="text-sm text-text-light">Väggklättring, bottenrengöring och vattenlinje, bästa valet för din nedgrävda pool.</p>
        </a>
      </div>
    </section>

    <MethodologyBlock criteria={['Rengöringseffektivitet', 'Navigation & täckning', 'Filterkapacitet', 'Hantering & förvaring']} productCount={6} lastUpdated="2026-06-22" />

    <FAQ items={faqItems} />

    <AffiliateDisclaimer />
  </div>

  <StickyCTA
    text={products[0].ctaText}
    url={products[0].ctaUrl}
    productName={products[0].name}
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Bästa poolrobot 2026",
    "description": "Topplista över de bästa poolrobotarna 2026, rankade efter test.",
    "numberOfItems": products.length,
    "itemListElement": products.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": p.name,
      "url": "https://robotjakt.se/poolrobot/",
    })),
  })} />

</BaseLayout>
