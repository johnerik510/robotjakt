    price: 'ca 7 990 kr',
    rating: 4.5,
    badge: 'Bäst i test',
    pros: ['Rengör väggar', 'Pålitlig motor', 'Lättviktig', 'Enkel att rensa filtret'],
    cons: ['Ingen app/WiFi', 'Kort kabel till stora pooler'],
    ctaText: 'Se pris på Dolphin E30',
    ctaUrl: villanytt,
    dataProduct: 'Maytronics Dolphin E30',
    reviewUrl: '/dolphin-e30/',
  },
  {
    rank: 2,
    name: 'Planet Pool Orca 50CL',
    image: '/images/orca-50cl.webp',
    price: '5 900 kr',
    rating: 4.3,
    badge: 'Bäst budget',
    pros: ['Batteridrift — ingen kabel', 'Rengör botten och väggar', 'Lättviktig (4,5 kg)', 'Passar pooler upp till 80 m³'],
    cons: ['Ingen app', 'Batteridriven — begränsad drifttid'],
    ctaText: 'Se pris hos Villanytt',
    ctaUrl: villanytt,
    dataProduct: 'Planet Pool Orca 50CL',
  },
