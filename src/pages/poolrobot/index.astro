  },
  {
    rank: 7,
    name: 'Maytronics Dolphin Sigma',
    image: '/images/dolphin-sigma.webp',
    price: 'ca 14 990 kr',
    rating: 4.4,
    badge: 'Premium',
    pros: ['WiFi-app', 'Rengör vattenlinje', 'Intelligent navigering', 'Kraftfullt filter'],
    cons: ['Dyr', 'Tung (11 kg)'],
    ctaText: 'Se pris på Dolphin Sigma',
    ctaUrl: villanytt,
    dataProduct: 'Maytronics Dolphin Sigma',
    reviewUrl: '/dolphin-sigma/',
  },
  {
    rank: 8,
    name: 'Steinbach Poolrunner Battery Pro',
    image: '/images/steinbach-poolrunner-battery-pro.webp',
    price: 'ca 3 990 kr',
    rating: 3.5,
    pros: ['Trådlös — batteridrift', 'Lättviktig (5 kg)', 'Prisvärd'],
    cons: ['Enbart botten', '90 min batteri', 'Ej utbytbart batteri'],
    ctaText: 'Se pris på Poolrunner Battery Pro',
    ctaUrl: villanytt,
    dataProduct: 'Steinbach Poolrunner Battery Pro',
    reviewUrl: '/steinbach-poolrunner-battery-pro/',
  },
