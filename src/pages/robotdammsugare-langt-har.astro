---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import FAQ from '../components/FAQ.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const products = [
  {
    rank: 1,
    name: 'Dreame X40 Ultra',
    image: '/images/dreame-x40-ultra.webp',
    price: '9 990 kr',
    rating: 4.8,
    badge: 'Bäst för långt hår',
    pros: ['12 000 Pa suger upp allt hår', 'Gummirullar trasslar inte', 'Automatisk mopptvättning med varmvatten', 'Fullautomatisk station'],
    cons: ['Högt pris', 'Stor station'],
    ctaText: 'Se pris hos Komplett',
    ctaUrl: 'https://www.komplett.se/product/1307950',
    amazonUrl: 'https://www.amazon.se/dp/B0CXDXKSXP?tag=johnerik510-20',
    reviewUrl: '/dreame-x40-ultra/',
  },
  {
    rank: 2,
    name: 'Roborock S8 MaxV Ultra',
    image: '/images/roborock-s8-maxv-ultra.webp',
    price: '11 990 kr',
    rating: 4.7,
    badge: 'AI-kamera undviker hinder',
    pros: ['ReactiveAI 2.0 undviker hinder och hår-trassel', 'Dubbla gummirullar för långhårigt hushåll', 'Starkaste Roborock för hår', '10 000 Pa sugkraft'],
    cons: ['Dyrt', 'Moppmodulen når inte hörnen som X40 Ultra'],
    ctaText: 'Se pris hos Elgiganten',
    ctaUrl: 'https://www.elgiganten.se/search/roborock+s8+maxv+ultra',
    reviewUrl: '/roborock-s8-maxv-ultra/',
  },
  {
    rank: 3,
    name: 'Ecovacs Deebot X5 Omni',
    image: '/images/ecovacs-deebot-x5-omni.webp',
    price: '8 990 kr',
    rating: 4.5,
    badge: 'Stark sugkraft',
    pros: ['8 000 Pa + TrueDetect', 'Roterande moppmoduler', 'Fullautomatisk station', 'Bra pris i premiumklass'],
    cons: ['AI-hinderdetektion inte lika mogen som Roborocks', 'Appen upplevs komplex'],
    ctaText: 'Se pris hos Elgiganten',
    ctaUrl: 'https://www.elgiganten.se/search/ecovacs+x5+omni',
    reviewUrl: '/ecovacs-deebot-x5-omni/',
  },
  {
    rank: 4,
    name: 'iRobot Roomba j9+',
    image: '/images/irobot-roomba-j9-plus.webp',
    price: 'ca 5 990 kr',
    rating: 4.2,
    badge: 'Bäst för husdjurshår',
    pros: ['Dubbla gummi-extraktorer trasslar inte', '60-dagars Clean Base', 'AI undviker hinder', 'Pålitlig drift'],
    cons: ['Ingen moppfunktion', 'Kortare drifttid (90 min)'],
    ctaText: 'Se pris hos Elgiganten',
    ctaUrl: 'https://www.elgiganten.se/search/irobot+j9',
    reviewUrl: '/irobot-roomba-j9-plus/',
  },
];

const faqItems = [
  {
    question: 'Vilken robotdammsugare är bäst för långt hår?',
    answer: 'Dreame X40 Ultra är bäst totalt — 12 000 Pa och gummirullar som inte trasslar av långt hår. iRobot Roomba j9+ är bäst specifikt för husdjurshår med sina gummi-extraktorer och 60-dagars Clean Base, men saknar moppfunktion.',
  },
  {
    question: 'Varför fastnar hår i robotdammsugare?',
    answer: 'Traditionella borstar med brister och hår-trassel. Hår lindar sig runt borstaxeln och skapar klump som blockerar sugeffekten och sliter på motorns. Moderna gummirullar (Dreame, Roborock, iRobot) är designade för att sluta suga upp hår utan att det fastnar — de förs av i stationen istället.',
  },
  {
    question: 'Hur ofta behöver man rengöra gummirullarna?',
    answer: 'Med gummirullar räcker det normalt med rengöring var 1–2 veckor istället för varje dag med traditionella borstar. Dreame X40 Ultras och Roborock S8 MaxV Ultras stationer hanterar också en del hår-rensning automatiskt.',
  },
  {
    question: 'Passar robotdammsugare med gummirullar för alla golvtyper?',
    answer: 'Ja, gummirullar fungerar utmärkt på hårda golv (laminat, klinker, parkett) och på mattor med kort till medellång lugg. På mycket tjocka, långluggsmattor kan gummirullar prestera något sämre än borsttyps-valsar — men detta är sällan ett problem i svenska hem.',
  },
  {
    question: 'Kan en robotdammsugare hantera hår från husdjur och människor samtidigt?',
    answer: 'Ja. Alla modeller på listan hanterar blandning av husdjurspäls och mänskligt hår utan problem. Dreame X40 Ultra och Roborock S8 MaxV Ultra är de starkaste valen för hushåll med mycket hår av båda sorter.',
  },
];

const breadcrumbs = [
  { label: 'Robotdammsugare för långt hår', href: '/robotdammsugare-langt-har/' },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": { "@type": "Answer", "text": item.answer },
}));
---

<BaseLayout
  title="Robotdammsugare för Långt Hår 2026 – Test och Guide"
  description="Robotdammsugare för långt hår 2026: vi har testat vilka modeller som klarar långt hår och husdjurspäls utan att trassla. Topp 4 med gummirullar."
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={breadcrumbs} />
    <AffiliateDisclaimer />

    <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text mb-3 leading-tight">
      Bästa Robotdammsugare för Långt Hår 2026
    </h1>
    <p class="text-text-light text-lg mb-6 leading-relaxed">
      Gummirullar som inte trasslar — 4 modeller testade för långt hår och husdjurspäls.
    </p>

    <!-- Snabbjämförelse -->
    <div class="bg-bg-alt rounded-xl border border-border p-5 mb-8">
      <h2 class="font-heading text-lg font-bold text-text mb-4">Snabbval</h2>
      <div class="grid sm:grid-cols-2 gap-4 text-sm">
        <div class="flex items-start gap-2">
          <span class="text-winner font-bold mt-0.5">1.</span>
          <div><a href="/dreame-x40-ultra/" class="font-semibold text-accent hover:underline">Dreame X40 Ultra</a> — bäst totalt, 12 000 Pa + gummirullar</div>
        </div>
        <div class="flex items-start gap-2">
          <span class="font-bold text-text-lighter mt-0.5">2.</span>
          <div><a href="/roborock-s8-maxv-ultra/" class="font-semibold text-accent hover:underline">Roborock S8 MaxV Ultra</a> — AI undviker hinder, dubbla gummirullar</div>
        </div>
        <div class="flex items-start gap-2">
          <span class="font-bold text-text-lighter mt-0.5">3.</span>
          <div><a href="/ecovacs-deebot-x5-omni/" class="font-semibold text-accent hover:underline">Ecovacs X5 Omni</a> — stark sugkraft, prisvärd premium</div>
        </div>
        <div class="flex items-start gap-2">
          <span class="font-bold text-text-lighter mt-0.5">4.</span>
          <div><a href="/irobot-roomba-j9-plus/" class="font-semibold text-accent hover:underline">iRobot Roomba j9+</a> — bäst för husdjurshår, 60-dagars station</div>
        </div>
      </div>
    </div>

    <div class="space-y-6 mb-10">
      {products.map(product => (
        <ProductCard {...product} />
      ))}
    </div>

    <section class="mb-10">
      <h2 class="font-heading text-2xl font-bold text-text mb-5">Varför trasslar hår i robotdammsugare?</h2>
      <p class="text-text-light leading-relaxed mb-4">
        Traditionella borstvalsar har ett mönster av plastborstar som fångar upp damm och skräp effektivt — men som också fångar hår. Långt hår lindar sig runt axeln, bygger upp klumpar och blockerar sugeffekten. I värsta fall sliter det på motorn.
      </p>
      <p class="text-text-light leading-relaxed mb-6">
        Lösningen är gummirullar (även kallade gummi-extraktorer). De har ett strukturerat gummimönster som lyfter hår och skräp utan att linda det runt sig. Hår följer med till dammkorgen istället för att fastna. Dreame, Roborock och iRobot använder alla gummirullar i sina premiummodeller.
      </p>

      <h3 class="font-heading text-xl font-semibold text-text mb-3">Vad ska man titta på?</h3>
      <ul class="space-y-3 text-text-light text-sm mb-6">
        <li class="flex items-start gap-2"><span class="text-winner font-bold mt-0.5">+</span> <strong>Gummirullar</strong> — inte borstvalsar. Avgörande för långt hår.</li>
        <li class="flex items-start gap-2"><span class="text-winner font-bold mt-0.5">+</span> <strong>Hög sugkraft</strong> — 8 000 Pa+ för att lyfta hår från mattor med lugg.</li>
        <li class="flex items-start gap-2"><span class="text-winner font-bold mt-0.5">+</span> <strong>Automatisk tömning</strong> — ju mer hår, desto snabbare fylls dammkorgen. Station sparar jobb.</li>
        <li class="flex items-start gap-2"><span class="text-winner font-bold mt-0.5">+</span> <strong>AI-hinderdetektion</strong> — undviker att köra in i sladdar och hårbollar på golvet.</li>
      </ul>
    </section>

    <FAQ items={faqItems} />

    <section class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
      <h2 class="font-heading text-lg font-bold text-text mb-3">Relaterade guider</h2>
      <ul class="space-y-2">
        <li><a href="/robotdammsugare-husdjur/" class="text-accent hover:underline text-sm">Bästa robotdammsugare för husdjur 2026</a></li>
        <li><a href="/" class="text-accent hover:underline text-sm">Bästa robotdammsugare 2026 — alla kategorier</a></li>
        <li><a href="/robotdammsugare-med-mopp/" class="text-accent hover:underline text-sm">Bästa robotdammsugare med mopp 2026</a></li>
      </ul>
    </section>
  </div>

  <StickyCTA
    text="Dreame X40 Ultra — bäst för långt hår"
    url="https://www.komplett.se/product/1307950"
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Bästa robotdammsugare för långt hår 2026",
    "description": "Topp 4 robotdammsugare med gummirullar som klarar långt hår och husdjurspäls.",
    "numberOfItems": products.length,
    "itemListElement": products.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": p.name,
      "url": `https://robotjakt.se${p.reviewUrl}`,
    })),
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqSchema,
  })} />
</BaseLayout>
