    dataProduct: 'Segway Navimow i210E',
    desc: 'Segway Navimow i210E är det prisvärdare alternativet i Navimow-serien för ytor upp till 1 000 m². LiDAR och RTK-GPS utan perimeterkabel ger exakta klippgränser. Tyst och energisnål för daglig klippning.',
  },
  {
    rank: 7,
    name: 'Roborock RockNeo Q110',
    image: 'https://www.komplett.se/img/p/400/1339517.jpg?imformat=generic',
    rating: 4.2,
    badge: 'Utan slinga',
