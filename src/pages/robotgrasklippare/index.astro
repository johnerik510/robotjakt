    dataProduct: 'Husqvarna Automower 315X',
    reviewUrl: '/husqvarna-automower-315x/',
  },
  {
    rank: 3,
    name: 'Mammotion LUBA AWO 3000',
    image: '/images/mammotion-luba-awo-3000.jpg',
    price: 'ca 24 990 kr',
    rating: 4.5,
    badge: 'UTAN SLINGA',
    pros: ['Ingen perimeterkabel — RTK GPS', '4G och kamerasystem', 'Kan klippa komplexa former via app', '26 cm klippbredd'],
    cons: ['RTK-antenn krävs', 'Nyare teknik med färre oberoende tester'],
    ctaText: 'Se pris på LUBA AWO 3000',
    ctaUrl: 'https://www.maskinklippet.se/tradgard/robotgrasklippare-och-tillbehor/robotgrasklippare/mammotion-luba-2-awd-3000x-robotgrasklippare'
    amazonUrl: 'https://www.amazon.se/s?k=mammotion+luba+awo+3000&tag=johnerik510-20',,
    dataProduct: 'Mammotion LUBA AWO 3000',
    reviewUrl: '/mammotion-luba-awo-3000/',
  },
  {
    rank: 4,
    name: 'Gardena Sileno City 500',
    image: '/images/gardena-sileno-city-500.jpg',
