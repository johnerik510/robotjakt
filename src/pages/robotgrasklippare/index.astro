  },
  {
    rank: 6,
    name: 'Segway Navimow i210E',
    image: 'https://csdam.net/data/jpg/0/7bfd3cd1/7bfd3cd1-6e99-4f3d-9fe0-557ed0eaf0e4.jpg',
