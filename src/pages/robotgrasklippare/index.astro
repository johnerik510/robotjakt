  },
  {
    rank: 2,
    name: 'Husqvarna Automower 315X',
    image: '/images/husqvarna-315x.jpg',
    price: 'ca 19 990 kr',
    rating: 4.5,
    badge: 'Bäst för medelstora trädgårdar',
    pros: ['Pålitlig GPS-assisterad navigering', 'Bra app och 3G-uppkoppling', 'Passar de flesta villaträdgårdar upp till 1600 m²'],
    cons: ['Behöver perimeterkabel', 'Ingen 4G'],
