  {
    rank: 5,
    name: 'Worx Landroid M500',
    image: '/images/worx-landroid-m500.jpg',
    price: 'ca 9 990 kr',
    rating: 4.0,
    pros: ['Bra pris/prestanda-förhållande', 'WiFi-ansluten med AIA-navigering', 'Expansionsbar med moduler'],
    cons: ['Navigering sämre än Husqvarna', 'Slinga krävs'],
    ctaText: 'Se pris på Worx Landroid M500',
    ctaUrl: 'https://www.pricerunner.se/pl/1595-4860328/Robotgraesklippare/Worx-Landroid-M500-WR141E-priser'
    amazonUrl: 'https://www.amazon.se/s?k=worx+landroid+m500&tag=johnerik510-20',,
    dataProduct: 'Worx Landroid M500',
    reviewUrl: '/worx-landroid-m500/',
  },
