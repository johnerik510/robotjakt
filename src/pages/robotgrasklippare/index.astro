    cons: ['Liten yta, max 500 m²', 'Basic app', 'Slinga krävs'],
    ctaText: 'Se pris på Gardena Sileno City 500',
    ctaUrl: 'https://www.clasohlson.com/se/Robotgrasklippare-Gardena-City-500/p/31-9803'
    amazonUrl: 'https://www.amazon.se/s?k=gardena+sileno+city+500&tag=johnerik510-20',,
    dataProduct: 'Gardena Sileno City 500',
    reviewUrl: '/gardena-sileno-city-500/',
