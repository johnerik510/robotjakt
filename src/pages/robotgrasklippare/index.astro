    cons: ['Hög prisklass', 'Kräver installationskabel (perimeterkabel)'],
    ctaText: 'Se pris på Husqvarna 430X',
    ctaUrl: 'https://www.bygghemma.se/tradgard-och-utemiljo/tradgardsmaskiner/robotgrasklippare/robotgrasklippare-husqvarna-automower-430x-nera/p-1838454'
    amazonUrl: 'https://www.amazon.se/s?k=husqvarna+automower+430x+nera&tag=johnerik510-20',,
    dataProduct: 'Husqvarna Automower 430X Nera',
