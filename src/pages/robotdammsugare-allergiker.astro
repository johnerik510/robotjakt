      { "@type": "ListItem", "position": 1, "name": "Robotdammsugare", "item": "https://robotjakt.se/" },
      { "@type": "ListItem", "position": 2, "name": "För allergiker", "item": "https://robotjakt.se/robotdammsugare-allergiker/" },
    ],
