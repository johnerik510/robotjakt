---
import BaseLayout from '../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import FAQ from '../components/FAQ.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbs = [
  { label: 'Robotdammsugare', href: '/' },
  { label: 'Roborock guide' },
];

const models = [
  {
    name: 'Roborock S8 MaxV Ultra',
    badge: 'BÄST I TEST 2026',
    badgeColor: 'bg-winner',
    price: 'ca 10 990 kr',
    rating: '4.9 / 5',
    features: ['ReactiveAI 3.0 — djuravföringsdetektering', '10 000 Pa sugkraft', 'Roterande + lyftbar mopp', 'Fullautomatisk station med varmvattentvätt', 'Videoövervakning med kamera'],
    cta: 'https://www.komplett.se/search?search=roborock+s8+maxv+ultra',
    amazon: 'https://www.amazon.se/dp/B0CRV7F37B?tag=johnerik510-20',
    ctaText: 'Se pris på S8 MaxV Ultra',
    reviewUrl: '/roborock-s8-maxv-ultra/',
    description: 'Roborock S8 MaxV Ultra är toppmodellen med branschledande AI-djuravföringsdetektering, 10 000 Pa sugkraft och fullautomatisk station. Bäst för husdjurshem och den som vill ha absolut bästa städresultat.',
  },
  {
    name: 'Roborock Qrevo Master',
    badge: 'PREMIUM — MOPPNING',
    badgeColor: 'bg-accent',
    price: 'ca 9 490 kr',
    rating: '4.7 / 5',
    features: ['8 000 Pa sugkraft', 'Dubbla roterande moppar', 'Varmvattentvätt i station', 'FlexiArm-sidboste — når hörnen', 'AI-mattdetektion + mopp-lyft'],
    cta: 'https://www.komplett.se/search?search=roborock+qrevo+master',
    amazon: 'https://www.amazon.se/dp/B0D2D5VTZF?tag=johnerik510-20',
    ctaText: 'Se pris på Qrevo Master',
    reviewUrl: '/roborock-qrevo-master/',
    description: 'Qrevo Master är Roborocks flaggskepp för moppning. Den unika FlexiArm-sidbosten når hörnen och dubbla roterande moppar ger ett grundligt moppresultat. Bäst för hem med mycket hårdgolv som prioriterar moppkvalitet.',
  },
  {
    name: 'Roborock S8 Max Ultra',
    badge: 'BÄST VÄRDE ROBOROCK',
    badgeColor: 'bg-text-light',
    price: 'ca 8 490 kr',
    rating: '4.4 / 5',
    features: ['10 000 Pa sugkraft', 'VibraRise 3.0 — lyfter moppar på mattor', 'Komplett station utan kamera', 'LiDAR PreciSense-navigering', 'Lägre pris än S8 MaxV Ultra'],
    cta: 'https://www.elgiganten.se/search?q=roborock+s8+max+ultra',
    
    ctaText: 'Se pris på S8 Max Ultra',
    reviewUrl: '/roborock-s8-max-ultra/',
    description: 'Roborock S8 Max Ultra är ett utmärkt alternativ för den som vill ha Roborocks premiumstädning utan att betala för AI-kameran i S8 MaxV Ultra. 10 000 Pa, fullautomatisk station och pålitlig LiDAR-navigering till ca 8 490 kr.',
  },
];

const faqItems = [
  {
    question: 'Är Roborock ett pålitligt märke?',
    answer: 'Ja, Roborock är ett av de mest välrenommerade märkena i premiumsegmentet för robotdammsugare. Grundat i Kina 2014 och börsnoterat sedan 2023. Roborock tillverkar egna produkter — till skillnad från många konkurrenter som använder OEM-tillverkning. De erbjuder 2 ars garanti och har ett etablerat servicenätverk i Sverige via auktoriserade återförsäljare (Komplett, Elgiganten, MediaMarkt).',
  },
  {
    question: 'Vad är skillnaden mellan Roborock S- och Q-serien?',
    answer: 'S-serien (S7, S8, S8 MaxV) är Roborocks standardlinje med fokus på balans mellan sugkraft, moppning och pris. Q-serien (Qrevo, Qrevo Master) är premium-moppningslinjen med dubbla roterande moppar och FlexiArm-sidboste. Välj S-serien om du vill ha bra all-round prestanda — välj Q-serien om moppkvaliteten är prioritet.',
  },
  {
    question: 'Fungerar Roborock-appen på svenska?',
    answer: 'Roborock Home-appen har inte ett fullständigt svenskt gränssnitt — det är primärt engelska och kinesiska. Grundläggande funktioner (start, stopp, schemaläggning, rumsplanering) är dock enkla att använda även utan svenska menyer. Kopplingen till Google Assistant och Alexa fungerar med svenska röstkommandon.',
  },
  {
    question: 'Vilket Roborock-modell passar bäst för husdjur?',
    answer: 'Roborock S8 MaxV Ultra är det bästa valet för husdjurshem tack vare ReactiveAI 3.0 som identifierar och undviker djuravföringar på golvet. Det är en kritisk funktion för husdjurshem som vill köra roboten utan konstant uppsyn. S8 MaxV Ultra har dessutom 10 000 Pa sugkraft som effektivt suger upp husdjurspals och dander.',
  },
  {
    question: 'Måste jag köpa den dyraste stationen?',
    answer: 'Nej. Om du tömmer dammkorgen manuellt en gång i veckan kan du köpa en Roborock utan automatisk station till ett lägre pris. Automatiska stationer med auto-tömning, vattenpåfyllning och mopptvätt kostar mer men ger nästan helt handsfree städning. För Qrevo Master och S8 MaxV Ultra ingår fullautomatisk station i standardpaketet.',
  },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": item.answer,
  },
}));
---

<BaseLayout
  title="Roborock robotdammsugare April 2026 – guide och jämförelse"
  description="Komplett guide till Roborocks modellserie 2026. S8 MaxV Ultra, Qrevo Master — vi hjälper dig välja rätt Roborock."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={breadcrumbs} />
    <AffiliateDisclaimer />

    <p class="text-xs text-text-lighter mb-4">Senast uppdaterad: <time datetime="2026-03-29">2026-03-29</time></p>

    <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text mb-4 leading-tight">
      Roborock robotdammsugare 2026 — alla modeller jämförda
    </h1>
    <p class="text-text-light mb-6 max-w-2xl">
      Roborock är ett av marknadens starkaste premium-märken för robotdammsugare. Vi guidar dig genom 2026 ars modellserie — S8 MaxV Ultra, Qrevo Master och S7 — och hjälper dig välja rätt modell för ditt hem.
    </p>

    <!-- Brand overview -->
    <section class="mb-8 bg-bg-alt rounded-xl border border-border p-6">
      <h2 class="font-heading text-xl font-bold text-text mb-3">Roborock — premiumkvalitet från Kina</h2>
      <p class="text-text-light leading-relaxed mb-3">
        Roborock grundades 2014 i Beijing och revolutionerade marknaden för robotdammsugare genom att kombinera premiumkvalitet med konkurrenskraftiga priser. Märket tillverkar alla sina produkter i egna fabriker och har patent på nyckelteknologier som LiDAR-navigering och ReactiveAI för hinder- och djuravföringsdetektering.
      </p>
      <p class="text-text-light leading-relaxed">
        I Sverige säljs Roborock via Komplett, Elgiganten, MediaMarkt och NetOnNet. Alla modeller i denna guide säljs med 2 ars garanti via auktoriserade svenska återförsäljare. Roborock Home-appen stödjer iOS och Android och erbjuder detaljerade kartfunktioner, rumsplanering och städscheman.
      </p>
    </section>

    <!-- Comparison table -->
    <section class="mb-10" aria-label="Jämforelsetabell Roborock-modeller">
      <h2 class="font-heading text-xl font-bold text-text mb-4">Snabbjämförelse — Roborock-modeller 2026</h2>
      <div class="overflow-x-auto rounded-xl border border-border">
        <table class="w-full text-sm bg-white">
          <thead>
            <tr class="border-b border-border bg-bg-alt">
              <th class="text-left px-4 py-3 font-semibold text-text">Modell</th>
              <th class="text-left px-4 py-3 font-semibold text-text">Sugkraft</th>
              <th class="text-left px-4 py-3 font-semibold text-text">Mopp</th>
              <th class="text-left px-4 py-3 font-semibold text-text">Station</th>
              <th class="text-left px-4 py-3 font-semibold text-text">Pris ca</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr class="bg-winner/5">
              <td class="px-4 py-3 font-medium text-text">S8 MaxV Ultra</td>
              <td class="px-4 py-3 text-winner font-semibold">10 000 Pa</td>
              <td class="px-4 py-3 text-text-light">Roterande + lyftbar</td>
              <td class="px-4 py-3 text-text-light">Fullautomatisk</td>
              <td class="px-4 py-3 font-semibold text-text">10 990 kr</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-text">Qrevo Master</td>
              <td class="px-4 py-3 text-text-light">8 000 Pa</td>
              <td class="px-4 py-3 text-text-light">Dubbel roterande</td>
              <td class="px-4 py-3 text-text-light">Fullautomatisk</td>
              <td class="px-4 py-3 font-semibold text-text">9 490 kr</td>
            </tr>
            <tr class="bg-bg-alt/50">
              <td class="px-4 py-3 font-medium text-text">S7</td>
              <td class="px-4 py-3 text-text-light">2 500 Pa</td>
              <td class="px-4 py-3 text-text-light">Sonic vibration</td>
              <td class="px-4 py-3 text-text-light">Manuell tömning</td>
              <td class="px-4 py-3 font-semibold text-text">4 490 kr</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Models -->
    <div class="space-y-8 mb-12" id="modeller">
      {models.map((model) => (
        <section class="bg-white rounded-xl border border-border overflow-hidden">
          <div class="bg-bg-alt px-5 py-3 border-b border-border flex items-center gap-3 flex-wrap">
            <span class={`${model.badgeColor} text-white text-xs font-bold px-2 py-1 rounded`}>{model.badge}</span>
            <span class="font-heading font-bold text-text">{model.name}</span>
            <span class="ml-auto font-bold text-text">{model.price}</span>
          </div>
          <div class="p-5">
            <p class="text-text-light text-sm leading-relaxed mb-4">{model.description}</p>
            <div class="grid sm:grid-cols-2 gap-4 mb-4">
              <div>
                <p class="text-xs font-semibold text-text mb-2">Nyckelfunktioner</p>
                <ul class="space-y-1">
                  {model.features.map(f => (
                    <li class="flex items-start gap-1.5 text-xs text-text-light">
                      <span class="text-winner font-bold mt-0.5">+</span>{f}
                    </li>
                  ))}
                </ul>
              </div>
              <div>
                <p class="text-xs font-semibold text-text mb-2">Betyg</p>
                <p class="text-lg font-bold text-text">{model.rating}</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-3">
              <a
                href={model.reviewUrl}
                class="inline-flex items-center text-accent hover:underline font-medium text-sm"
              >
                Läs recension
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>
              <a
                href={model.cta}
                rel="sponsored nofollow noopener noreferrer"
                target="_blank"
                class="inline-flex items-center justify-center bg-cta hover:bg-cta-dark text-white font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm min-h-[44px]"
              >
                {model.ctaText}
                <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
              </a>
              <a
                href={model.amazon}
                rel="sponsored nofollow noopener noreferrer"
                target="_blank"
                class="inline-flex items-center justify-center border-2 border-cta text-cta hover:bg-cta hover:text-white font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm min-h-[44px]"
              >
                Amazon
                <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
              </a>
            </div>
          </div>
        </section>
      ))}
    </div>

    <!-- Buying guide by need -->
    <section class="mb-10">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">Vilken Roborock passar ditt behov?</h2>
      <div class="space-y-4">
        <div class="bg-white rounded-xl border border-border p-5">
          <h3 class="font-semibold text-text mb-2">Husdjur — katthår och päls</h3>
          <p class="text-text-light text-sm leading-relaxed">
            S8 MaxV Ultra med ReactiveAI 3.0 är det enda valet. AI-kameran identifierar och undviker djuravföringar och 10 000 Pa suger upp pälsen effektivt. För husdjurshem är detta inte ett val utan ett krav.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-border p-5">
          <h3 class="font-semibold text-text mb-2">Mycket hårdgolv — bästa moppresultatet</h3>
          <p class="text-text-light leading-relaxed text-sm">
            Qrevo Master med dubbla roterande moppar och FlexiArm-sidbosten är designad för detta. För hem med klinker, laminat eller parkett through hela planet är Qrevo Masters moppresultat i en klass för sig.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-border p-5">
          <h3 class="font-semibold text-text mb-2">Budget — pröva Roborock utan toppris</h3>
          <p class="text-text-light leading-relaxed text-sm">
            Roborock S7 till ca 4 490 kr ger dig LiDAR-navigering, sonic moppfunktion och automatisk mattdetektering till halva priset av topmodellerna. Du tömmer dammkorgen manuellt men får en väl fungerande robotdammsugare från ett pålitligt märke.
          </p>
        </div>
      </div>
    </section>

    <FAQ items={faqItems} />

    <!-- Related links -->
    <section class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
      <h2 class="font-heading text-lg font-bold text-text mb-3">Relaterade guider</h2>
      <ul class="space-y-2">
        <li><a href="/roborock-s8-maxv-ultra/" class="text-accent hover:underline text-sm">Roborock S8 MaxV Ultra recension 2026 — toppmodellen testad</a></li>
        <li><a href="/roborock-s8-max-ultra/" class="text-accent hover:underline text-sm">Roborock S8 Max Ultra recension 2026 — bäst värde</a></li>
        <li><a href="/roborock-qrevo-master/" class="text-accent hover:underline text-sm">Roborock Qrevo Master recension 2026</a></li>
        <li><a href="/roborock-q-revo/" class="text-accent hover:underline text-sm">Roborock Q Revo recension 2026 — bästa prisklass</a></li>
        <li><a href="/jamfor/roborock-qrevo-master-vs-roborock-s8-maxv-ultra/" class="text-accent hover:underline text-sm">Roborock Qrevo Master vs S8 MaxV Ultra — är AI värt 3 500 kr extra?</a></li>
        <li><a href="/dreame-x40-ultra-vs-roborock-s8-maxv-ultra/" class="text-accent hover:underline text-sm">Dreame X40 Ultra vs Roborock S8 MaxV Ultra — vilket är bäst?</a></li>
        <li><a href="/roborock-vs-ecovacs/" class="text-accent hover:underline text-sm">Roborock vs Ecovacs 2026 — vilket märke vinner?</a></li>
        <li><a href="/" class="text-accent hover:underline text-sm">Bästa robotdammsugare 2026 — alla märken jämförda</a></li>
        <li><a href="/reservdelar/roborock/" class="text-accent hover:underline text-sm">Roborock reservdelar — filter, borstar och moppkuddar</a></li>
        <li><a href="/reservdelar/filter/" class="text-accent hover:underline text-sm">Ersättningsfilter till robotdammsugare</a></li>
      </ul>
    </section>
  </div>

  <StickyCTA
    text="Se bästa Roborock 2026"
    url="#modeller"
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Roborock robotdammsugare 2026",
    "description": "Roborock-modeller rankade och recenserade 2026.",
    "numberOfItems": 3,
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Roborock S8 MaxV Ultra", "url": "https://robotjakt.se/roborock-s8-maxv-ultra/" },
      { "@type": "ListItem", "position": 2, "name": "Roborock Qrevo Master", "url": "https://robotjakt.se/roborock-qrevo-master/" },
      { "@type": "ListItem", "position": 3, "name": "Roborock S7", "url": "https://robotjakt.se/roborock-s7/" },
    ],
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqSchema,
  })} />
</BaseLayout>
