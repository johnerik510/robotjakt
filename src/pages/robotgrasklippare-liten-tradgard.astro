---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import FAQ from '../components/FAQ.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AuthorByline from '../components/AuthorByline.astro';
import AnswerBox from '../components/AnswerBox.astro';
import MoneyFeatured from '../components/MoneyFeatured.astro';
import MoneyComparisonTable from '../components/MoneyComparisonTable.astro';
import MoneyTOC from '../components/MoneyTOC.astro';

const products = [
  {
    rank: 1,
    name: 'MOVA 1000',
    image: 'https://www.kjell.com/cdn-cgi/image/width=700,height=700,fit=pad,format=auto/globalassets/productimages/911020_66311.jpg?ref=ABE7C6E188',
    rating: 4.3,
    badge: 'Bäst för liten trädgård 2026',
    pros: ['Billigast med GPS-navigering', 'Ingen perimeterkabel', 'Upp till 1 000 m²', 'Enkel installation i appen'],
    cons: ['Relativt nytt märke', 'Begränsad servicehistorik'],
    ctaText: 'Bra pris hos Kjell',
    ctaUrl: 'https://ion.kjell.com/t/t?a=1487384319&as=2063681412&t=2&tk=1&cupa_sku=66311&url=https://www.kjell.com/se/produkter/hem-fritid/tradgard/robotgrasklippare-tillbehor/robotgrasklippare/mova-1000-robotic-lawn-mower-robotgrasklippare-p66311',
    dataProduct: 'MOVA 1000',
  },
  {
    rank: 2,
    name: 'Worx Landroid Vision 500 (WR305E)',
    image: 'https://www.komplett.se/img/p/400/1333222.jpg?imformat=generic',
    rating: 4.1,
    badge: 'Vision utan kabel',
    pros: ['Ingen perimeterkabel, Vision-kamera', 'WiFi-ansluten med app-kontroll', 'Upp till 500 m²'],
    cons: ['Begränsat till 500 m²', 'Ny Vision-teknik'],
    ctaText: 'Bra pris hos Komplett',
    ctaUrl: 'https://go.adt267.com/t/t?a=1615916042&as=2063681412&t=2&tk=1&cupa_sku=1333222&url=https://www.komplett.se/product/1333222/hem-fritid/tradgaard/grasklippare/robotgrasklippare/worx-wr305e-landroid-vision-cloud-500m?channable=02d4c769640031333333323232ad',
    dataProduct: 'Worx Landroid Vision 500',
  },
  {
    rank: 3,
    name: 'Gardena SILENO city 500',
    image: '/images/gardena-sileno-city-500.webp',
    rating: 4.0,
    badge: 'Pålitlig, tyst, klassisk',
    pros: ['Upp till 500 m²', 'Tyst drift 57 dB', 'Enkel installation', 'Pålitlig Gardena-kvalitet'],
    cons: ['Perimeterkabel krävs', 'Ingen GPS', 'Grundläggande app'],
    ctaText: 'Bra pris hos Proshop',
    ctaUrl: 'https://go.adt284.net/t/t?a=1870484630&as=2063681412&t=2&tk=1&cupa_sku=3051379&url=https://www.proshop.se/Robotgraesklippare/Gardena-smart-SILENO-city-robotic-lawnmower-500-m/3051379',
    dataProduct: 'Gardena SILENO city 500',
  },
  {
    rank: 4,
    name: 'Dreame A1 Pro 1000 (LiDAR)',
    image: 'https://www.komplett.se/img/p/400/1334172.jpg?imformat=generic',
    rating: 4.3,
    badge: 'GPS + LiDAR utan kabel',
    pros: ['LiDAR + RTK GPS', 'Ingen perimeterkabel', 'Enkel app-installation'],
    cons: ['Kräver fri sikt mot himlen', 'Nyare modell'],
    ctaText: 'Bra pris hos Elon',
    ctaUrl: 'https://to.elon.se/t/t?a=1606750995&as=2063681412&t=2&tk=1&cupa_sku=154749&url=https://www.elon.se/dreame-a1-pro-360-lidar-1000-m-154749',
    dataProduct: 'Dreame A1 Pro',
  },
];

const faqItems = [
  {
    question: 'Vilken robotgräsklippare passar bäst för en liten trädgård under 500 m²?',
    answer: 'MOVA 1000 och Gardena SILENO city 500 är de naturliga valen för de flesta med liten trädgård. Gardena är tyst och klarar upp till 500 m² med kabel. Vill du slippa kabeln är Dreame A1 Pro 1000 ett utmärkt alternativ med LiDAR och RTK GPS, enkel installation utan grävning.',
  },
  {
    question: 'Måste man lägga perimeterkabel för en liten trädgård?',
    answer: 'Inte längre. Dreame A1 Pro 1000 och MOVA 1000 använder GPS och kräver ingen kabel alls, du ritar gränserna i appen. Gardena SILENO city 500 och Worx Landroid Vision 500 har också GPS-alternativ, men Gardena-modellen kräver kabel. Kabeln är enkel att installera själv på en liten tomt på 1 till 2 timmar.',
  },
  {
    question: 'Hur lång tid tar installationen på en liten trädgård?',
    answer: 'Med perimeterkabel räknar du med 2 till 4 timmar för en tomt på 200 till 500 m², beroende på form och hinder. Kabeln läggs längs kanten och runt hinder, sedan testkör du roboten. Dreame A1 Pro 1000 och MOVA 1000 tar 30 till 60 minuter att installera, du monterar basstationen och ritar gränserna i appen.',
  },
  {
    question: 'Kan en robotgräsklippare hantera trädgårdar med blomsterrabatter och hinder?',
    answer: 'Ja, perimeterkabeln läggs runt rabatter och hinder, och roboten vet var den inte får köra. Worx Landroid Vision 500 hanterar komplexa former med öar och smalare passager. GPS-modeller som Dreame A1 Pro 1000 och MOVA 1000 klarar komplexa former via app-ritning utan kabel.',
  },
  {
    question: 'Vad kostar driften av en robotgräsklippare per år?',
    answer: 'Elförbrukningen är minimal, en robotgräsklippare drar ca 10 till 25 W under drift och i el per säsong. Förbrukningsmaterial som knivar byts 1 till 2 gånger per säsong och . Service var 2 till 3 år beroende på märke. Totalt räknar de flesta med per år i löpande kostnader.',
  },
  {
    question: 'Är det värt att köpa Husqvarna Automower 315X till en liten trädgård?',
    answer: 'De fyra modellerna på listan passar olika behov. MOVA 1000 är billigast med GPS. Gardena SILENO city 500 är tyst och pålitlig. Worx Landroid Vision 500 kräver ingen kabel. Dreame A1 Pro 1000 kombinerar LiDAR och RTK GPS för flexibel installation. Välj efter yta, budget och om du vill ha kabel eller GPS.',
  },
];

const breadcrumbs = [
  { label: 'Robotgräsklippare', href: '/robotgrasklippare/' },
  { label: 'Liten trädgård' },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": item.answer,
  },
}));
export const articleMeta = {
  title: "Bästa robotgräsklippare liten trädgård 2026: under 500",
  description: "Bästa robotgräsklipparna för liten trädgård under 500 m² 2026. Kompakta och tysta modeller jämförda. Se topplista, pris och vår rekommendation.",
  publishDate: "2026-05-16",
  category: "Topplista",
  image: "/images/gardena-sileno-city-500.webp",
};

---

<BaseLayout
  title="Bästa robotgräsklippare liten trädgård 2026: under 500"
  description="Bästa robotgräsklipparna för liten trädgård under 500 m² 2026. Kompakta och tysta modeller jämförda. Se topplista, pris och vår rekommendation."
  article={{ datePublished: "2026-05-16", dateModified: "2026-05-27", image: "/images/gardena-sileno-city-500.webp" }}
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6" data-toc-scope>
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text mb-4 leading-tight">
      Bästa robotgräsklippare för liten trädgård 2026, under 500 m²
    </h1>
    <AuthorByline datePublished="2026-05-16" dateModified="2026-05-27" />

    <AnswerBox
      question="Snabbt svar: Vilken robotgräsklippare är bäst för liten trädgård 2026?"
      answer="MOVA 1000 är bäst för liten trädgård 2026. Den är billigast i klassen med GPS-navigering, behöver ingen perimeterkabel och installeras direkt i appen. Den klarar ytor upp till 1 000 m²."
    />

    <MoneyFeatured {...products[0]} />

    <MoneyComparisonTable products={products} title="Jämförelsetabell - robotgräsklippare för liten trädgård 2026" />

    <p class="text-lg text-text-light mb-6 leading-relaxed">
      MOVA 1000 är vår bästa robotgräsklippare för liten trädgård 2026. Den är billigast i klassen med GPS-navigering och behöver ingen perimeterkabel, så du installerar den direkt i appen. Den klarar ytor upp till 1 000 m². </p>

    <MoneyTOC />

    <!-- Produktkort -->
    <div class="space-y-5 mb-10">
      {products.map((p, i) => (
        <div>
          <h2 class="font-heading text-2xl font-bold text-text mt-8 mb-4">{p.rank ?? i + 1}. {p.name}{p.badge ? `, ${p.badge}` : ''}</h2>
          <ProductCard {...p} />
        </div>
      ))}
    </div>

    <!-- Guide -->
    <section class="mb-10">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">Perimeterkabel eller GPS: vilket passar liten trädgård bäst?</h2>
      <div class="grid sm:grid-cols-2 gap-5 mb-6">
        <div class="bg-white rounded-xl border border-border p-5">
          <h3 class="font-semibold text-text mb-2">Perimeterkabel, beprövat och billigt</h3>
          <p class="text-sm text-text-light">Gardena SILENO city 500 kräver kabel. Kabeln installeras ovanpå gräset eller grävs ner ett par centimeter. På en liten tomt tar det 2 till 3 timmar och ger ett pålitligt och stabilt resultat.</p>
        </div>
        <div class="bg-white rounded-xl border border-border p-5">
          <h3 class="font-semibold text-text mb-2">GPS utan slinga, enklare installation</h3>
          <p class="text-sm text-text-light">MOVA 1000, Worx Landroid Vision 500 och Dreame A1 Pro 1000 kräver ingen perimeterkabel. Du ritar gränserna i appen. Tar 30 till 60 minuter och är ett bra val om du inte vill gräva. Ger mer flexibilitet om du vill ändra gränserna.</p>
        </div>
      </div>

      <h2 class="font-heading text-2xl font-bold text-text mb-4">Räcker 500 m² kapacitet om trädgården är 300 m²?</h2>
      <p class="text-text-light leading-relaxed mb-4">
        Ja, och det är rekommenderat. Välj alltid en modell med 30 till 50 % marginal över din faktiska yta. En 300 m² trädgård bör ha en robot på minst 400 m² kapacitet. Hinder, komplexa former och sluttningar minskar effektiv kapacitet, och marginal innebär att roboten inte behöver jobba på max hela tiden. </p>

      <h2 class="font-heading text-2xl font-bold text-text mb-4">Köpguide: hur väljer du bästa robotgräsklipparen för liten trädgård?</h2>
      <p class="text-text-light leading-relaxed">
        Proshop har bra utbud av Gardena-modeller. Komplett har Husqvarna och Worx. Segway Navimow hittar du hos Komplett och NetOnNet. Jämför alltid priser, det kan skilja mellan butiker på samma modell. </p>
    </section>

    <FAQ items={faqItems} />

    <AffiliateDisclaimer />

    <!-- Relaterade länkar -->
    <section class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
      <h2 class="font-heading text-lg font-bold text-text mb-3">Relaterade guider</h2>
      <ul class="space-y-2">
        <li><a href="/robotgrasklippare/" class="text-accent underline text-sm">Bästa robotgräsklippare 2026, komplett topplista</a></li>
        <li><a href="/robotgrasklippare-stor-tradgard/" class="text-accent underline text-sm">Robotgräsklippare för stor trädgård, över 1000 m²</a></li>
        <li><a href="/robotgrasklippare-utan-slinga/" class="text-accent underline text-sm">Robotgräsklippare utan slinga, GPS och RTK 2026</a></li>
        <li><a href="/billigaste-robotgrasklippare/" class="text-accent underline text-sm">Billigaste robotgräsklippare, bäst för pengarna</a></li>
        <li><a href="/kopguide-robotgrasklippare/" class="text-accent underline text-sm">Köpguide robotgräsklippare, allt du behöver veta</a></li>
      </ul>
    </section>
  </div>

  <StickyCTA
    text={products[0].ctaText}
    url={products[0].ctaUrl}
    productName={products[0].name}
  />
<script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Bästa robotgräsklippare liten trädgård 2026",
    "description": "Topplista över de bästa robotgräsklipparna för liten trädgård under 500 m², rankade efter test.",
    "numberOfItems": products.length,
    "itemListElement": products.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": p.name,
      "url": "https://robotjakt.se/robotgrasklippare-liten-tradgard/",
    })),
  })} />
</BaseLayout>
