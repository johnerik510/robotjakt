    dataProduct: 'Neatsvor X520',
  },
  {
    rank: 4,
    name: 'Roborock Q5 Pro',
    image: '/images/roborock-q5-pro.webp',
    rating: 4.6,
    badge: 'Bäst LiDAR budget',
    pros: ['5 500 Pa sugkraft', 'LiDAR-navigation', 'App-styrning med rumsuppdelning', 'Lång batteritid 180 min'],
    cons: ['Ingen moppfunktion', 'Ingen automatisk tömning'],
    ctaText: 'Se pris hos Kjell',
    ctaUrl: 'https://ion.kjell.com/t/t?a=1487384319&as=2063681412&t=2&tk=1&cupa_sku=66000&url=http://www.kjell.com/se/produkter/hem-fritid/stadning-rengoring/robotdammsugare/roborock-robotdammsugare/roborock-q5-pro-robotdammsugare-p66000',
