        <p class="text-white/70 mt-1">{winner.bestFor}.</p>
      </div>
      <a
        href={winner.ctaUrl}
        target="_blank"
        rel="nofollow sponsored noopener noreferrer"
        class="inline-flex items-center justify-center bg-cta hover:bg-cta-dark text-white font-bold py-4 px-8 rounded-xl transition-colors text-base shadow-lg whitespace-nowrap"
      >
        Bra pris hos {winner.merchant}
      </a>
