const winner = products[0];
const top5 = products.slice(0, 5);
---

<BaseLayout
  title="Bästa robotdammsugare och robotgräsklippare 2026: Robotjakt"
  description="Bästa robotdammsugare 2026: 16 modeller rankade. Dreame X50 Ultra vinner. Robotgräsklippare, poolrobotar och fönsterputsrobotar jämförda."
  article={true}
>
  <link slot="head" rel="preload" as="image" href="/images/hero-robotjakt.webp" type="image/webp" fetchpriority="high" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Bästa robotdammsugare 2026",
    "numberOfItems": allProducts.length,
    "itemListElement": allProducts.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": p.name,
      "url": p.reviewUrl ? `https://robotjakt.se${p.reviewUrl}` : `https://robotjakt.se/`,
    })),
  })} />

  <!-- Hero -->
  <section class="text-white relative overflow-hidden">
    <img
      src="/images/hero-robotjakt.webp"
      alt="Robotdammsugare i modernt hem"
      class="absolute inset-0 w-full h-full object-cover -z-10"
      loading="eager"
      fetchpriority="high"
      width="1280"
      height="720"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-primary/50 -z-10" aria-hidden="true"></div>
    <div class="max-w-6xl mx-auto px-4 py-8 md:py-12 relative">
      <div class="grid md:grid-cols-[1fr_auto] gap-6 md:gap-10 items-center">
        <!-- Vänster: text -->
        <div>
          <div class="inline-flex items-center gap-2 bg-accent/20 border border-accent-light/40 rounded-full px-3 py-1 text-xs font-semibold text-accent-light uppercase tracking-wider mb-3">
            <span class="w-1.5 h-1.5 bg-accent-light rounded-full"></span>
            Uppdaterat april 2026 · {allProducts.length} modeller jämförda
          </div>
          <h1 class="text-2xl md:text-4xl font-extrabold leading-tight mb-3">
            Bästa robotdammsugare 2026: {allProducts.length} modeller rankade
          </h1>
          <p class="text-base md:text-lg text-white/80 max-w-xl leading-relaxed">
            Vi har jämfört {allProducts.length} modeller på sugkraft, navigering och moppfunktion. Från Dreame och Roborock till budget och husdjursmodeller.
          </p>
        </div>
        <!-- Höger: vinnarkort -->
        <div class="hidden md:block bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-5 md:min-w-[320px]">
          <div class="text-xs font-bold uppercase tracking-widest text-accent-light mb-2">Vinnare 2026</div>
          <div class="font-extrabold text-xl mb-3">{winner.name}</div>
          <a
            href={winner.ctaUrl}
            target="_blank"
            rel="nofollow sponsored noopener noreferrer"
            class="flex items-center justify-center w-full bg-cta hover:bg-cta-dark text-white font-bold py-3 rounded-xl transition-colors"
          >
            Bra pris hos {winner.merchant}
          </a>
          <a href="#topplista" class="block text-center text-sm font-semibold text-white/70 hover:text-white mt-3 transition-colors">
            Se hela topp 5 ↓
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Topp 5 -->
  <section id="topplista" class="max-w-6xl mx-auto px-4 py-10">
    <h2 class="font-heading text-2xl md:text-3xl font-bold text-text mb-2">Topp 5 robotdammsugare 2026</h2>
    <p class="text-text-light mb-6">Rankade på sugkraft, navigering och moppfunktion. Klicka på modellen för fullständig recension.</p>

    <div class="space-y-4">
      {top5.map((p, i) => (
        <article class={`bg-white rounded-2xl p-5 md:p-6 flex flex-col sm:flex-row sm:items-center gap-5 transition-colors ${
          i === 0 ? 'border-2 border-cta shadow-md' : 'border border-border hover:border-accent'
        }`}>
          <div class={`flex-shrink-0 flex items-center justify-center w-12 h-12 rounded-full font-extrabold text-xl ${
            i === 0 ? 'bg-cta text-white' : 'bg-bg-alt text-accent'
          }`}>
            {i + 1}
          </div>

          <div class="flex-shrink-0 w-full sm:w-44 h-44 bg-bg-alt rounded-xl overflow-hidden flex items-center justify-center">
            <img src={p.image} alt={p.name} width="176" height="176" class="object-contain w-full h-full p-3" loading={i === 0 ? 'eager' : 'lazy'} />
          </div>

          <div class="flex-1 min-w-0">
            {p.badge && (
              <span class={`inline-block px-2.5 py-0.5 text-xs font-bold rounded-full mb-2 uppercase tracking-wide ${
                i === 0 ? 'bg-cta text-white' : 'bg-accent/10 text-accent'
              }`}>
                {p.badge}
              </span>
            )}
            <h3 class="font-heading font-bold text-lg text-text mb-1">
              {p.reviewUrl
                ? <a href={p.reviewUrl} class="hover:text-accent transition-colors">{p.name}</a>
                : p.name
              }
            </h3>
            <div class="flex items-center gap-1 mb-1.5">
              {[1,2,3,4,5].map((s) => (
                <svg class={`w-4 h-4 ${s <= Math.round(p.rating) ? 'text-star' : 'text-border-dark'}`} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
              <span class="text-sm text-text-light ml-1">{p.rating} ({p.reviewCount} recensioner)</span>
            </div>
            <p class="text-sm text-text-light mb-2">{p.bestFor}</p>
          </div>

          <div class="flex-shrink-0 flex flex-col gap-2 sm:items-end">
            <a
              href={p.ctaUrl}
              target="_blank"
              rel="nofollow sponsored noopener noreferrer"
              class="inline-flex items-center justify-center bg-cta hover:bg-cta-dark text-white font-bold py-3 px-5 rounded-xl transition-colors whitespace-nowrap"
            >
              Bra pris hos {p.merchant}
            </a>
            {p.reviewUrl && (
              <a href={p.reviewUrl} class="text-sm font-semibold text-accent hover:text-accent-dark py-2 px-1 inline-block">
                {p.name}, recension
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Senaste recensioner -->
  {senasteRecensioner.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 py-10">
      <div class="flex items-end justify-between mb-6 flex-wrap gap-3">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-text">Senaste recensioner</h2>
        <a href="/robotdammsugare/" class="text-sm font-semibold text-accent hover:text-accent-dark">Alla recensioner →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {senasteRecensioner.map((art) => (
          <article class="group bg-white border border-border rounded-xl overflow-hidden hover:shadow-md hover:border-accent transition-all">
            <a href={art.href} class="block aspect-[16/9] overflow-hidden bg-bg-alt" tabindex="-1" aria-hidden="true">
              <img src={art.image} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" width="480" height="270" />
            </a>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-bold uppercase tracking-wider text-accent">{art.category}</span>
                <span class="text-text-light">·</span>
                <time datetime={art.publishDate} class="text-xs text-text-light">{fmtDate(art.publishDate)}</time>
              </div>
              <h3 class="font-heading font-semibold text-text leading-snug mb-2">
                <a href={art.href} class="hover:text-accent transition-colors">{art.title}</a>
              </h3>
              <p class="text-sm text-text-light leading-relaxed">{art.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- CTA-banner vinnare -->
  <section class="bg-gradient-to-r from-primary to-primary-light text-white py-10">
    <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <div class="text-xs font-bold uppercase tracking-widest text-accent-light mb-1">Vår vinnare 2026</div>
