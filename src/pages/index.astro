          { name: 'Med mopp', href: '/robotdammsugare/med-mopp/' },
          { name: 'För husdjur', href: '/robotdammsugare/husdjur/' },
          { name: 'Med basstation', href: '/robotdammsugare/med-bassation/' },
          { name: 'Robotgräsklippare', href: '/robotgrasklippare/' },
