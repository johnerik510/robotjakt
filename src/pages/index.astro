const faqItems = [
  {
    question: 'Vilken robotdammsugare är bäst i test 2026?',
    answer: 'Dreame X50 Ultra är vår testvinnare april 2026. Med 20 000 Pa sugkraft, VersaLift-navigering som når under låga möbler och en självrenande PowerDock är den bäst i klassen. Dreame X40 Ultra är fortfarande ett starkt val med sin utfällbara mopparm. Roborock S8 MaxV Ultra är bäst för husdjurshem tack vare AI-kameran som undviker djuravföring.',
  },
  {
    question: 'Är det värt att köpa en robotdammsugare med moppfunktion?',
    answer: 'Ja, moderna robotdammsugare med mopp gör ett överraskande bra jobb på hårdgolv. Modeller som Dreame X40 Ultra och Roborock S8 MaxV Ultra kan torka bort intorkade fläckar. För heltäckningsmattor är moppfunktionen mindre relevant — välj en modell med automatisk mopplyftning om du har både mattor och hårdgolv.',
  },
  {
    question: 'Vilken robotdammsugare är bäst för husdjur?',
    answer: 'För djurägare rekommenderar vi modeller med stark sugkraft (minst 8 000 Pa) och gummirullar som inte trasslas av päls. Roborock S8 MaxV Ultra har en AI-kamera som identifierar och undviker djuravföring — ett unikt skydd. Dreame X40 Ultra och Roborock Qrevo Master klarar djurhår utmärkt.',
  },
  {
    question: 'Hur ofta behöver man tömma en robotdammsugare?',
    answer: 'Med en självtömmande station behöver du bara tömma påsen var 30–60 dag beroende på hemstorlek och smutsbelastning. Utan station bör du tömma behållaren efter varje städning. Nästan alla premiummodeller 2026 inkluderar självtömmande station.',
  },
  {
    question: 'Kan en robotdammsugare ersätta en vanlig dammsugare?',
    answer: 'För daglig underhållsstädning ja. En robotdammsugare håller golven rena mellan mer grundliga städningar. För djuprengöring av soffor, trappor och svåråtkomliga ställen behöver du fortfarande en vanlig eller sladdlös dammsugare.',
  },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
