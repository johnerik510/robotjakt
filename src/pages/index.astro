              <div class="text-sm text-text-light">Grundare och testledare</div>
              <div class="text-xs text-text-lighter mt-1">60+ modeller testade</div>
            </figcaption>
          </figure>
          <figure class="group relative rounded-2xl overflow-hidden ring-1 ring-border">
            <div class="aspect-[4/5] overflow-hidden">
              <img src="/images/team-anna.jpg" alt="Anna Svensson, teknikredaktör Robotjakt" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <figcaption class="p-5 bg-white">
              <div class="font-heading font-bold text-lg text-text leading-tight">Anna Svensson</div>
              <div class="text-sm text-text-light">Teknikredaktör</div>
              <div class="text-xs text-text-lighter mt-1">LiDAR och navigering</div>
            </figcaption>
          </figure>
        </div>
      </div>
    </div>
