      height="720"
    />
    <div class="absolute inset-0 bg-primary/80" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">
      <!-- Badge -->
