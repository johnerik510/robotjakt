  <link slot="head" rel="preload" as="image" href="/images/hero-robotjakt.webp" type="image/webp" fetchpriority="high" />
  <!-- Hero -->
  <section class="text-white relative overflow-hidden flex flex-col justify-center py-8 md:py-10">
    <img
      src="/images/hero-robotjakt.webp"
      alt="Robotdammsugare — Dreame och Roborock"
      class="absolute inset-0 w-full h-full object-cover -z-10"
      loading="eager"
      fetchpriority="high"
      width="1920"
      height="600"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary/85 to-primary/60 -z-10" aria-hidden="true"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative w-full">
      <p class="text-xs text-white/50 mb-2">Senast uppdaterad: 2026-04-10</p>
      <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-3 leading-tight">
        Bästa robotdammsugare 2026 — test och jämförelse
      </h1>
      <p class="text-white/80 mb-5 max-w-2xl">
        Vi har testat de populäraste robotdammsugarna på den svenska marknaden. Dreame X50 Ultra toppar listan april 2026 — här är vår rangordning med fullständiga recensioner.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="#topplista" class="inline-flex items-center justify-center bg-accent hover:bg-accent-dark text-white font-bold py-3 px-7 rounded-xl transition-colors text-base shadow-lg">
          Se topplistan
        </a>
        <a href="/dreame-guide/" class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white font-semibold py-3 px-7 rounded-xl transition-colors text-base border border-white/20">
          Märkesguider
        </a>
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

