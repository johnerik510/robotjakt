        ].map((c) => (
          <a href={c.href} class="inline-flex items-center bg-white hover:bg-accent hover:text-white text-accent font-semibold py-2.5 px-5 rounded-full border border-border hover:border-accent transition-all text-sm shadow-sm">
            {c.name}
          </a>
        ))}
      </div>
    </div>
  </section>

