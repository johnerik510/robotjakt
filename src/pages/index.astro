const allMods = import.meta.glob('./**/*.astro', { eager: true })
type ArtMeta = { title: string; description: string; publishDate: string; category: string; image: string }
const senasteRecensioner = Object.entries(allMods)
  .filter(([path, mod]) => path !== './index.astro' && !path.endsWith('/index.astro') && !!(mod as any).articleMeta)
  .map(([path, mod]) => {
    const meta = (mod as any).articleMeta as ArtMeta
    const href = '/' + path.replace(/^\.\//, '').replace(/\.astro$/, '/')
    return { ...meta, href }
  })
  .sort((a, b) => b.publishDate.localeCompare(a.publishDate))
  .slice(0, 6)

function fmtDate(d: string) {
  return new Date(d + 'T12:00:00').toLocaleDateString('sv-SE', { year: 'numeric', month: 'long', day: 'numeric' })
}

