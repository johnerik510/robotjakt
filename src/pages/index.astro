---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import FAQ from '../components/FAQ.astro';

const products = [
  {
    rank: 1,
    name: 'Dreame X40 Ultra',
    price: 'ca 9 990 kr',
    rating: 4.8,
    badge: 'Bäst i test 2026',
    pros: ['Extremt stark sugkraft (12 000 Pa)', 'Självtömmande och självtvättande', 'Utfällbar mopp for hörnen'],
    cons: ['Hög prisklass', 'Stor dockningsstation'],
    ctaText: 'Se pris hos Komplett',
    ctaUrl: 'https://www.komplett.se/search?q=Dreame+X40+Ultra',
  },
  {
    rank: 2,
    name: 'Roborock S8 MaxV Ultra',
    price: 'ca 11 990 kr',
    rating: 4.7,
    badge: 'Premium',
    pros: ['Branschledande navigering', 'Dubbla gummirullar', 'Lysande moppfunktion'],
    cons: ['Dyrast i testet', 'App kan vara överväldigande'],
    ctaText: 'Se pris hos Komplett',
    ctaUrl: 'https://www.komplett.se/search?q=Roborock+S8+MaxV+Ultra',
  },
  {
    rank: 3,
    name: 'Roborock Qrevo Master',
    price: 'ca 7 490 kr',
    rating: 4.6,
    badge: 'Bästa värde',
    pros: ['Premiumfunktioner till lägre pris', 'FlexiArm moppsystem', 'Stark sugkraft (10 000 Pa)'],
    cons: ['Något högre ljudnivå', 'Enklare kamera än S8 MaxV'],
    ctaText: 'Se pris hos Komplett',
    ctaUrl: 'https://www.komplett.se/search?q=Roborock+Qrevo+Master',
  },
  {
    rank: 4,
    name: 'Ecovacs Deebot X5 Omni',
    price: 'ca 8 990 kr',
    rating: 4.5,
    badge: 'Innovativt',
    pros: ['Fyrkantig design når hörnen', 'Kraftfull moppning', 'Bra app med AI-funktioner'],
    cons: ['Nyare pa marknaden', 'Tillbehör kan vara dyra'],
    ctaText: 'Se pris hos Komplett',
    ctaUrl: 'https://www.komplett.se/search?q=Ecovacs+Deebot+X5+Omni',
  },
  {
    rank: 5,
    name: 'Dreame L20 Ultra',
    price: 'ca 5 990 kr',
    rating: 4.4,
    pros: ['Bra prestanda for priset', 'Självtömmande station', 'Moppfunktion med varmvatten'],
    cons: ['Inte lika stark som X40', 'Enklare hinderdetektion'],
    ctaText: 'Se pris hos Komplett',
    ctaUrl: 'https://www.komplett.se/search?q=Dreame+L20+Ultra',
  },
];

const faqItems = [
  {
    question: 'Vilken robotdammsugare är bäst i test 2026?',
    answer: 'Dreame X40 Ultra är var testvinnare 2026 tack vare sin extrema sugkraft, självtömmande station och utfällbara mopp som når in i hörnen. Roborock S8 MaxV Ultra är bäst for den som vill ha allra bästa navigeringen.',
  },
  {
    question: 'Är det värt att köpa en robotdammsugare med moppfunktion?',
    answer: 'Ja, moderna robotdammsugare med mopp gör ett överraskande bra jobb pa hardgolv. Modeller som Dreame X40 Ultra och Roborock S8 MaxV Ultra kan till och med torka bort intorkade fläckar. For heltäckningsmattor är moppfunktionen mindre relevant.',
  },
  {
    question: 'Vilken robotdammsugare är bäst for husdjur?',
    answer: 'For djurägare rekommenderar vi modeller med stark sugkraft (minst 8 000 Pa) och gummirullar som inte trasslas av pälsar. Roborock S8 MaxV Ultra och Dreame X40 Ultra klarar djurhar utmärkt.',
  },
  {
    question: 'Hur ofta behöver man tömma en robotdammsugare?',
    answer: 'Med en självtömmande station behöver du bara tömma pâsen var 30–60 dag beroende pa storlek pa hemmet och mängden smuts. Utan station bör du tömma behallaren efter varje städning.',
  },
  {
    question: 'Kan en robotdammsugare ersätta en vanlig dammsugare?',
    answer: 'For daglig underhallsstädning ja. En robotdammsugare haller golven rena mellan grundligare städningar. For djuprengöring av soffor, trappor och svaraatkomliga ställen behöver du fortfarande en vanlig dammsugare eller sladdlös modell.',
  },
];
---

<BaseLayout
  title="Robotjakt &mdash; Sveriges guide for robotdammsugare, robotgräsklippare och poolrobotar 2026"
  description="Vi testar och jämför konsumentrobotar for den svenska marknaden. Bästa robotdammsugare, robotgräsklippare och poolrobotar 2026 &mdash; oberoende recensioner och uppdaterade priser."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <AffiliateDisclaimer />
    <p class="text-xs text-text-lighter mb-2">Senast uppdaterad: 2026-03-29</p>

    <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text mb-3">
      Sveriges guide for konsumentrobotar 2026
    </h1>
    <p class="text-text-light mb-6 max-w-2xl">
      Robotjakt testar och jämfor robotdammsugare, robotgräsklippare och poolrobotar for den svenska marknaden. Oberoende recensioner, raka rekommendationer och alltid uppdaterade priser.
    </p>

    <!-- Kategorisektionen -->
    <section class="mb-10">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">Utforska alla robotar</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <a href="/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Robotdammsugare</h3>
          <p class="text-sm text-text-light">Vi har testat {products.length} modeller. Dreame X40 Ultra är var testvinnare 2026.</p>
        </a>
        <a href="/robotgrasklippare/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Robotgräsklippare</h3>
          <p class="text-sm text-text-light">Fran Husqvarna Automower till slingfria GPS-modeller — hitta rätt klippare for din trädgard.</p>
        </a>
        <a href="/kontakt/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Poolrobot</h3>
          <p class="text-sm text-text-light">Guide for poolrobotar under uppbyggnad. Kontakta oss for tipseller förhandsinfo.</p>
        </a>
      </div>
    </section>

    <!-- Topplista robotdammsugare -->
    <h2 class="font-heading text-2xl font-bold text-text mb-4">Bästa robotdammsugare 2026</h2>
    <p class="text-text-light mb-5 text-sm">Vi har testat {products.length} robotdammsugare och rankat dem efter sugkraft, navigering, moppfunktion och prisvärdhet.</p>
    <div class="space-y-5 mb-12">
      {products.map((p) => (
        <ProductCard {...p} />
      ))}
    </div>

    <!-- Köpguide -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">Köpguide: Hur väljer man robotdammsugare?</h2>
      <div class="prose prose-slate max-w-none text-text-light text-sm leading-relaxed space-y-4">
        <h3 class="font-heading text-lg font-bold text-text">Sugkraft (Pa)</h3>
        <p>Sugkraften mäts i Pascal (Pa). For normala golv räcker 5 000 Pa. Har du husdjur eller mattor behöver du minst 8 000 Pa. Premiummodeller erbjuder 10 000–12 000 Pa.</p>

        <h3 class="font-heading text-lg font-bold text-text">Navigering</h3>
        <p>LiDAR-navigering är snabbast och mest exakt. Kamerabaserade system är bra pa att undvika hinder (skor, kablar). De bästa modellerna kombinerar bada teknikerna.</p>

        <h3 class="font-heading text-lg font-bold text-text">Moppfunktion</h3>
        <p>Roterande moppar gör rent bättre än vibrerande. Modeller med automatisk mopplyftning är ett maste om du har bade mattor och hardgolv — roboten lyfter moppen när den kör over mattor.</p>

        <h3 class="font-heading text-lg font-bold text-text">Självtömmande station</h3>
        <p>En självtömmande dockningsstation innebär att roboten tömmer sin dammbehallare automatiskt. Du behöver bara byta pase var 30–60 dag. Nästan alla premiummodeller 2026 har detta.</p>

        <h3 class="font-heading text-lg font-bold text-text">Pris</h3>
        <p>Budget (under 4 000 kr): Grundläggande städning utan mopp. Mellanpris (4 000–8 000 kr): Bra prestanda med mopp och självtömning. Premium (over 8 000 kr): Toppprestanda med alla funktioner.</p>
      </div>
    </section>

    <!-- Category guides -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">Guider per kategori</h2>
      <div class="grid sm:grid-cols-3 gap-4 mb-6">
        <a href="/robotdammsugare-med-mopp/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Robotdammsugare med mopp</h3>
          <p class="text-sm text-text-light">5 testade modeller — Dreame X40 Ultra vinner med utfällbar mopp och varmvattentvätt.</p>
        </a>
        <a href="/robotdammsugare-husdjur/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Robotdammsugare for husdjur</h3>
          <p class="text-sm text-text-light">Anti-tangle gummirullar och stark sugkraft for hem med katt och hund.</p>
        </a>
        <a href="/billigaste-robotdammsugare/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Billigaste robotdammsugare</h3>
          <p class="text-sm text-text-light">Bäst for pengarna under 4 000 kr — med riktig LiDAR-navigation.</p>
        </a>
      </div>
      <h2 class="font-heading text-2xl font-bold text-text mb-4">Produktrecensioner</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href="/dreame-x40-ultra/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Dreame X40 Ultra recension</h3>
          <p class="text-sm text-text-light">Var testvinnare med utfällbar mopp och 12 000 Pa. Bäst for moppning 2026.</p>
        </a>
        <a href="/roborock-s8-maxv-ultra/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Roborock S8 MaxV Ultra recension</h3>
          <p class="text-sm text-text-light">AI-kamera undviker djuravföring. Bäst for husdjurshem 2026.</p>
        </a>
        <a href="/roborock-qrevo-master/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Roborock Qrevo Master recension</h3>
          <p class="text-sm text-text-light">FlexiArm mopp och 10 000 Pa till bästa värdepriset i mellanklass.</p>
        </a>
        <a href="/kopguide-robotdammsugare/" class="bg-white rounded-xl border border-border p-5 hover:border-accent transition-colors group">
          <h3 class="font-semibold text-text group-hover:text-accent transition-colors mb-2">Köpguide robotdammsugare</h3>
          <p class="text-sm text-text-light">Forstå LiDAR, sugkraft, moppfunktion och stationer — hitta rätt modell for ditt hem.</p>
        </a>
      </div>
    </section>

    <FAQ items={faqItems} />
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Bästa robotdammsugare 2026",
    "description": "Topplista over de bästa robotdammsugarna 2026, rankade efter test.",
    "numberOfItems": products.length,
    "itemListElement": products.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": p.name,
    })),
  })} />
</BaseLayout>
