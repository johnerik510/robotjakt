---
import BaseLayout from '../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import FAQ from '../components/FAQ.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const faqItems = [
  {
    question: 'Vad är skillnaden mellan Roborock Qrevo Pro och Qrevo Master?',
    answer: 'Qrevo Master är Roborocks toppmodell med starkare sugkraft (13 000 Pa mot Qrevo Pros 7 000 Pa) och AI-kamera med djuravföringsdetektering. Qrevo Pro saknar kamera men levererar automatisk dammtömning, mopptvättning och avtorkning — allt till lägre pris. För de flesta utan husdjur är Qrevo Pro ett bättre val per krona.',
  },
  {
    question: 'Har Roborock Qrevo Pro automatisk mopptvättning?',
    answer: 'Ja. Qrevo Pro:s station tvättar mopparna med varmt vatten under städcykeln och torkar dem med varmluft efteråt. Det förhindrar mögel och dålig lukt. Du behöver fylla vattentankarna (ca en gång i veckan) och tömma dammpåsen var 7:e vecka.',
  },
  {
    question: 'Kan Roborock Qrevo Pro lyfta mopparna på mattor?',
    answer: 'Ja, Qrevo Pro lyfter automatiskt mopparna 5 mm när den kör över mattor. Det räcker för de flesta tunnare mattor men kan ge fuktiga spår på tjocka mattor om du har avvikande trösklar. Konfigurera mattzonerna i appen för bäst resultat.',
  },
  {
    question: 'Fungerar Qrevo Pro med Google Home och Alexa?',
    answer: 'Ja, Roborock Qrevo Pro stödjer Google Assistant och Amazon Alexa för röststyrning. Du kan starta, pausa och schemalägga städning med röstkommandon. Styrning via Roborock-appen ger fler möjligheter som selektiv rumsrengöring.',
  },
  {
    question: 'Vilka reservdelar passar Roborock Qrevo Pro?',
    answer: 'Qrevo Pro delar reservdelssystem med Qrevo S och Qrevo MaxV. Du hittar kompatibla kit med HEPA-filter, sidoborstar, huvudborste och moppkuddar på Amazon. Byt filter var 2 månad och sidoborstar var 6–12 månad.',
  },
];

const breadcrumbs = [
  { label: 'Roborock Qrevo Pro recension' },
];

const specs = [
  { label: 'Sugkraft', value: '7 000 Pa' },
  { label: 'Navigering', value: 'LiDAR + PreciSense' },
  { label: 'Klippbredd', value: '—' },
  { label: 'Moppfunktion', value: 'Ja — roterande mopp' },
  { label: 'Automatisk dammtömning', value: 'Ja' },
  { label: 'Mopptvättning', value: 'Ja — varmt vatten' },
  { label: 'Mopptorkning', value: 'Ja — varmluft' },
  { label: 'Mattlyftning', value: 'Ja — 5 mm' },
  { label: 'AI-kamera', value: 'Nej' },
  { label: 'App', value: 'Roborock (iOS/Android)' },
  { label: 'Röststyrning', value: 'Google Assistant, Alexa' },
  { label: 'Batteri', value: '5 200 mAh' },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": { "@type": "Answer", "text": item.answer },
}));
---

<BaseLayout
  title="Roborock Qrevo Pro Recension 2026 – Test och Pris Sverige"
  description="Roborock Qrevo Pro testad: 7 000 Pa, automatisk mopptvättning och dammtömning utan AI-kamera. Se betyg, pris och jämförelse med Qrevo Master 2026."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={breadcrumbs} />
    <AffiliateDisclaimer />

    <p class="text-xs text-text-lighter mb-4">Senast uppdaterad: 2026-04-05</p>

    <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text mb-4 leading-tight">
      Roborock Qrevo Pro Recension 2026
    </h1>

    <div class="bg-winner/5 border border-winner/20 rounded-xl p-5 mb-8">
      <div class="flex items-start gap-4">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-2">
            <span class="bg-accent text-white text-xs font-bold px-2 py-1 rounded">BÄST PRIS/PRESTANDA QREVO</span>
            <div class="flex gap-0.5">
              {[1,2,3,4,5].map(i => (
                <svg class={`w-4 h-4 ${i <= 4 ? 'text-winner' : 'text-border'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="font-bold text-text">4.3 / 5</span>
          </div>
          <p class="text-text-light text-sm leading-relaxed">
            Roborock Qrevo Pro levererar helautomatisk städning med mopptvättning, dammtömning och mopptorkning — utan att kosta som Qrevo Master. Utan AI-kamera men med LiDAR-navigering och 7 000 Pa sugkraft är det ett genomarbetat val för hem utan husdjur.
          </p>
        </div>
      </div>
    </div>

    <div class="bg-bg-alt rounded-xl border border-border p-5 mb-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <p class="text-2xl font-bold text-text">ca 6 490 kr</p>
          <p class="text-sm text-text-light">Pris varierar — jämför alltid mellan butiker</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="https://go.adt267.com/t/t?a=1615916040&as=2063681412&t=2&tk=1&url=https%3A%2F%2Fwww.komplett.se%2Fsearch%3Fq%3Droborock%2Bqrevo%2Bpro"
            rel="sponsored noopener noreferrer"
            target="_blank"
            class="inline-flex items-center justify-center bg-cta hover:bg-cta/90 text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm min-h-[44px]"
          >
            Se pris på Komplett
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 gap-5 mb-8">
      <div class="bg-white rounded-xl border border-border p-5">
        <h2 class="font-semibold text-text mb-3">Fördelar med Roborock Qrevo Pro</h2>
        <ul class="space-y-2">
          {[
            'Helautomatisk station — dammtömning + mopptvättning + torkning',
            '7 000 Pa — stark sugkraft för djur- och familjehushåll',
            'LiDAR-navigering med rumsigenkänning',
            'Automatisk mattlyftning (5 mm)',
            'Prisvärd jämfört med Qrevo Master',
            'Bra reservdelstillgång',
          ].map(pro => (
            <li class="flex items-start gap-2 text-sm text-text-light">
              <span class="text-winner font-bold flex-shrink-0 mt-0.5">+</span>
              {pro}
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-white rounded-xl border border-border p-5">
        <h2 class="font-semibold text-text mb-3">Nackdelar med Roborock Qrevo Pro</h2>
        <ul class="space-y-2">
          {[
            'Ingen AI-kamera — kan inte undvika husdjursavföring',
            'Lägre sugkraft än Qrevo Master (7 000 vs 13 000 Pa)',
            'Inga obstacle avoidance-kameror',
          ].map(con => (
            <li class="flex items-start gap-2 text-sm text-text-light">
              <span class="text-cta font-bold flex-shrink-0 mt-0.5">-</span>
              {con}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <section class="mb-10">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">Roborock Qrevo Pro — detaljerad genomgång</h2>

      <h3 class="font-heading text-xl font-semibold text-text mb-3">Helautomatisk station</h3>
      <p class="text-text-light leading-relaxed mb-6">
        Stationen sköter dammtömning efter varje städpass, tvättar mopparna med varmt vatten under pågående städning och torkar dem sedan med varmluft. I praktiken kan du gå veckor utan att behöva röra roboten — fyll vattenttankarna (ca 3 liter) en gång i veckan och töm dammpåsen var 7:e vecka.
      </p>

      <h3 class="font-heading text-xl font-semibold text-text mb-3">Specifikationer Roborock Qrevo Pro</h3>
      <div class="bg-bg-alt rounded-xl border border-border overflow-hidden mb-6">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-border">
            {specs.map((spec, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : ''}>
                <td class="px-4 py-3 font-medium text-text w-1/2">{spec.label}</td>
                <td class="px-4 py-3 text-text-light">{spec.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="font-heading text-xl font-semibold text-text mb-3">Qrevo Pro vs Qrevo Master — när är Pro tillräckligt?</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Qrevo Master kostar ca 4 000 kr mer och tillför AI-kamera med djuravföringsdetektering, starkare sugkraft (13 000 Pa) och fler hinder-sensorer. För hem utan husdjur och utan extremt smutsiga ytor levererar Qrevo Pro identisk komfort. Välj Master om du har katt eller hund — annars är Pro det smartare köpet per krona.
      </p>

      <h3 class="font-heading text-xl font-semibold text-text mb-3">Reservdelar och underhåll</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Qrevo Pro delar reservdelssystem med Qrevo S och Qrevo MaxV. Byt HEPA-filter var 2 månad, sidoborstar var 6–12 månad och huvudborsten var 12 månader. Amazon erbjuder kompletta kit på ca 200–300 kr.
      </p>
    </section>

    <FAQ items={faqItems} />

    <section class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
      <h2 class="font-heading text-lg font-bold text-text mb-3">Jämför med liknande modeller</h2>
      <ul class="space-y-2">
        <li><a href="/roborock-qrevo-master/" class="text-accent hover:underline text-sm">Roborock Qrevo Master — mer kraft och AI-kamera</a></li>
        <li><a href="/roborock-s8-pro-ultra/" class="text-accent hover:underline text-sm">Roborock S8 Pro Ultra — äldre flaggskepp med FlexiArm</a></li>
        <li><a href="/reservdelar/roborock/" class="text-accent hover:underline text-sm">Roborock reservdelar — filter, borstar och tillbehör</a></li>
        <li><a href="/roborock-guide/" class="text-accent hover:underline text-sm">Roborock — alla modeller guide 2026</a></li>
      </ul>
    </section>
  </div>

  <StickyCTA
    text="Se pris på Roborock Qrevo Pro"
    url="https://go.adt267.com/t/t?a=1615916040&as=2063681412&t=2&tk=1&url=https%3A%2F%2Fwww.komplett.se%2Fsearch%3Fq%3Droborock%2Bqrevo%2Bpro"
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": {
      "@type": "Product",
      "name": "Roborock Qrevo Pro",
      "image": "https://robotjakt.se/images/roborock-qrevo-pro.webp",
      "brand": { "@type": "Brand", "name": "Roborock" },
      "category": "Robotdammsugare",
      "description": "Roborock Qrevo Pro med helautomatisk station, 7 000 Pa sugkraft och LiDAR-navigering.",
      "offers": {
        "@type": "Offer",
        "priceCurrency": "SEK",
        "price": "6490",
        "availability": "https://schema.org/InStock",
      }
    },
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": "4.3",
      "bestRating": "5",
      "worstRating": "1"
    },
    "author": { "@type": "Person", "name": "John Erik Johansson" },
    "datePublished": "2026-04-05",
    "reviewBody": "Roborock Qrevo Pro levererar helautomatisk städning till ett rimligare pris än Qrevo Master — utan AI-kamera men med all nödvändig automatik.",
    "publisher": { "@type": "Organization", "name": "Robotjakt", "url": "https://robotjakt.se" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqSchema,
  })} />
</BaseLayout>
