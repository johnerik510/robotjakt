const productSchema = products.map((p, i) => ({
  "@type": "Product",
  "position": i + 1,
  "name": p.name,
  "image": p.image.startsWith('http') ? p.image : `https://robotjakt.se${p.image}`,
  "review": {
    "@type": "Review",
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": p.rating.toString(),
      "bestRating": "5",
