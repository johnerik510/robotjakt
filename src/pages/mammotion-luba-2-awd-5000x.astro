  "brand": { "@type": "Brand", "name": "Mammotion" },
  "description": "Mammotion LUBA 2 AWD 5000X robotgräsklippare utan slingkabel med RTK GPS, AWD, 80% lutning och 5 000 m² kapacitet.",
  "category": "Robotgräsklippare",
