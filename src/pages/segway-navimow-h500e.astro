    "publisher": { "@type": "Organization", "name": "Robotjakt", "url": "https://robotjakt.se" }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqSchema,
})} />
