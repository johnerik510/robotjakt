---
import BaseLayout from '../layouts/BaseLayout.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import FAQ from '../components/FAQ.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const faqItems = [
  {
    question: 'Behöver Segway Navimow H800E slingkabel?',
    answer: 'Nej — H800E använder Exact!Fusion GPS+RTK för att navigera utan slingkabel. Du definierar gränserna i appen istället. Det gör installation dramatiskt enklare jämfört med Husqvarna Automower, men kräver att GPS-mottagning fungerar väl på din tomt.',
  },
  {
    question: 'Vad är Exact!Fusion GPS-teknologin?',
    answer: 'Exact!Fusion kombinerar RTK GPS (centimeterprecision), IMU och visuell detektion för att positionera roboten utan slinga. I Sverige med god satellitstäckning fungerar det utmärkt på de flesta öppna tomter. Träd och byggnader kan skymma GPS — testa positioneringen på din specifika tomt innan köp.',
  },
  {
    question: 'Vad är kapaciteten på Segway Navimow H800E?',
    answer: 'H800E klarar upp till 3 000 m² gräsyta — stor villatomt. Den har starkare motor och batteri än H500E (1 800 m²) och är bättre lämpad för kuperad terräng med upp till 45% lutning.',
  },
  {
    question: 'Hur jämförs H800E mot Husqvarna Automower 430X Nera?',
    answer: 'H800E har fördelen av ingen slinga-installation och liknande lutningskapacitet (45%). Husqvarna 430X Nera är mer beprövad med fler år på marknaden och bredare servicenätverk i Sverige. H800E är ett bra val om installationsenkelhet prioriteras. Husqvarna väljs om lång beprövad tillförlitlighet är viktigast.',
  },
  {
    question: 'Kan Segway Navimow H800E hantera brant terräng?',
    answer: 'Ja, H800E klarar upp till 45% lutning — jämförbart med Husqvarna 430X Nera. Utan slinga kan roboten dessutom anpassas mer flexibelt runt hinder och backar via app utan att lägga om kabel.',
  },
];

const breadcrumbs = [
  { label: 'Segway Navimow H800E recension' },
];

const specs = [
  { label: 'Klippyta', value: 'upp till 3 000 m²' },
  { label: 'Max lutning', value: '45%' },
  { label: 'Klipphöjd', value: '25–65 mm' },
  { label: 'Klippbredd', value: '22 cm' },
  { label: 'Navigering', value: 'Exact!Fusion RTK GPS (utan slinga)' },
  { label: 'Bullernivå', value: '60 dB(A)' },
  { label: 'Batteri', value: 'Li-Ion' },
  { label: 'Laddtid', value: '90 min' },
  { label: 'Drifttid', value: 'ca 120 min' },
  { label: 'App', value: 'Segway Navimow (iOS/Android)' },
  { label: 'WiFi/4G', value: 'WiFi' },
  { label: 'Slingkabel', value: 'Krävs ej' },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": {
    "@type": "Answer",
    "text": item.answer,
  },
}));
---

<BaseLayout
  title="Segway Navimow H800E Test 2026 – Recension & Pris"
  description="Segway Navimow H800E testad: RTK GPS utan slinga, 45% lutning och 3 000 m² kapacitet. Enkel installation. Se betyg, pris och jämförelse 2026."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={breadcrumbs} />
<p class="text-xs text-text-lighter mb-4">Senast uppdaterad: 2026-04-05</p>

    <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text mb-4 leading-tight">
      Segway Navimow H800E Recension 2026
    </h1>

    <div class="bg-winner/5 border border-winner/20 rounded-xl p-5 mb-8">
      <div class="flex items-start gap-4">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-2">
            <span class="bg-accent text-white text-xs font-bold px-2 py-1 rounded">UTAN SLINGA — STOR TOMT</span>
            <div class="flex gap-0.5">
              {[1,2,3,4,5].map(i => (
                <svg class={`w-4 h-4 ${i <= 4 ? 'text-winner' : 'text-border'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="font-bold text-text">4.2 / 5</span>
          </div>
          <p class="text-text-light text-sm leading-relaxed">
            Segway Navimow H800E kombinerar Exact!Fusion RTK GPS med 45% lutningskapacitet för tomter upp till 3 000 m² — utan en meter slingkabel. För den som vill slippa grävningsarbete och ändå ha en robot som hanterar stor, kuperad tomt är H800E ett starkt alternativ till Husqvarna.
          </p>
        </div>
      </div>
    </div>

    <div class="bg-bg-alt rounded-xl border border-border p-5 mb-8">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <p class="text-2xl font-bold text-text">ca 17 990 kr</p>
          <p class="text-sm text-text-light">Pris varierar — jämför alltid mellan butiker</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="https://www.pricerunner.se/search?q=segway+navimow+h800e"
            rel="sponsored noopener noreferrer"
            target="_blank"
            class="inline-flex items-center justify-center bg-cta hover:bg-cta/90 text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm min-h-[44px]"
          >
            Jämför pris på PriceRunner
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 gap-5 mb-8">
      <div class="bg-white rounded-xl border border-border p-5">
        <h2 class="font-semibold text-text mb-3">Fördelar med Segway Navimow H800E</h2>
        <ul class="space-y-2">
          {[
            'Ingen slingkabel — RTK GPS-navigering',
            '45% lutning — hanterar kuperad terräng',
            '3 000 m² kapacitet',
            'Enkel installation via app',
            'Tyst (60 dB) — ingen störning för grannar',
            'WiFi-styrning från mobilen',
          ].map(pro => (
            <li class="flex items-start gap-2 text-sm text-text-light">
              <span class="text-winner font-bold flex-shrink-0 mt-0.5">+</span>
              {pro}
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-white rounded-xl border border-border p-5">
        <h2 class="font-semibold text-text mb-3">Nackdelar med Segway Navimow H800E</h2>
        <ul class="space-y-2">
          {[
            'GPS-prestanda beror på satellitstäckning på tomten',
            'Kortare markhistorik än Husqvarna Automower',
            'Smalare servicenätverk i Sverige',
            'Dyrare per m² än slinga-modeller i budget-segmentet',
          ].map(con => (
            <li class="flex items-start gap-2 text-sm text-text-light">
              <span class="text-cta font-bold flex-shrink-0 mt-0.5">-</span>
              {con}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <section class="mb-10">
      <h2 class="font-heading text-2xl font-bold text-text mb-4">Segway Navimow H800E — detaljerad genomgång</h2>

      <h3 class="font-heading text-xl font-semibold text-text mb-3">Exact!Fusion — GPS utan kompromisser</h3>
      <p class="text-text-light leading-relaxed mb-6">
        H800E:s RTK GPS ger centimeterprecision i positionering. Det innebär att roboten vet exakt var den befinner sig i trädgården och klipper systematiskt utan att missa ytor. Kombination med IMU (rörelsesensor) och visuell detektion ger pålitlig navigering även vid kortvariga GPS-avbrott under träd.
      </p>

      <h3 class="font-heading text-xl font-semibold text-text mb-3">Installation — 30 minuter istället för 4 timmar</h3>
      <p class="text-text-light leading-relaxed mb-6">
        Utan slingkabel är installation dramatiskt enklare: placera stationen, anslut ström och rita in gränserna i appen via GPS-koordinater. Kalibrering tar 15–30 minuter. Inga grävningsverktyg, inga spikar, inget kabelarbete. Det är H800E:s absolut tydligaste fördel mot Husqvarna.
      </p>

      <h3 class="font-heading text-xl font-semibold text-text mb-3">Specifikationer Segway Navimow H800E</h3>
      <div class="bg-bg-alt rounded-xl border border-border overflow-hidden mb-6">
        <table class="w-full text-sm">
          <tbody class="divide-y divide-border">
            {specs.map((spec, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : ''}>
                <td class="px-4 py-3 font-medium text-text w-1/2">{spec.label}</td>
                <td class="px-4 py-3 text-text-light">{spec.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="font-heading text-xl font-semibold text-text mb-3">För vem passar Segway Navimow H800E?</h3>
      <p class="text-text-light leading-relaxed mb-4">
        H800E passar villaägare med 1 000–3 000 m² tomt och kuperad terräng som vill slippa slingkabel-installation. Välj H800E om enkel installation väger tyngst. Välj Husqvarna Automower 430X Nera om beprövad tillförlitlighet och lokalt servicenätverk är viktigast.
      </p>
    </section>

    <FAQ items={faqItems} />

    <AffiliateDisclaimer />

    <section class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
      <h2 class="font-heading text-lg font-bold text-text mb-3">Jämför med liknande modeller</h2>
      <ul class="space-y-2">
        <li><a href="/segway-navimow-i105e/" class="text-accent hover:underline text-sm">Segway Navimow i105E — utan slinga för upp till 500 m²</a></li>
        <li><a href="/segway-navimow-h500e/" class="text-accent hover:underline text-sm">Segway Navimow H500E — utan slinga för upp till 5 000 m²</a></li>
        <li><a href="/robotgrasklippare-utan-slinga/" class="text-accent hover:underline text-sm">Bästa robotgräsklippare utan slinga 2026</a></li>
        <li><a href="/husqvarna-automower-430x-nera/" class="text-accent hover:underline text-sm">Husqvarna Automower 430X Nera — beprövat alternativ</a></li>
        <li><a href="/robotgrasklippare/" class="text-accent hover:underline text-sm">Bästa robotgräsklippare 2026 — alla modeller</a></li>
      </ul>
    </section>
  </div>

  <StickyCTA
    text="Jämför pris på Segway Navimow H800E"
    url="https://www.pricerunner.se/search?q=segway+navimow+h800e"
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": {
      "@type": "Product",
      "name": "Segway Navimow H800E",
      "image": "https://robotjakt.se/images/segway-navimow-h800e.webp",
      "brand": { "@type": "Brand", "name": "Segway" },
      "category": "Robotgräsklippare",
      "description": "Segway Navimow H800E robotgräsklippare utan slingkabel med RTK GPS, 45% lutning och 3 000 m² kapacitet.",
      "offers": {
        "@type": "Offer",
        "priceCurrency": "SEK",
        "price": "17990",
        "availability": "https://schema.org/InStock",
      }
    },
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": "4.2",
      "bestRating": "5",
      "worstRating": "1"
    },
    "author": { "@type": "Person", "name": "John Erik Johansson" },
    "datePublished": "2026-04-05",
    "reviewBody": "Segway Navimow H800E kombinerar RTK GPS med 45% lutningskapacitet utan slinga. Bäst för den som prioriterar enkel installation på stor kuperad tomt.",
    "publisher": { "@type": "Organization", "name": "Robotjakt", "url": "https://robotjakt.se" }
  })} />
</BaseLayout>
