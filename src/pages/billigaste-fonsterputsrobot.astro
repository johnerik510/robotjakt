                ))}
              </ul>
            </div>
            <div>
              <p class="text-xs font-semibold text-text mb-2">Kompromisser</p>
              <ul class="space-y-1">
                {['Ingen app-styrning', 'Lägre täckning — 15 m²/h', 'Kräver fönsterram', 'Grundläggande rengöringsresultat utan spray'].map(c => (
