      </section>

      <!-- Produkt 4: Gladoxt W66 -->
      <section class="bg-white rounded-xl border border-border overflow-hidden">
        <div class="bg-bg-alt px-5 py-3 border-b border-border flex items-center gap-3">
          <span class="bg-text-lighter text-white text-xs font-bold px-2 py-1 rounded">ABSOLUT BILLIGAST</span>
          <span class="font-heading font-bold text-text">Gladoxt W66</span>
          <span class="ml-auto font-bold text-text">ca 799 kr</span>
        </div>
        <div class="p-5">
          <p class="text-text-light text-sm leading-relaxed mb-4">
            Gladoxt W66 är det absolut billigaste alternativet i segmentet — en enkel kabeldriven fönsterputsrobot för standardfönster med ram. Ingen app, ingen spray, inga extrafunktioner. Rengör med mikrofiberduk och vakuumsugsugning mot glaset. Passar den som vill testa konceptet till minimalt pris.
          </p>
          <div class="grid sm:grid-cols-2 gap-4 mb-4">
            <div>
              <p class="text-xs font-semibold text-text mb-2">Vad den klarar</p>
              <ul class="space-y-1">
                {['Absolut lägst pris — 799 kr', 'Enkel och driftsäker kabeldrift', 'Grundläggande fönsterputsning på standardfönster'].map(p => (
                  <li class="flex items-start gap-1.5 text-xs text-text-light"><span class="text-winner font-bold mt-0.5">+</span>{p}</li>
                ))}
              </ul>
            </div>
            <div>
              <p class="text-xs font-semibold text-text mb-2">Kompromisser</p>
              <ul class="space-y-1">
                {['Ingen app-styrning', 'Ingen inbyggd sprayflaska', 'Kräver fönsterram', 'Lägst täckning — 15 m²/h', 'Sämre rengöringsresultat vid kraftig smuts'].map(c => (
                  <li class="flex items-start gap-1.5 text-xs text-text-light"><span class="text-cta font-bold mt-0.5">-</span>{c}</li>
                ))}
              </ul>
            </div>
          </div>
          <a
            href="https://www.amazon.se/s?k=gladoxt+w66+window+robot"
            rel="sponsored nofollow noopener"
            target="_blank"
            class="inline-flex items-center justify-center bg-cta hover:bg-cta-dark text-white font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm min-h-[44px]"
          >
            Se pris på Gladoxt W66
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
