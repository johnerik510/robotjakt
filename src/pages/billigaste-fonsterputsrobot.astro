              <td class="px-4 py-3 font-medium text-text">Cleano Window Robot</td>
              <td class="px-4 py-3 text-winner font-semibold">Reservbatteri 30 min</td>
              <td class="px-4 py-3 text-text-light">Kabel + batteri</td>
              <td class="px-4 py-3 text-text-light">17 m²/h</td>
              <td class="px-4 py-3 text-text-light">1 år</td>
              <td class="px-4 py-3 font-semibold text-text">1 499 kr</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-text">EziBot Window Robot</td>
              <td class="px-4 py-3 text-text-light">Kabel — ingen risk</td>
              <td class="px-4 py-3 text-text-light">Kabel</td>
              <td class="px-4 py-3 text-text-light">15 m²/h</td>
              <td class="px-4 py-3 text-text-light">1 år</td>
              <td class="px-4 py-3 font-semibold text-text">999 kr</td>
