---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Roborock eller Dreame — vilket märke ska jag välja?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Roborock har generellt bättre app och navigering, medan Dreame ofta erbjuder mer sugkraft och lägre pris för samma prestanda. Roborock passar dig som vill ha pålitlig mjukvara, Dreame om du prioriterar råstyrka och pris/prestanda."
      }
    },
    {
      "@type": "Question",
      name: "Vad ska jag jämföra när jag väljer robotdammsugare?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "De viktigaste faktorerna är sugkraft (Pa), navigeringstyp (LiDAR vs kamera), hinderdetektering, tömningsstations-funktion, moppfunktion och pris. För hem med husdjur är hinderdetektering extra viktigt."
      }
    },
    {
      "@type": "Question",
      name: "Är det värt att betala mer för ett premiumrobot?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Ja i de flesta fall. Modeller över 6 000 kr erbjuder LiDAR-navigering, automatisk tömmning och bättre hinderdetektering som sparar tid. Budget-modeller under 3 000 kr saknar ofta dessa funktioner."
      }
    },
    {
      "@type": "Question",
      name: "Husqvarna eller Mammotion robotgräsklippare?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Husqvarna kräver perimeterkabel men är beprövad teknik. Mammotion använder GPS och kräver ingen kabel, vilket ger enklare installation. Mammotion passar bättre för de flesta moderna trädgårdar under 1 500 m²."
      }
    }
  ]
};

const comparisons = [
  {
    title: 'Roborock Saros 10R vs Dreame X40 Ultra April 2026',
    href: '/jamfor/roborock-saros-10r-vs-dreame-x40-ultra/',
    desc: '14 990 kr vs 9 990 kr. Världens tunnaste robot (7,98 cm) och 20 000 Pa mot utfällbar sidoarm och bäst pris/prestanda. Är 5 000 kr extra värt det?',
    tag: 'Roborock vs Dreame',
  },
  {
    title: 'Roborock Saros 10R vs Roborock S8 MaxV Ultra April 2026',
    href: '/jamfor/roborock-saros-10r-vs-roborock-s8-maxv-ultra/',
    desc: '14 990 kr vs 9 990 kr. Ny toppmodell mot beprövat flaggskepp. 7,98 cm och 20 000 Pa mot 9,65 cm och 10 000 Pa — är det värt 5 000 kr extra?',
    tag: 'Roborock vs Roborock',
  },
  {
    title: 'Dreame L20 Ultra vs X40 Ultra 2026',
    href: '/jamfor/dreame-l20-ultra-vs-dreame-x40-ultra/',
    desc: 'Budget vs premium inom Dreame-familjen. L20 Ultra till 5 990 kr eller X40 Ultra till 9 990 kr — vilken passar ditt hem?',
    tag: 'Dreame vs Dreame',
  },
  {
    title: 'Dreame X40 Ultra vs Roborock S8 MaxV Ultra 2026',
    href: '/dreame-x40-ultra-vs-roborock-s8-maxv-ultra/',
    desc: '12 000 Pa och utfällbar mopp mot 10 000 Pa och AI-djurskydd. Flaggskepp mot flaggskepp.',
    tag: 'Dreame vs Roborock',
  },
  {
    title: 'Roborock Qrevo Master vs Dreame X40 Ultra 2026',
    href: '/jamfor/roborock-qrevo-master-vs-dreame-x40-ultra/',
    desc: '7 490 kr mot 9 990 kr. FlexiArm och gummirulle mot utfällbar sidoarm och 12 000 Pa.',
    tag: 'Roborock vs Dreame',
  },
  {
    title: 'Roborock Qrevo Master vs S8 MaxV Ultra 2026',
    href: '/jamfor/roborock-qrevo-master-vs-roborock-s8-maxv-ultra/',
    desc: 'Samma sugkraft, 3 500 kr skillnad. Är AI-djuravföringsdetektion och ReactiveAI 3.0 värt merkostnaden?',
    tag: 'Roborock vs Roborock',
  },
  {
    title: 'Roborock vs Dreame April 2026 — märkesjämförelse',
    href: '/roborock-vs-dreame/',
    desc: 'Vilket märke ska du välja? Vi jämför ekosystem, reservdelar, app-kvalitet och total value.',
    tag: 'Märkesjämförelse',
  },
  {
    title: 'Ecovacs X5 Omni vs Dreame X40 Ultra 2026',
    href: '/jamfor/ecovacs-deebot-x5-omni-vs-dreame-x40-ultra/',
    desc: 'Fyrkantig design och 180 min batteri mot 12 000 Pa och utfällbar sidoarm. 8 990 kr mot 9 990 kr.',
    tag: 'Ecovacs vs Dreame',
  },
  {
    title: 'Ecovacs X5 Omni vs Roborock S8 MaxV Ultra April 2026',
    href: '/jamfor/ecovacs-deebot-x5-omni-vs-roborock-s8-maxv-ultra/',
    desc: '8 990 kr vs 9 990 kr. Fyrkantig design och AIVI 3D mot LiDAR och 10 000 Pa. Vilket direkta flaggskepp vinner i samma prisklass?',
    tag: 'Ecovacs vs Roborock',
  },
  {
    title: 'Roborock vs Ecovacs April 2026 — märkesjämförelse',
    href: '/roborock-vs-ecovacs/',
    desc: 'ReactiveAI 3.0 och AI-djurskydd mot 11 000 Pa och hygienisk varmluftstorkning. Vilket märke passar ditt hem?',
    tag: 'Märkesjämförelse',
  },
  {
    title: 'Husqvarna vs Mammotion April 2026 — robotgräsklippare',
    href: '/husqvarna-vs-mammotion/',
    desc: 'Traditionell slinga mot GPS-navigering utan slinga. Vilket system passar din trädgård?',
    tag: 'Robotgräsklippare',
  },
  {
    title: 'Husqvarna vs Gardena robotgräsklippare 2026',
    href: '/husqvarna-vs-gardena/',
    desc: 'De ägs av samma företag — men skiljer sig i pris, kapacitet och GPS-stöldskydd. Vilket passar din trädgård?',
    tag: 'Robotgräsklippare',
  },
  {
    title: 'Gardena vs Segway Navimow April 2026 — kabel vs kabelläst GPS',
    href: '/gardena-vs-segway-navimow/',
    desc: 'Perimeterkabel mot slingfri GPS-navigation — pris, installation, kantklippning och vem som vinner.',
    tag: 'Robotgräsklippare',
  },
  {
    title: 'Husqvarna Automower vs Segway Navimow April 2026 — GPS mot GPS',
    href: '/husqvarna-vs-segway-navimow/',
    desc: 'Båda är kabelläsa GPS-robotar. Vi avgör vilket system som vinner på pris, precision och servicenätverk.',
    tag: 'Robotgräsklippare',
  },
  {
    title: 'Narwal Freo X Ultra vs Dreame X40 Ultra April 2026',
    href: '/narwal-freo-x-ultra-vs-dreame-x40-ultra/',
    desc: 'Varmluftsfunktion (40°C) mot 12 000 Pa och utfällbar mopparm. Samma prisklass — helt olika USP:ar.',
    tag: 'Narwal vs Dreame',
  },
];
---

<BaseLayout
  title="Jämförelser — Robotdammsugare och robotgräsklippare April 2026"
  description="Direkta jämförelser mellan de bästa robotarna 2026. Vi svarar på: vilken ska jag välja? Dreame vs Roborock, Husqvarna vs Mammotion och mer."
>
  <section class="bg-gradient-to-br from-primary to-primary-dark text-white py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Robotdammsugare', href: '/' }, { label: 'Jämförelser' }]} />
      <h1 class="font-heading text-3xl font-bold mb-2">Jämförelser 2026</h1>
      <p class="text-base text-gray-300 max-w-3xl">
        Sida vid sida — vi jämför de mest efterfrågade modellerna och ger dig ett tydligt svar.
      </p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {comparisons.map((c) => (
        <a href={c.href} class="block bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-border overflow-hidden group">
          <div class="h-2 bg-gradient-to-r from-accent to-cta"></div>
          <div class="p-6">
            <span class="inline-block text-xs font-semibold text-accent bg-accent/10 px-2 py-0.5 rounded mb-2">{c.tag}</span>
            <h2 class="font-heading text-xl font-bold text-text group-hover:text-accent transition-colors mb-2">
              {c.title}
            </h2>
            <p class="text-text-light text-sm leading-relaxed">{c.desc}</p>
            <span class="inline-block mt-3 text-sm font-semibold text-accent">Se jämförelsen →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <h2 class="font-heading text-2xl font-bold text-text mb-6">Vanliga frågor om att jämföra robotar</h2>
    <div class="space-y-4">
      {faqSchema.mainEntity.map((item) => (
        <details class="bg-white border border-border rounded-xl overflow-hidden group">
          <summary class="flex items-center justify-between cursor-pointer px-5 py-4 font-semibold text-text hover:text-accent transition-colors list-none">
            <span>{item.name}</span>
            <svg class="w-5 h-5 text-text-light group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-5 pb-4 text-text-light text-sm leading-relaxed">{item.acceptedAnswer.text}</div>
        </details>
      ))}
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
