---
import ArticleLayout from '../layouts/ArticleLayout.astro';
import FAQ from '../components/FAQ.astro';
import StickyCTA from '../components/StickyCTA.astro';

const breadcrumbs = [
  { label: 'Drönare', href: '/dronare/' },
  { label: 'DJI Air 3S' },
];

const specs = [
  { label: 'Vikt', value: '724 g (C1-klass)' },
  { label: 'Vidvinkelkamera', value: '1-tums CMOS, 50 MP' },
  { label: 'Telekamera', value: '70 mm, 48 MP, f/2.8' },
  { label: 'Video', value: '4K/60 fps HDR, D-Log M' },
  { label: 'Dynamiskt omfång', value: '14 steg' },
  { label: 'Flygtid', value: 'Upp till 45 min' },
  { label: 'Räckvidd', value: '10 km (CE)' },
  { label: 'Internlagring', value: '42 GB' },
  { label: 'Vindbegränsning', value: '12 m/s (Level 6)' },
  { label: 'Hinderdetektering', value: 'Omnidirektionell + Nightscape' },
];

const faqItems = [
  {
    question: 'Kräver DJI Air 3S drönarkort i Sverige?',
    answer: 'Ja. DJI Air 3S väger 724 g och klassas som C1 i EU:s regelverk. Det innebär att du behöver A1/A3-kompetensbevis för att flyga i öppen kategori. Provet tas gratis via EASAs online-utbildning och tar ca 1–2 timmar. Du måste också registrera dig som operatör hos Transportstyrelsen (190 kr + 250 kr/år). Kontrollera alltid aktuella regler på Transportstyrelsen.se.',
  },
  {
    question: 'Vad är skillnaden mellan DJI Air 3S och DJI Air 3?',
    answer: 'Air 3S (2024) är uppföljaren till Air 3 (2023) med en uppgraderad 1-tums sensor i vidvinkelkameran istället för 1/1.3-tums. Air 3S har också förbättrad O4 Pro videoöverföring, förbättrad hinderdetektering och nytt Nightscape-läge för säkrare nattflygning. Air 3S är klart bättre för foto och film i varierat ljus.',
  },
  {
    question: 'Är 45 minuters flygtid realistiskt?',
    answer: 'Under idealiska testförhållanden — lugnt väder, konstant hastighet — ja. I verkligheten med vind, aktiv manövrering och kyla räkna med 30–38 minuter. Det är fortfarande klart bäst i konsumentklassen. Med Fly More Combo och tre batterier har du ca 120 minuters total flygtid per session.',
  },
  {
    question: 'Vilken kontrollenhet ska man välja till Air 3S?',
    answer: 'RC-N3 är den billigaste varianten — du kopplar din smartphone. DJI RC 2 har en inbyggd 1000 nit-skärm som syns utomhus i solljus utan att du behöver en telefon. Rekommendationen är RC 2 om du flyger regelbundet utomhus — det förenklar hanteringen kraftigt. RC-N3 räcker för att komma igång och spara pengar initialt.',
  },
];

const faqSchema = faqItems.map((item) => ({
  "@type": "Question",
  "name": item.question,
  "acceptedAnswer": { "@type": "Answer", "text": item.answer },
}));

const ctaUrl = 'https://dronarbutiken.se/collections/dji-air-3';
---

<ArticleLayout
  title="DJI Air 3S Test April 2026 — Recension och Specifikationer"
  description="Fullständig recension av DJI Air 3S. Vi testar dubbla kameror, 4K HDR, 45 min flygtid och C1-regler. Är den bästa kameradrönaren 2026?"
  breadcrumbs={breadcrumbs}
  lastUpdated="2026-04-06"
  ogImage="/images/dji-air-3s.webp"
>
  <h1 class="font-heading text-3xl sm:text-4xl font-bold text-text mb-4 leading-tight">
    DJI Air 3S — Recension 2026
  </h1>

  <!-- Verdict box -->
  <div class="bg-winner/5 border border-winner/20 rounded-xl p-5 mb-8">
    <div class="flex items-start gap-4">
      <div class="flex-1">
        <div class="flex items-center gap-3 mb-2">
          <span class="bg-winner text-white text-xs font-bold px-2 py-1 rounded">BÄST KAMERA 2026</span>
          <div class="flex gap-0.5" aria-label="Betyg: 9.3 av 10">
            {[1,2,3,4,5].map(i => (
              <svg class="w-4 h-4 text-winner" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="font-bold text-text">9,3 / 10</span>
        </div>
        <p class="text-text-light text-sm leading-relaxed mb-3">
          DJI Air 3S är konsumentdrönaren med bäst bildkvalitet 2026. Dubbla 1-tums kameror, 45 min flygtid och 4K HDR — för den som vill ha professionellt material utan att kompromissa på portabilitet.
        </p>
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <div>
            <p class="text-2xl font-bold text-text">ca 13 199 kr</p>
            <p class="text-xs text-text-light">Fly More Combo: ca 18 990 kr</p>
          </div>
          <a
            href={ctaUrl}
            rel="sponsored nofollow noopener noreferrer"
            target="_blank"
            class="inline-flex items-center justify-center bg-cta hover:bg-cta-dark text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm min-h-[44px]"
          >
            Se pris på DJI Air 3S
            <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Pros/Cons -->
  <div class="grid sm:grid-cols-2 gap-5 mb-8">
    <div class="bg-white rounded-xl border border-border p-5">
      <h2 class="font-semibold text-text mb-3">Fördelar</h2>
      <ul class="space-y-2">
        {[
          'Dubbla kameror — 1-tums vidvinkel + 70 mm tele',
          '4K HDR med 14 steg dynamiskt omfång',
          '45 min flygtid — bäst i klassen',
          '42 GB internlagring',
          'Nightscape hinderdetektering — fungerar i mörker',
          'D-Log M för professionell färggradering',
        ].map(pro => (
          <li class="flex items-start gap-2 text-sm text-text-light">
            <span class="text-winner font-bold flex-shrink-0 mt-0.5">+</span>
            {pro}
          </li>
        ))}
      </ul>
    </div>
    <div class="bg-white rounded-xl border border-border p-5">
      <h2 class="font-semibold text-text mb-3">Nackdelar</h2>
      <ul class="space-y-2">
        {[
          '724 g — C1-klass, drönarkort A1/A3 krävs',
          'Dyrare än Mini-serien',
          'Tyngre och bulkigare att transportera',
        ].map(con => (
          <li class="flex items-start gap-2 text-sm text-text-light">
            <span class="text-cta font-bold flex-shrink-0 mt-0.5">-</span>
            {con}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Specs -->
  <section class="mb-10">
    <h2 class="font-heading text-2xl font-bold text-text mb-4">Tekniska specifikationer</h2>
    <div class="bg-bg-alt rounded-xl border border-border overflow-hidden">
      <table class="w-full text-sm">
        <tbody class="divide-y divide-border">
          {specs.map((spec, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : ''}>
              <td class="px-4 py-3 font-medium text-text w-1/2">{spec.label}</td>
              <td class="px-4 py-3 text-text-light">{spec.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Detailed review -->
  <section class="mb-10">
    <h2 class="font-heading text-2xl font-bold text-text mb-6">Detaljerad genomgång</h2>

    <h3 class="font-heading text-xl font-semibold text-text mb-3">Dubbla kameror — det stora lyftet</h3>
    <p class="text-text-light leading-relaxed mb-4">
      Det som skiljer Air 3S från alla Mini-modeller är dubbla kameror: en 1-tums vidvinkelkamera (50 MP, f/1.7) och en 70 mm medium telekamera (48 MP, f/2.8). Telekameran är inte en digital zoom — det är en fysiskt separat kamera med egen lins. Det ger skarp, brussnål bild även med "telezoom".
    </p>
    <p class="text-text-light leading-relaxed mb-6">
      I praktiken öppnar det upp filmberättande som är svårt att uppnå med en enda kamera. Du kan skifta mellan vidvinkelperspektiv på hela miljön och tight tele-närbild på ett motiv — allt i luften, utan att landa och byta drönare. För resor, natur, sport och evenemang är det en enorm kreativ fördel.
    </p>

    <h3 class="font-heading text-xl font-semibold text-text mb-3">Bildkvalitet — 4K HDR och D-Log M</h3>
    <p class="text-text-light leading-relaxed mb-4">
      Air 3S filmar 4K med upp till 60 bilder per sekund med HDR. Det dynamiska omfånget på 14 steg är bra nog för att hantera kontrasterika situationer — solnedgångar, djupa skuggor mot ljus himmel, gyllene timmen — utan att förlora detaljer i höjdligheter eller skuggor.
    </p>
    <p class="text-text-light leading-relaxed mb-6">
      D-Log M-profilen ger dig flat, färggraderbar video för postproduktion — viktigt om du levererar material till kunder eller redigerar mer professionellt. Normal färgprofil ger snygga, filmklara bilder direkt från drönaren för dem som inte vill gradera.
    </p>

    <h3 class="font-heading text-xl font-semibold text-text mb-3">Flygtid — 45 minuter i praktiken</h3>
    <p class="text-text-light leading-relaxed mb-4">
      DJI anger upp till 45 minuters flygtid under optimala förhållanden. Under verkliga flygningar — normal vind, aktiv manövrering — räkna med 32–40 minuter per batteri. Det är märkbart längre än Mini-serien och ger dig generöst med tid per session.
    </p>

    <h3 class="font-heading text-xl font-semibold text-text mb-3">C1-klass och drönarkort</h3>
    <p class="text-text-light leading-relaxed mb-4">
      Air 3S väger 724 gram och klassas som C1. Det innebär att du behöver ta A1/A3-kompetensbeviset via EASAs webbutbildning — gratis, ca 1–2 timmar. Du måste också registrera dig som operatör hos Transportstyrelsen. Om du planerar kommersiell användning (betalt uppdrag) gäller strängare krav.
    </p>
    <p class="text-text-light leading-relaxed mb-6">
      Kravet är en liten tröskel men inget avskräckande — de allra flesta kan ta det på en eftermiddag. Drönarkort öppnar dessutom upp för mer avancerad flygning som är förbjuden utan certifiering.
    </p>
  </section>

  <!-- Who is it for -->
  <section class="mb-10 bg-bg-alt rounded-xl border border-border p-6">
    <h2 class="font-heading text-xl font-bold text-text mb-3">Vem passar DJI Air 3S för?</h2>
    <p class="text-text-light leading-relaxed mb-3">
      Air 3S är rätt val för dig som är villig att ta drönarkort och vill ha bästa möjliga bildkvalitet. Videografer, fotografer, content creators och semi-professionella piloter hittar sin drönare här.
    </p>
    <p class="text-text-light leading-relaxed">
      Är du nybörjare och vill slippa drönarkort — välj DJI Mini 5 Pro istället. Vill du ha premium bildkvalitet utan att väger mer än 250 g — välj DJI Mini 5 Pro. Vill du ha bäst kamera och är redo för drönarkort — Air 3S.
    </p>
  </section>

  <section class="mb-10 bg-white rounded-xl border border-border p-5">
    <h2 class="font-heading text-lg font-bold text-text mb-2">Se vår fullständiga drönare-topplista</h2>
    <a href="/dronare/" class="inline-flex items-center text-accent hover:underline font-medium text-sm">
      Alla drönare vi testat 2026
      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
    </a>
  </section>

  <FAQ items={faqItems} />

  <section class="mt-10 p-5 bg-bg-alt rounded-xl border border-border">
    <h2 class="font-heading text-lg font-bold text-text mb-3">Relaterade artiklar</h2>
    <ul class="space-y-2">
      <li><a href="/dji-mini-5-pro/" class="text-accent hover:underline text-sm">DJI Mini 5 Pro recension — bäst under 250 g</a></li>
      <li><a href="/dronare-med-kamera/" class="text-accent hover:underline text-sm">Bästa drönare med kamera 2026</a></li>
      <li><a href="/dronare/" class="text-accent hover:underline text-sm">Bästa drönaren 2026 — komplett topplista</a></li>
    </ul>
  </section>
</ArticleLayout>

<StickyCTA
  text="Se pris på DJI Air 3S"
  url={ctaUrl}
  productName="DJI Air 3S"
/>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["Product", "Review"],
  "name": "DJI Air 3S",
  "brand": { "@type": "Brand", "name": "DJI" },
  "category": "Drönare",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "SEK",
    "price": "13199",
    "availability": "https://schema.org/InStock",
    "shippingDetails": {"@type":"OfferShippingDetails","shippingDestination":{"@type":"DefinedRegion","addressCountry":"SE"},"deliveryTime":{"@type":"ShippingDeliveryTime","handlingTime":{"@type":"QuantitativeValue","minValue":1,"maxValue":3,"unitCode":"d"},"transitTime":{"@type":"QuantitativeValue","minValue":1,"maxValue":5,"unitCode":"d"}}},
    "hasMerchantReturnPolicy": {"@type":"MerchantReturnPolicy","applicableCountry":"SE","returnPolicyCategory":"https://schema.org/MerchantReturnFiniteReturnWindow","merchantReturnDays":14,"returnMethod":"https://schema.org/ReturnByMail","returnFees":"https://schema.org/ReturnShippingFees"}
  },
  "review": {
    "@type": "Review",
    "reviewRating": { "@type": "Rating", "ratingValue": "9.3", "bestRating": "10", "worstRating": "1" },
    "author": { "@type": "Organization", "name": "Robotjakt" },
    "datePublished": "2026-04-06",
    "reviewBody": "DJI Air 3S är konsumentdrönaren med bäst bildkvalitet 2026. Dubbla 1-tums kameror, 45 min flygtid och 4K HDR för den som vill ha professionellt material.",
    "publisher": { "@type": "Organization", "name": "Robotjakt", "url": "https://robotjakt.se" }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqSchema,
})} />
