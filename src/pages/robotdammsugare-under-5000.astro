---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import FAQ from '../components/FAQ.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const products = [
  {
    rank: 1,
    name: 'Roborock Q10 VF+',
    image: '/images/products/roborock-q10-vf-plus.webp',
    rating: 4.6,
    badge: 'Bäst i test under 5 000 kr',
    pros: [
      'Självtömmande basstation med 70 dagars påsekapacitet',
      'PreciSense LiDAR-navigering, kartlägger rum exakt',
      '7 000 Pa sugkraft, klarar djupare mattor',
      'VibraRise-moppning lyfter mopp över mattor',
    ],
    cons: ['Stor basstation kräver 60×60 cm yta', 'Inga AI-hinder, kan fastna i kablar'],
    ctaText: 'Se pris hos Kjell',
    ctaUrl: 'https://ion.kjell.com/t/t?a=1487384319&as=2063681412&t=2&tk=1&cupa_sku=66993&url=http%3A%2F%2Fwww.kjell.com%2Fse%2Fprodukter%2Fhem-fritid%2Fstadning-rengoring%2Frobotdammsugare%2Froborock-robotdammsugare%2Froborock-q10-vf-robotdammsugare-med-basstation-vit-p66993',
    dataProduct: 'Roborock Q10 VF+',
  },
  {
    rank: 2,
    name: 'Dreame D20 Ultra',
    image: '/images/products/dreame-d20-ultra.webp',
    rating: 4.5,
    badge: 'Bäst på moppning under 5 000 kr',
    pros: [
      'Självtvättande mopp i basstationen',
      '7 000 Pa sugkraft, hanterar både mattor och hårda golv',
      'Smart hinderdetektion med AI-kamera',
      'Hanterar mattor upp till 20 mm tjocka',
    ],
    cons: ['Mindre etablerat än Roborock i appen', 'Saknar varmluftstorkning av mopp'],
    ctaText: 'Se pris hos Kjell',
    ctaUrl: 'https://ion.kjell.com/t/t?a=1487384319&as=2063681412&t=2&tk=1&cupa_sku=66540&url=http%3A%2F%2Fwww.kjell.com%2Fse%2Fprodukter%2Fhem-fritid%2Fstadning-rengoring%2Frobotdammsugare%2Fdreame-robotdammsugare%2Fdreame-d20-ultra-robotdammsugare-vit-p66540',
    dataProduct: 'Dreame D20 Ultra',
  },
  {
    rank: 3,
    name: 'Roborock Q8 Max+',
    image: '/images/products/roborock-q8-max-plus.webp',
    rating: 4.4,
    badge: 'Bästa pris/prestanda',
    pros: [
      'Självtömmande basstation till låg prispunkt',
      'DuoRoller-borste, mindre hårtrassel',
      '5 500 Pa sugkraft räcker för normal hemstädning',
      'PreciSense LiDAR, smart kartläggning',
    ],
    cons: ['Saknar moppning med vibration', 'Ingen AI-hinder'],
    ctaText: 'Se pris hos Kjell',
    ctaUrl: 'https://ion.kjell.com/t/t?a=1487384319&as=2063681412&t=2&tk=1&cupa_sku=66004&url=http%3A%2F%2Fwww.kjell.com%2Fse%2Fprodukter%2Fhem-fritid%2Fstadning-rengoring%2Frobotdammsugare%2Froborock-robotdammsugare%2Froborock-q8-max-helautomatisk-robotdammsugare-vit-p66004',
    dataProduct: 'Roborock Q8 Max+',
  },
  {
    rank: 4,
    name: 'Dreame D10 Plus Gen 2',
    image: '/images/products/dreame-d10-plus-gen2.webp',
    rating: 4.3,
    badge: 'Bäst under 3 000 kr',
    pros: [
      'Självtömmande dock under 3 000 kr',
      '4 000 Pa sugkraft, OK för dagligt underhåll',
      'Lasernavigering med rumsindelning',
      'Tystare än de flesta i prisklassen (54 dB)',
    ],
    cons: ['Lägre sugkraft än Q8 Max+', 'Mindre dammbehållare i basstationen'],
    ctaText: 'Se pris hos Kjell',
    ctaUrl: 'https://ion.kjell.com/t/t?a=1487384319&as=2063681412&t=2&tk=1&cupa_sku=65904&url=http%3A%2F%2Fwww.kjell.com%2Fse%2Fprodukter%2Fhem-fritid%2Fstadning-rengoring%2Frobotdammsugare%2Fdreame-robotdammsugare%2Fdreame-d10-plus-robotdammsugare-gen.-2-p65904',
