const faqItems = [
  {
    question: 'Är robotdammsugare till lägre pris värda pengarna?',
    answer: 'Ja, för normal hemstädning. Roborock Q10 VF+ och Dreame D20 Ultra (båda ) ger 80 procent av prestandan från flaggskepp som Roborock S8 MaxV Ultra . Du betalar främst för LiDAR-navigering och självtömmande dock, vilket finns i hela budgetsegmentet 2026.',
