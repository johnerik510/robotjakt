---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import AuthorByline from '../components/AuthorByline.astro';

interface Props {
  title: string;
  description: string;
  breadcrumbs: { label: string; href?: string }[];
  ogImage?: string;
  lastUpdated?: string;
  datePublished?: string;
  showDisclaimer?: boolean;
  showAuthor?: boolean;
  image?: string;
  productName?: string;
  productBrand?: string;
  productPrice?: string;
  productImage?: string;
  productRating?: string;
  productAffiliateUrl?: string;
  productPros?: string[];
  productCons?: string[];
}

const { title, description, breadcrumbs, ogImage, lastUpdated, datePublished, showDisclaimer = true, showAuthor = true, productName, productBrand, productPrice, productImage, productRating, productAffiliateUrl, productPros = [], productCons = [], image } = Astro.props;

const productSchema = productName ? {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: productName,
  ...(productImage ? { image: `https://robotjakt.se${productImage}` } : {}),
  ...(productBrand ? { brand: { '@type': 'Brand', name: productBrand } } : {}),
  description: description || '',
  ...(productRating ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: productRating,
      bestRating: '10',
      worstRating: '1',
      ratingCount: '1',
    },
    review: {
      '@type': 'Review',
      reviewRating: {
        '@type': 'Rating',
        ratingValue: productRating,
        bestRating: '10',
      },
      author: { '@id': 'https://robotjakt.se/#axel' },
      datePublished: datePublished || lastUpdated,
      ...(productPros.length > 0 ? {
        positiveNotes: {
          '@type': 'ItemList',
          itemListElement: productPros.map((p, i) => ({ '@type': 'ListItem', position: i + 1, name: p })),
        },
      } : {}),
      ...(productCons.length > 0 ? {
        negativeNotes: {
          '@type': 'ItemList',
          itemListElement: productCons.map((c, i) => ({ '@type': 'ListItem', position: i + 1, name: c })),
        },
      } : {}),
    },
  } : {}),
} : null;

const pageUrl = Astro.url.href;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Hem', item: 'https://robotjakt.se/' },
    ...breadcrumbs.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: b.label,
      ...(b.href ? { item: `https://robotjakt.se${b.href}` } : {}),
    })),
  ],
};

// Auto-generera relaterade artiklar från samma sektion
const autoPathname = Astro.url.pathname.replace(/\/$/, '');
const autoSection = autoPathname.split('/').filter(Boolean)[0];
let autoRelated: { title: string; href: string }[] = [];
if (autoSection) {
  const pagesGlob = import.meta.glob('/src/pages/**/*.astro', { eager: false });
  const mdGlob = import.meta.glob('/src/pages/**/*.md', { eager: false });
  const allPaths = [...Object.keys(pagesGlob), ...Object.keys(mdGlob)];
  autoRelated = allPaths
    .map((p) => {
      const rel = p.replace('/src/pages', '').replace(/\.(astro|md)$/, '').replace(/\/index$/, '');
      return rel || '/';
    })
    .filter((href) => {
      if (href === autoPathname || href === autoPathname + '/') return false;
      if (href.startsWith('/404') || href.includes('[')) return false;
      if (href === '/' || href === `/${autoSection}` || href === `/${autoSection}/`) return false;
      return href.startsWith(`/${autoSection}/`);
    })
    .slice(0, 6)
    .map((href) => {
      const slug = href.split('/').filter(Boolean).pop() || '';
      const label = slug.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
      return { title: label, href: href.endsWith('/') ? href : href + '/' };
    });
}

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title.split('|')[0]?.trim() || title,
  url: pageUrl,
  ...(lastUpdated ? { dateModified: lastUpdated } : {}),
  ...(datePublished ? { datePublished } : {}),
  image: ogImage ? (ogImage.startsWith('http') ? ogImage : `https://robotjakt.se${ogImage}`) : 'https://robotjakt.se/og-default.jpg',
  author: { '@id': 'https://robotjakt.se/#axel' },
  publisher: { '@id': 'https://robotjakt.se/#organization' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  inLanguage: 'sv-SE',
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} hideAutoRelated={true}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={breadcrumbs} />
    {showAuthor && (
      <AuthorByline datePublished={datePublished} dateModified={lastUpdated} />
    )}
    {image && (
      <div class="mb-6 rounded-xl overflow-hidden aspect-[16/9] bg-slate-100">
        <img src={image} alt={title} class="w-full h-full object-cover" loading="lazy" width="1200" height="675" />
      </div>
    )}
    <slot />
    {autoRelated.length > 0 && (
      <aside class="mt-12 pt-8 border-t border-slate-200">
        <h2 class="text-xl font-bold text-slate-900 mb-4">Relaterade guider</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {autoRelated.map((article) => (
            <a href={article.href} class="block p-4 bg-white rounded-lg border border-slate-200 hover:border-blue-400 hover:shadow-md transition-all">
              <span class="font-medium text-slate-800 hover:text-blue-700">{article.title}</span>
            </a>
          ))}
        </div>
      </aside>
    )}
    {showDisclaimer && <AffiliateDisclaimer />}
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {productSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  )}
</BaseLayout>
