---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import AuthorByline from '../components/AuthorByline.astro';

interface Props {
  title: string;
  description: string;
  breadcrumbs: { label: string; href?: string }[];
  ogImage?: string;
  lastUpdated?: string;
  datePublished?: string;
  showDisclaimer?: boolean;
  showAuthor?: boolean;
  productName?: string;
  productBrand?: string;
  productPrice?: string;
  productImage?: string;
  productRating?: string;
  productAffiliateUrl?: string;
  productPros?: string[];
  productCons?: string[];
}

const { title, description, breadcrumbs, ogImage, lastUpdated, datePublished, showDisclaimer = true, showAuthor = true, productName, productBrand, productPrice, productImage, productRating, productAffiliateUrl, productPros = [], productCons = [] } = Astro.props;

const productSchema = productName ? {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: productName,
  ...(productImage ? { image: `https://robotjakt.se${productImage}` } : {}),
  ...(productBrand ? { brand: { '@type': 'Brand', name: productBrand } } : {}),
  description: description || '',
  offers: {
    '@type': 'Offer',
    priceCurrency: 'SEK',
    price: productPrice ? productPrice.replace(/[^0-9]/g, '') : '',
    priceValidUntil: '2027-12-31',
    availability: 'https://schema.org/InStock',
    ...(productAffiliateUrl ? { url: productAffiliateUrl } : {}),
  },
  ...(productRating ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: productRating,
      bestRating: '10',
      worstRating: '1',
      ratingCount: '1',
    },
    review: {
      '@type': 'Review',
      reviewRating: {
        '@type': 'Rating',
        ratingValue: productRating,
        bestRating: '10',
      },
      author: {
        '@type': 'Person',
        name: 'John Erik Johansson',
      },
      datePublished: datePublished || lastUpdated || '2026-04-07',
      ...(productPros.length > 0 ? {
        positiveNotes: {
          '@type': 'ItemList',
          itemListElement: productPros.map((p, i) => ({ '@type': 'ListItem', position: i + 1, name: p })),
        },
      } : {}),
      ...(productCons.length > 0 ? {
        negativeNotes: {
          '@type': 'ItemList',
          itemListElement: productCons.map((c, i) => ({ '@type': 'ListItem', position: i + 1, name: c })),
        },
      } : {}),
    },
  } : {}),
} : null;

const pageUrl = Astro.url.href;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Hem', item: 'https://robotjakt.se/' },
    ...breadcrumbs.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: b.label,
      ...(b.href ? { item: `https://robotjakt.se${b.href}` } : {}),
    })),
  ],
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title.split('|')[0]?.trim() || title,
  url: pageUrl,
  ...(lastUpdated ? { dateModified: lastUpdated } : {}),
  ...(datePublished ? { datePublished } : {}),
  author: {
    '@type': 'Person',
    name: 'John Erik Johansson',
    url: 'https://robotjakt.se/om-redaktionen/',
    image: 'https://robotjakt.se/images/john-erik-johansson.webp',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Robotjakt.se',
    url: 'https://robotjakt.se',
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
};
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={breadcrumbs} />
    {showAuthor && (
      <AuthorByline datePublished={datePublished} dateModified={lastUpdated} />
    )}
    <slot />
    {showDisclaimer && <AffiliateDisclaimer />}
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {productSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  )}
</BaseLayout>
