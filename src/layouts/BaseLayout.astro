---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage = '/og-default.jpg', canonical } = Astro.props;
const canonicalUrl = canonical || Astro.url.href;
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Robotjakt" />
  <meta property="og:locale" content="sv_SE" />
  <meta property="og:image" content={ogImage} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <meta name="google-site-verification" content="FM773Rf8kiX_UkWU6y1h0mjcpGtc3fvjrAC8HxCfVz8" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" /></noscript>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Robotjakt",
    "url": "https://robotjakt.se",
    "description": "Vi testar och jämför robotdammsugare för den svenska marknaden. Oberoende recensioner och uppdaterade priser.",
    "inLanguage": "sv-SE"
  })} />

  <!-- GSC verification placeholder -->
  <!-- <meta name="google-site-verification" content="VERIFICATION_CODE" /> -->

  <!-- Addrevenue Easylinks – auto-converts direct links to affiliate tracking -->
  <script async src="https://addrevenue.io/easylinks.min.js?c=3467197" is:inline></script>
</head>
<body class="bg-bg text-text font-sans antialiased">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[200] focus:bg-accent focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold">Hoppa till innehåll</a>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <CookieConsent />

  <!-- Deferred: GA4 + Clarity -->
  <script>
    function loadDeferredScripts() {
      // GA4
      var gs = document.createElement('script');
      gs.src = 'https://www.googletagmanager.com/gtag/js?id=G-G2V09YKFPS';
      gs.async = true;
      document.head.appendChild(gs);
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', 'G-G2V09YKFPS');

      // Microsoft Clarity
      (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","s2r9tpq83x");
    }
    if (document.readyState === 'complete') {
      loadDeferredScripts();
    } else {
      window.addEventListener('load', loadDeferredScripts);
    }
  </script>

  <!-- Affiliate click tracking -->
  <script>
    document.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('a[rel*="sponsored"]') as HTMLAnchorElement;
      if (!link) return;

      const url = new URL(link.href);
      const merchant = url.hostname.replace('www.', '').replace('.se', '').replace('.com', '');
      const product = link.closest('[data-product]')?.getAttribute('data-product') ||
                      link.textContent?.trim() || '';
      const article = document.title.split('|')[0]?.trim() || '';

      if (typeof gtag === 'function') {
        gtag('event', 'affiliate_click', {
          merchant,
          product,
          article,
          link_url: link.href,
        });
      }

      console.debug('affiliate_click', { merchant, product, article });
    });
  </script>
</body>
</html>
